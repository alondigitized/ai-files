---
import StoryLayout from '../../layouts/StoryLayout.astro';
import stories from '../../data/stories.json';

const story = stories.find(s => s.slug === 'evoranker-rare-disease')!;
---

<style is:global>
  .phantom-wrap { width: 100%; margin: 0; line-height: 0; }
  .evoranker-rare-disease-canvas { display: block; width: 100%; height: 380px; background: var(--bg); }

  /* Light-theme text overrides for WCAG 2.2 AA contrast — --story (#10b981) on cream
     yields ~2.24:1; darker emerald #066d4f achieves 5.60:1. Applied to shared
     layout elements and all story-specific emerald text surfaces. */
  :root[data-theme="light"] h2 .num,
  :root[data-theme="light"] .story-chapter,
  :root[data-theme="light"] .wi-label,
  :root[data-theme="light"] .evo-bench-num,
  :root[data-theme="light"] .evo-bench-terminal-body .evo-bench-rank-1,
  :root[data-theme="light"] .evo-bench-terminal-dot,
  :root[data-theme="light"] .evo-bottleneck-col.evo-bottleneck-evo .evo-bottleneck-header,
  :root[data-theme="light"] .evo-bottleneck-evo .evo-bottleneck-node,
  :root[data-theme="light"] .evo-bottleneck-evo .evo-bottleneck-result,
  :root[data-theme="light"] .evo-bottleneck-evo .evo-bottleneck-arrow,
  :root[data-theme="light"] .evo-supt4h1-header span,
  :root[data-theme="light"] .evo-supt4h1-after .evo-supt4h1-col-label,
  :root[data-theme="light"] .evo-supt4h1-treatment {
    color: #066d4f;
  }
  :root[data-theme="light"] .evo-bottleneck-trad .evo-bottleneck-node,
  :root[data-theme="light"] .evo-bottleneck-trad .evo-bottleneck-result {
    color: #755a17;
  }

  /* Reenactment 1 — Bottleneck diagram */
  .evo-bottleneck-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin: 2rem 0;
  }
  .evo-bottleneck-col {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .evo-bottleneck-header {
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .evo-bottleneck-col.evo-bottleneck-trad .evo-bottleneck-header {
    background: color-mix(in srgb, var(--muted) 8%, var(--surface));
  }
  .evo-bottleneck-col.evo-bottleneck-evo .evo-bottleneck-header {
    background: color-mix(in srgb, var(--story) 10%, var(--surface));
    color: var(--story);
  }
  .evo-bottleneck-body {
    padding: 1.25rem;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
    font-size: 0.78rem;
    line-height: 1.6;
  }
  .evo-bottleneck-step {
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
  .evo-bottleneck-arrow {
    color: var(--muted);
    font-size: 0.72rem;
    margin: 0.3rem 0;
  }
  .evo-bottleneck-col.evo-bottleneck-evo .evo-bottleneck-arrow {
    color: var(--story);
  }
  .evo-bottleneck-node {
    padding: 0.5rem 0.75rem;
    border-radius: 0.4rem;
    margin: 0.5rem 0;
    font-size: 0.75rem;
    line-height: 1.4;
  }
  .evo-bottleneck-trad .evo-bottleneck-node {
    background: color-mix(in srgb, var(--accent) 8%, var(--surface));
    border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--border));
    color: var(--accent);
  }
  .evo-bottleneck-evo .evo-bottleneck-node {
    background: color-mix(in srgb, var(--story) 10%, var(--surface));
    border: 1px solid color-mix(in srgb, var(--story) 25%, var(--border));
    color: var(--story);
  }
  .evo-bottleneck-result {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    font-size: 0.75rem;
    font-weight: 700;
  }
  .evo-bottleneck-trad .evo-bottleneck-result {
    color: var(--accent);
  }
  .evo-bottleneck-evo .evo-bottleneck-result {
    color: var(--story);
  }
  .evo-bottleneck-footer {
    font-size: 0.68rem;
    color: var(--muted);
    font-style: italic;
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--border);
    grid-column: 1 / -1;
  }
  @media (max-width: 600px) {
    .evo-bottleneck-wrap { grid-template-columns: 1fr; }
  }

  /* Reenactment 2 — Benchmark stat cards + ranked output */
  .evo-bench-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 2rem 0 1.5rem;
  }
  .evo-bench-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    text-align: center;
  }
  .evo-bench-num {
    font-size: 2rem;
    font-weight: 900;
    color: var(--story);
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  .evo-bench-label {
    font-size: 0.72rem;
    color: var(--muted);
    line-height: 1.3;
  }
  .evo-bench-terminal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    overflow: hidden;
    margin: 1.5rem 0 2rem;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }
  .evo-bench-terminal-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--surface2, var(--surface));
    border-bottom: 1px solid var(--border);
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .evo-bench-terminal-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--story);
  }
  .evo-bench-terminal-body {
    padding: 1.25rem;
    font-size: 0.78rem;
    line-height: 1.7;
    color: var(--muted);
    overflow-x: auto;
  }
  .evo-bench-terminal-body .evo-bench-label-line {
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .evo-bench-terminal-body .evo-bench-case {
    color: var(--text);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .evo-bench-terminal-body .evo-bench-row {
    display: grid;
    grid-template-columns: 3rem 5.5rem 8.5rem auto;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
    white-space: nowrap;
  }
  .evo-bench-terminal-body .evo-bench-row-header {
    font-weight: 700;
    color: var(--text);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.35rem;
  }
  .evo-bench-terminal-body .evo-bench-rank-1 {
    color: var(--story);
    font-weight: 700;
  }
  .evo-bench-terminal-footer {
    font-size: 0.68rem;
    color: var(--muted);
    font-style: italic;
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--border);
  }
  @media (max-width: 600px) {
    .evo-bench-stats { grid-template-columns: 1fr; }
    .evo-bench-terminal-body .evo-bench-row { grid-template-columns: 2.5rem 4rem 7rem auto; font-size: 0.72rem; }
  }

  /* Reenactment 3 — SUPT4H1 before/after */
  .evo-supt4h1-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    overflow: hidden;
    margin: 2rem 0;
  }
  .evo-supt4h1-header {
    padding: 0.75rem 1.25rem;
    background: var(--surface2, var(--surface));
    border-bottom: 1px solid var(--border);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.02em;
  }
  .evo-supt4h1-header span {
    color: var(--story);
  }
  .evo-supt4h1-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .evo-supt4h1-col {
    padding: 1.25rem;
  }
  .evo-supt4h1-col + .evo-supt4h1-col {
    border-left: 1px solid var(--border);
  }
  .evo-supt4h1-col-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .evo-supt4h1-before .evo-supt4h1-col-label {
    color: var(--muted);
  }
  .evo-supt4h1-after .evo-supt4h1-col-label {
    color: var(--story);
  }
  .evo-supt4h1-row {
    margin-bottom: 0.75rem;
  }
  .evo-supt4h1-row-key {
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.15rem;
  }
  .evo-supt4h1-row-val {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.4;
  }
  .evo-supt4h1-before .evo-supt4h1-row-val {
    color: var(--muted);
    font-style: italic;
  }
  .evo-supt4h1-after .evo-supt4h1-row-val {
    color: var(--text);
  }
  .evo-supt4h1-treatment {
    color: var(--story);
    font-weight: 700;
  }
  .evo-supt4h1-footer {
    font-size: 0.68rem;
    color: var(--muted);
    font-style: italic;
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--border);
  }
  @media (max-width: 600px) {
    .evo-supt4h1-grid { grid-template-columns: 1fr; }
    .evo-supt4h1-col + .evo-supt4h1-col { border-left: none; border-top: 1px solid var(--border); }
  }
</style>

<StoryLayout story={story}>
  <div class="container">

    <section class="section" id="bottleneck">
      <h2><span class="num">01 — Context</span>The Annotation Bottleneck</h2>
      <p>Rare diseases are individually rare and collectively enormous. An estimated 300 million people worldwide live with one. Most of these conditions are genetic. Most are diagnosed — when they are diagnosed at all — through a process that begins with whole-exome sequencing: reading the protein-coding regions of a patient's genome, filtering for unusual variants, and producing a list of candidate genes that might explain the symptoms.</p>
      <p>The list is where the process stalls. A typical exome yields dozens of rare variants. To determine which one is causative, clinicians feed that list into gene-ranking tools — software that scores each candidate against databases of known gene-disease associations, protein interactions, and phenotype ontologies. These tools work well when the causative gene has been studied before. When it has not, they are blind. As of January 2023, the Human Phenotype Ontology covered approximately 4,900 genes. The human genome contains roughly 20,000 protein-coding genes. That leaves around 15,000 genes for which the annotation databases have little or nothing to say.</p>
      <p>This is a circular problem. You cannot prioritize a gene your tools have never encountered in a disease context. And those tools will never encounter it until someone publishes a study linking it to disease — which requires identifying it as a candidate in the first place. The diagnostic yield of whole-exome sequencing stalls at roughly 25–50% across clinical studies. The bottleneck is not sequencing technology. It is prior knowledge.</p>
      <p>EvORanker was built on a different premise. Genes that co-evolve across species share functional constraints. If two genes are always gained or lost together across a thousand lineages — mammals, fungi, plants, arthropods — they are likely part of the same biological machinery. This signal exists whether or not any human researcher has written a paper about either gene. It is, in effect, a four-billion-year annotation database that no one had formatted for clinical use.</p>

      <div class="evo-bottleneck-wrap">
        <div class="evo-bottleneck-col evo-bottleneck-trad">
          <div class="evo-bottleneck-header">Traditional Tools (ExomeWalker, PHIVE)</div>
          <div class="evo-bottleneck-body">
            <div class="evo-bottleneck-step">Patient Exome</div>
            <div class="evo-bottleneck-arrow">&#8595;</div>
            <div class="evo-bottleneck-step">Variant Filter</div>
            <div class="evo-bottleneck-arrow">&#8595;</div>
            <div class="evo-bottleneck-step">Candidate Gene List</div>
            <div class="evo-bottleneck-arrow">&#8595;</div>
            <div class="evo-bottleneck-node">ANNOTATION DATABASE<br/>~4,900 genes annotated<br/>~15,000 genes unstudied</div>
            <div class="evo-bottleneck-arrow">&#8595;</div>
            <div class="evo-bottleneck-result">Poorly annotated genes &#10005; unranked</div>
          </div>
        </div>
        <div class="evo-bottleneck-col evo-bottleneck-evo">
          <div class="evo-bottleneck-header">EvORanker</div>
          <div class="evo-bottleneck-body">
            <div class="evo-bottleneck-step">Patient Exome</div>
            <div class="evo-bottleneck-arrow">&#8595;</div>
            <div class="evo-bottleneck-step">Variant Filter</div>
            <div class="evo-bottleneck-arrow">&#8595;</div>
            <div class="evo-bottleneck-step">Candidate Gene List</div>
            <div class="evo-bottleneck-arrow">&#8595;</div>
            <div class="evo-bottleneck-node">EVOLUTIONARY CO-OCCURRENCE<br/>1,028 species / 16 clades<br/>Signal exists for all genes</div>
            <div class="evo-bottleneck-arrow">&#8595;</div>
            <div class="evo-bottleneck-result">All candidates ranked &#10003;</div>
          </div>
        </div>
        <div class="evo-bottleneck-footer">The annotation bottleneck: traditional tools rank genes by what humans have published. EvORanker ranks genes by how they co-evolved across 1,028 species — a signal that exists independent of prior study.</div>
      </div>
    </section>

    <section class="section" id="tool">
      <h2><span class="num">02 — The Tool</span>Reading Evolution</h2>
      <p>Dr. Christina Canavati and Prof. Yuval Tabach built EvORanker at the Hebrew University of Jerusalem's Department of Developmental Biology and Cancer Research. The tool was published in <em>Genome Medicine</em> on January 4, 2024. Its lineage stretches back over a decade. In 2013, Tabach — working with Gary Ruvkun (later awarded the 2024 Nobel Prize in Physiology or Medicine) at Massachusetts General Hospital — published the foundational method: phylogenetic profiling of 19,017 human proteins across 86 eukaryotic genomes, sorting them into approximately 1,076 co-evolved clusters. A 2021 <em>Nature Communications</em> paper scaled the approach with machine learning across 1,154 species, achieving a 14% improvement in area under the ROC curve for predicting functional gene interactions. EvORanker is the clinical integration of that research.</p>
      <p>The method works as follows. For every human gene, EvORanker computes a normalized phylogenetic profile — a vector of BLASTP similarity scores against 1,028 eukaryotic species, log2-transformed and z-score normalized to correct for phylogenetic distance bias. Genes with similar profiles across species are likely functionally related. The tool groups species into 16 representative clades — Chordata, Mammalia, Fungi, Arthropoda, Nematoda, Viridiplantae, and others — and selects the top 100 co-evolving genes per candidate in each clade. A one-tailed Kolmogorov–Smirnov test then measures whether those co-evolving genes are significantly enriched among known phenotype-related genes. Fisher's combined probability test merges the phylogenetic signal with protein-interaction data from the STRING database to produce a final ranked list.</p>
      <p>The output is concrete: a CSV file with each candidate gene, its Fisher p-value, and its rank. A clinician holding a list of 47 rare homozygous variants gets back a ranked list telling them which gene is the most likely cause of the patient's symptoms — and how confident the evolutionary signal is.</p>

      <div class="evo-bench-stats">
        <div class="evo-bench-card">
          <div class="evo-bench-num">69%</div>
          <div class="evo-bench-label">Correct gene ranked #1<br/>(recessive cases)</div>
        </div>
        <div class="evo-bench-card">
          <div class="evo-bench-num">95%</div>
          <div class="evo-bench-label">Correct gene in top 5<br/>(recessive cases)</div>
        </div>
        <div class="evo-bench-card">
          <div class="evo-bench-num">1,028</div>
