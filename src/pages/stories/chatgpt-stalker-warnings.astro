---
import StoryLayout from '../../layouts/StoryLayout.astro';
import stories from '../../data/stories.json';

const story = stories.find(s => s.slug === 'chatgpt-stalker-warnings')!;
---

<style is:global>
  /* === Block A: Email Chain === */
