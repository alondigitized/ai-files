    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
    font-size: 0.72rem;
  }
  .tw-email-from { color: var(--text); font-weight: 600; }
  .tw-email-date { color: var(--muted); font-variant-numeric: tabular-nums; }
