  const P_W2_RISE_END   = 260;
  const P_W2_HOLD_END   = 280;
  const P_W2_FLAT_END   = 315;

  const P_W3_START      = 440;
  const P_W3_RISE_END   = 460;
  const P_W3_HOLD_END   = 485;
  const P_W3_FLAT_END   = 535;

  const P_CALM_START    = 620;
  const P_CALM_END      = 900;

  const P_FADE_START    = 900;
  const P_FADE_END      = 960;

  const SPIKE1_X_FRAC = 0.30;
  const SPIKE2_X_FRAC = 0.50;
  const SPIKE3_X_FRAC = 0.70;

  const SPIKE1_HEIGHT = 40;
  const SPIKE2_HEIGHT = 60;
  const SPIKE3_HEIGHT = 85;

  const SPIKE1_ALPHA = 0.6;
  const SPIKE2_ALPHA = 0.75;
  const SPIKE3_ALPHA = 0.9;

  const STAIN1_RADIUS = 50;
  const STAIN2_RADIUS = 70;
  const STAIN3_RADIUS = 90;

  const STAIN1_ALPHA = 0.03;
  const STAIN2_ALPHA = 0.05;
  const STAIN3_ALPHA = 0.07;

  let W = 0, H = 0, rafId = 0, frame = 0;

  const AMBIENT_COUNT = 9;
  interface Ambient { x: number; y: number; vx: number; vy: number; r: number; alpha: number; }
  const ambients: Ambient[] = [];
  for (let i = 0; i < AMBIENT_COUNT; i++) {
    ambients.push({
      x: Math.random(), y: Math.random(),
      vx: (Math.random() - 0.5) * 0.24,
      vy: (Math.random() - 0.5) * 0.24,
      r: 1 + Math.random() * 0.5,
      alpha: 0.03 + Math.random() * 0.02
    });
  }

  let stain1Active = false;
  let stain2Active = false;
  let stain3Active = false;

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function resize() {
    if (!canvas) return;
    W = canvas.offsetWidth;
    H = canvas.offsetHeight;
    canvas.width = W * devicePixelRatio;
    canvas.height = H * devicePixelRatio;
    ctx!.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
  }

  const ro = new ResizeObserver(() => {
    resize();
    if (reduced) drawStatic();
  });
  ro.observe(canvas);

  function rgba(r: number, g: number, b: number, a: number): string {
    return `rgba(${r},${g},${b},${Math.max(0, Math.min(1, a))})`;
  }
  function easeOut(t: number): number { return 1 - (1 - t) * (1 - t); }
  function easeIn(t: number): number { return t * t; }
  function lerp(a: number, b: number, t: number): number { return a + (b - a) * t; }

  function drawLine(lineY: number, lineAlpha: number, pulseX: number) {
    if (lineAlpha <= 0) return;
    const x0 = W * 0.10;
    const x1 = W * 0.90;
    ctx!.beginPath();
    ctx!.moveTo(x0, lineY);
    ctx!.lineTo(x1, lineY);
    ctx!.strokeStyle = rgba(LINE_R, LINE_G, LINE_B, 0.12 * lineAlpha);
    ctx!.lineWidth = 1;
    ctx!.stroke();

    const pulseWidth = 40;
    const steps = 20;
    for (let i = 0; i < steps; i++) {
      const frac = i / steps;
      const px = pulseX - pulseWidth / 2 + frac * pulseWidth;
      if (px < x0 || px > x1) continue;
      const dist = Math.abs(frac - 0.5) * 2;
      const brightness = Math.exp(-dist * dist * 3);
      ctx!.beginPath();
      ctx!.moveTo(px, lineY);
      ctx!.lineTo(px + pulseWidth / steps + 1, lineY);
      ctx!.strokeStyle = rgba(LINE_R, LINE_G, LINE_B, (0.06 + 0.12 * brightness) * lineAlpha);
      ctx!.lineWidth = 1.5;
      ctx!.stroke();
    }
  }

  function drawSpike(cx: number, lineY: number, height: number, alpha: number, globalAlpha: number) {
    if (height <= 0.5 || alpha <= 0 || globalAlpha <= 0) return;
    const a = alpha * globalAlpha;
    const baseW = 8;
    ctx!.beginPath();
    ctx!.moveTo(cx - baseW, lineY);
    ctx!.quadraticCurveTo(cx - baseW * 0.3, lineY - height * 0.7, cx, lineY - height);
    ctx!.lineTo(cx + baseW, lineY);
    ctx!.closePath();
    ctx!.fillStyle = rgba(ACCENT_R, ACCENT_G, ACCENT_B, a);
    ctx!.fill();

    const glowRadius = 15 + height * 0.3;
    const grd = ctx!.createRadialGradient(cx, lineY, 0, cx, lineY, glowRadius);
    grd.addColorStop(0, rgba(ACCENT_R, ACCENT_G, ACCENT_B, 0.08 * a));
    grd.addColorStop(1, rgba(ACCENT_R, ACCENT_G, ACCENT_B, 0));
    ctx!.beginPath();
    ctx!.arc(cx, lineY, glowRadius, 0, Math.PI * 2);
    ctx!.fillStyle = grd;
    ctx!.fill();
  }

  function drawWeight(cx: number, weightY: number, lineY: number, alpha: number) {
    if (alpha <= 0 || weightY > lineY) return;
    const w = 30;
    const h = lineY - weightY;
    if (h < 2) return;
    ctx!.fillStyle = rgba(LINE_R, LINE_G, LINE_B, 0.045 * alpha);
    ctx!.fillRect(cx - w / 2, weightY, w, h);
  }

  function drawRing(cx: number, cy: number, radius: number, alpha: number) {
    if (alpha <= 0 || radius <= 0) return;
    ctx!.beginPath();
    ctx!.arc(cx, cy, radius, 0, Math.PI * 2);
    ctx!.strokeStyle = rgba(ACCENT_R, ACCENT_G, ACCENT_B, alpha);
    ctx!.lineWidth = 1;
    ctx!.stroke();
  }

  function drawStain(cx: number, lineY: number, radius: number, alpha: number, globalAlpha: number) {
    if (alpha <= 0 || globalAlpha <= 0) return;
    const a = alpha * globalAlpha;
    const cy = lineY + radius * 0.4;
    const grd = ctx!.createRadialGradient(cx, cy, 0, cx, cy, radius);
    grd.addColorStop(0, rgba(ACCENT_R, ACCENT_G, ACCENT_B, a));
    grd.addColorStop(0.6, rgba(ACCENT_R, ACCENT_G, ACCENT_B, a * 0.5));
    grd.addColorStop(1, rgba(ACCENT_R, ACCENT_G, ACCENT_B, 0));
    ctx!.beginPath();
    ctx!.arc(cx, cy, radius, 0, Math.PI * 2);
    ctx!.fillStyle = grd;
    ctx!.fill();
  }

  function drawAmbients(globalAlpha: number) {
    for (const p of ambients) {
      ctx!.beginPath();
      ctx!.arc(p.x * W, p.y * H, p.r, 0, Math.PI * 2);
      ctx!.fillStyle = rgba(LINE_R, LINE_G, LINE_B, p.alpha * globalAlpha);
      ctx!.fill();
    }
  }

  function updateAmbients() {
    for (const p of ambients) {
      p.x += p.vx / W;
      p.y += p.vy / H;
      if (p.x < 0) p.x += 1;
      if (p.x > 1) p.x -= 1;
      if (p.y < 0) p.y += 1;
      if (p.y > 1) p.y -= 1;
    }
  }

  function getSpikeState(f: number, startFrame: number, riseEnd: number, holdEnd: number,
    flatEnd: number, maxHeight: number, maxAlpha: number, spikeIndex: number) {
    const result = { height: 0, alpha: 0, weightY: 0, weightAlpha: 0, ringRadius: 0, ringAlpha: 0 };
    if (f < startFrame || f > flatEnd + 30) return result;
    if (f <= riseEnd) {
      const t = (f - startFrame) / (riseEnd - startFrame);
      const easedT = easeOut(t);
      result.height = maxHeight * easedT;
      result.alpha = maxAlpha * easedT;
    } else if (f <= holdEnd) {
      result.height = maxHeight;
      result.alpha = maxAlpha;
      if (spikeIndex === 2) {
        const t = (f - riseEnd) / (holdEnd - riseEnd);
        result.ringRadius = 40 * t;
        result.ringAlpha = 0.3 * (1 - t);
      }
    } else if (f <= flatEnd) {
      const suppressDur = flatEnd - holdEnd;
      let t = (f - holdEnd) / suppressDur;
      if (spikeIndex === 2) {
        const suppressFrame = f - holdEnd;
        const pause1Start = Math.floor(suppressDur * 0.3);
        const pause1End = pause1Start + 5;
        const pause2Start = Math.floor(suppressDur * 0.6);
        const pause2End = pause2Start + 5;
        if (suppressFrame >= pause1Start && suppressFrame < pause1End) {
          t = pause1Start / suppressDur;
        } else if (suppressFrame >= pause1End && suppressFrame < pause2Start) {
          t = lerp(pause1Start / suppressDur, pause2Start / suppressDur,
            (suppressFrame - pause1End) / (pause2Start - pause1End));
        } else if (suppressFrame >= pause2Start && suppressFrame < pause2End) {
          t = pause2Start / suppressDur;
        } else if (suppressFrame >= pause2End) {
          t = lerp(pause2Start / suppressDur, 1.0,
            (suppressFrame - pause2End) / (suppressDur - pause2End));
        }
      }
      const easedT = easeIn(t);
      result.height = maxHeight * (1 - easedT);
      result.alpha = maxAlpha * (1 - easedT * 0.8);
      result.weightAlpha = 1 - t;
    } else {
      if (spikeIndex === 2 && f <= flatEnd + 30) {
        const t = (f - flatEnd) / 30;
        result.ringRadius = 40 + 10 * t;
        result.ringAlpha = 0.1 * (1 - t);
      }
    }
    return result;
  }

  function draw() {
    if (!ctx) return;
    ctx.clearRect(0, 0, W, H);
    const f = frame % TOTAL;
    const lineY = H * 0.5;

    let globalAlpha = 1;
    if (f >= P_FADE_START && f < P_FADE_END) {
      globalAlpha = 1 - (f - P_FADE_START) / (P_FADE_END - P_FADE_START);
    } else if (f >= P_FADE_END) {
      globalAlpha = 0;
    }

    let shadowAlpha = 1;
    if (f >= P_FADE_START && f < P_FADE_END) {
      const fadeProg = (f - P_FADE_START) / (P_FADE_END - P_FADE_START);
      shadowAlpha = 1 - fadeProg * 0.6;
    } else if (f >= P_FADE_END) {
      const lingerFrames = 30;
      if (f < P_FADE_END + lingerFrames) {
        const t = (f - P_FADE_END) / lingerFrames;
        shadowAlpha = 0.4 * (1 - t);
      } else {
        shadowAlpha = 0;
      }
    }

    let lineAlpha = globalAlpha;
    if (f < P_LINE_END) {
      lineAlpha = (f / P_LINE_END) * globalAlpha;
    }

    const pulseSpeed = 0.5;
    const lineX0 = W * 0.10;
    const lineX1 = W * 0.90;
    const lineLen = lineX1 - lineX0;
    const pulseX = lineX0 + ((f * pulseSpeed) % lineLen);

    if (f >= P_W1_FLAT_END) stain1Active = true;
    if (f >= P_W2_FLAT_END) stain2Active = true;
    if (f >= P_W3_FLAT_END) stain3Active = true;
    if (f < 5) {
      stain1Active = false;
      stain2Active = false;
      stain3Active = false;
    }

    let calmGrowth = 0;
    if (f >= P_CALM_START && f < P_CALM_END) {
      calmGrowth = (f - P_CALM_START) / (P_CALM_END - P_CALM_START);
    } else if (f >= P_CALM_END) {
      calmGrowth = 1;
    }

    if (stain1Active) {
      drawStain(W * SPIKE1_X_FRAC, lineY, STAIN1_RADIUS + calmGrowth * 4, STAIN1_ALPHA + calmGrowth * 0.01, shadowAlpha);
    }
    if (stain2Active) {
      drawStain(W * SPIKE2_X_FRAC, lineY, STAIN2_RADIUS + calmGrowth * 4, STAIN2_ALPHA + calmGrowth * 0.01, shadowAlpha);
    }
    if (stain3Active) {
      drawStain(W * SPIKE3_X_FRAC, lineY, STAIN3_RADIUS + calmGrowth * 4, STAIN3_ALPHA + calmGrowth * 0.01, shadowAlpha);
    }

    if (f >= P_W1_HOLD_END && f < P_W1_FLAT_END && !stain1Active) {
      const t = (f - P_W1_HOLD_END) / (P_W1_FLAT_END - P_W1_HOLD_END);
      drawStain(W * SPIKE1_X_FRAC, lineY, STAIN1_RADIUS * t, STAIN1_ALPHA * t, globalAlpha);
    }
    if (f >= P_W2_HOLD_END && f < P_W2_FLAT_END && !stain2Active) {
      const t = (f - P_W2_HOLD_END) / (P_W2_FLAT_END - P_W2_HOLD_END);
      drawStain(W * SPIKE2_X_FRAC, lineY, STAIN2_RADIUS * t, STAIN2_ALPHA * t, globalAlpha);
    }
    if (f >= P_W3_HOLD_END && f < P_W3_FLAT_END && !stain3Active) {
      const t = (f - P_W3_HOLD_END) / (P_W3_FLAT_END - P_W3_HOLD_END);
      drawStain(W * SPIKE3_X_FRAC, lineY, STAIN3_RADIUS * t, STAIN3_ALPHA * t, globalAlpha);
    }

    drawLine(lineY, lineAlpha, pulseX);

    const s1 = getSpikeState(f, P_W1_START, P_W1_RISE_END, P_W1_HOLD_END, P_W1_FLAT_END, SPIKE1_HEIGHT, SPIKE1_ALPHA, 0);
    const s2 = getSpikeState(f, P_W2_START, P_W2_RISE_END, P_W2_HOLD_END, P_W2_FLAT_END, SPIKE2_HEIGHT, SPIKE2_ALPHA, 1);
    const s3 = getSpikeState(f, P_W3_START, P_W3_RISE_END, P_W3_HOLD_END, P_W3_FLAT_END, SPIKE3_HEIGHT, SPIKE3_ALPHA, 2);

    if (s1.weightAlpha > 0) drawWeight(W * SPIKE1_X_FRAC, lineY - s1.height - 20, lineY, s1.weightAlpha * globalAlpha);
    if (s2.weightAlpha > 0) drawWeight(W * SPIKE2_X_FRAC, lineY - s2.height - 20, lineY, s2.weightAlpha * globalAlpha);
    if (s3.weightAlpha > 0) drawWeight(W * SPIKE3_X_FRAC, lineY - s3.height - 20, lineY, s3.weightAlpha * globalAlpha);

    drawSpike(W * SPIKE1_X_FRAC, lineY, s1.height, s1.alpha, globalAlpha);
    drawSpike(W * SPIKE2_X_FRAC, lineY, s2.height, s2.alpha, globalAlpha);
    drawSpike(W * SPIKE3_X_FRAC, lineY, s3.height, s3.alpha, globalAlpha);

    if (s3.ringRadius > 0 && s3.ringAlpha > 0) {
      drawRing(W * SPIKE3_X_FRAC, lineY, s3.ringRadius, s3.ringAlpha * globalAlpha);
    }

    drawAmbients(globalAlpha);
  }

  function drawStatic() {
    if (!ctx) return;
    ctx.clearRect(0, 0, W, H);
    const lineY = H * 0.5;
    drawStain(W * SPIKE1_X_FRAC, lineY, STAIN1_RADIUS, STAIN1_ALPHA, 1);
    drawStain(W * SPIKE2_X_FRAC, lineY, STAIN2_RADIUS, STAIN2_ALPHA, 1);
    drawStain(W * SPIKE3_X_FRAC, lineY, STAIN3_RADIUS, STAIN3_ALPHA + 0.02, 1);
    const x0 = W * 0.10;
    const x1 = W * 0.90;
    ctx.beginPath();
    ctx.moveTo(x0, lineY);
    ctx.lineTo(x1, lineY);
    ctx.strokeStyle = rgba(LINE_R, LINE_G, LINE_B, 0.12);
    ctx.lineWidth = 1;
    ctx.stroke();
    const spikeH = SPIKE3_HEIGHT * 0.45;
    drawSpike(W * SPIKE3_X_FRAC, lineY, spikeH, SPIKE3_ALPHA * 0.5, 1);
    drawWeight(W * SPIKE3_X_FRAC, lineY - spikeH - 15, lineY, 0.6);
    drawAmbients(1);
  }

  function tick() {
    if (!ctx) return;
    frame++;
    updateAmbients();
    draw();
    rafId = requestAnimationFrame(tick);
  }

  const io = new IntersectionObserver(([e]) => {
    if (e.isIntersecting) {
      if (!reduced && !rafId) rafId = requestAnimationFrame(tick);
    } else {
      if (rafId) { cancelAnimationFrame(rafId); rafId = 0; }
    }
  }, { threshold: 0.01 });

  if (reduced) {
    requestAnimationFrame(() => drawStatic());
  } else {
    io.observe(canvas);
  }

  window.addEventListener('pagehide', () => {
    cancelAnimationFrame(rafId);
    rafId = 0;
    ro.disconnect();
    io.disconnect();
  });
})();
</script>
