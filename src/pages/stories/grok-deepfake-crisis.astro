                <path d="M122,20 C126,34 128,46 128,54" fill="none" stroke="#9a7a58" stroke-width="3" stroke-linecap="round"/>
                <!-- Collarbones -->
                <path d="M74,102 C84,98 92,96 100,96 C108,96 116,98 126,102" fill="none" stroke="#b8a08a" stroke-width="1.2" opacity="0.5"/>

                <!-- === FITTED V-NECK TOP === -->
                <path d="M100,96 C112,96 132,102 144,112 C152,120 156,132 156,144 C156,154 152,162 146,168 C138,176 130,182 126,186 C124,190 124,194 126,198 L74,198 C76,194 76,190 74,186 C70,182 62,176 54,168 C48,162 44,154 44,144 C44,132 48,120 56,112 C68,102 88,96 100,96Z" fill="#4a6a8a"/>
                <!-- V-neckline -->
                <path d="M82,104 C88,116 94,128 100,136 C106,128 112,116 118,104 C112,100 106,98 100,98 C94,98 88,100 82,104Z" fill="url(#sk1)"/>
                <!-- Top hem -->
                <path d="M74,198 L126,198" fill="none" stroke="#3a5a7a" stroke-width="1.2"/>
                <!-- Bust seam -->
                <path d="M54,168 C68,178 86,184 100,184 C114,184 132,178 146,168" fill="none" stroke="#3a5a7a" stroke-width="0.8" opacity="0.5"/>

                <!-- === A-LINE SKIRT === -->
