                <path d="M32,230 C30,246 28,262 28,276 C28,286 30,294 34,298 L42,294 C38,290 36,284 36,274 C36,260 38,244 42,228Z" fill="url(#sk1)"/>
                <path d="M32,294 C28,302 28,310 32,314 C36,316 40,312 42,306 C42,300 42,296 42,292Z" fill="url(#sk1)"/>
                <path d="M30,310 C28,314 30,318 32,316" fill="none" stroke="#c9a584" stroke-width="1.2" stroke-linecap="round"/>
                <!-- === RIGHT ARM (hand on hip) === -->
                <path d="M156,144 C162,156 166,170 166,182 L156,180 C156,170 154,158 148,146Z" fill="url(#sk1)"/>
                <path d="M166,182 C166,194 160,206 152,216 C146,224 138,228 132,230 L128,222 C136,218 144,212 150,204 C156,196 158,188 156,180Z" fill="url(#sk1)"/>
                <path d="M128,222 C124,226 120,232 122,236 C124,240 130,240 134,236 C136,230 134,224 132,222Z" fill="url(#sk1)"/>
                <path d="M124,232 C122,236 124,238 126,238" fill="none" stroke="#c9a584" stroke-width="1" stroke-linecap="round"/>

                <!-- === LEGS (below skirt) === -->
                <path d="M46,350 C44,366 42,384 42,400 C42,416 44,430 46,442 C48,452 48,460 48,468 L66,468 C66,460 66,452 64,442 C62,430 60,416 60,400 C60,384 62,366 64,350Z" fill="url(#sk1)"/>
                <path d="M136,350 C138,366 140,384 140,400 C140,416 138,430 136,442 C134,452 134,460 134,468 L116,468 C116,460 116,452 118,442 C120,430 122,416 122,400 C122,384 120,366 118,350Z" fill="url(#sk1)"/>
                <path d="M44,400 C48,396 54,394 58,396" fill="none" stroke="#d4b49a" stroke-width="1.2" opacity="0.4"/>
                <path d="M138,400 C134,396 128,394 124,396" fill="none" stroke="#d4b49a" stroke-width="1.2" opacity="0.4"/>

                <!-- === SHOES === -->
                <path d="M46,464 C42,470 40,476 44,480 L64,480 C68,476 66,470 64,464Z" fill="#8a2020"/>
                <path d="M46,480 C46,486 48,490 50,490 L50,480Z" fill="#6a1818"/>
                <path d="M136,464 C140,470 142,476 138,480 L118,480 C114,476 116,470 118,464Z" fill="#8a2020"/>
                <path d="M136,480 C136,486 134,490 132,490 L132,480Z" fill="#6a1818"/>

                <!-- === BODY OUTLINE === -->
