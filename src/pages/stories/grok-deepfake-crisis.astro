<script>
(function () {
  const canvas = document.querySelector('.grok-deepfake-crisis-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const ACCENT_R = 217, ACCENT_G = 70, ACCENT_B = 239;
  const PARTICLE_R = 232, PARTICLE_G = 232, PARTICLE_B = 232;
  const BARRIER_NODES = 40;
  const AMBIENT_COUNT = 70;
  const FALLEN_MAX = 200;

  const P0_END = 120;
  const P1_END = 180;
  const P2_END = 240;
  const P3_END = 300;
  const P4_END = 600;
  const P5_END = 690;
  const CYCLE  = 693;

  let W = 0, H = 0, raf = 0, frame = 0;
  let dpr = 1;
  let barrierBaseY = 0;
  let leakAccum = 0;

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  interface BNode { baseX: number; baseY: number; x: number; y: number; oscPhase: number; vy: number; alpha: number; }
  let barrierNodes: BNode[] = [];

  interface AParticle { x: number; y: number; vx: number; vy: number; r: number; alpha: number; wPhase: number; crossing: boolean; crossProgress: number; fallenVy: number; }
  let particles: AParticle[] = [];

  interface FParticle { x: number; y: number; vx: number; vy: number; r: number; alpha: number; active: boolean; }
  let fallen: FParticle[] = [];

  const ro = new ResizeObserver(() => {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    W = canvas!.offsetWidth * dpr;
    H = canvas!.offsetHeight * dpr;
    canvas!.width = W;
    canvas!.height = H;
    barrierBaseY = H * 0.33;
    initState();
    if (prefersReduced) requestAnimationFrame(drawStatic);
  });
  ro.observe(canvas);

  function initState() {
    frame = 0;
    leakAccum = 0;
    barrierNodes = [];
    const spacing = W / (BARRIER_NODES - 1);
    for (let i = 0; i < BARRIER_NODES; i++) {
      const bx = i * spacing;
      const by = barrierBaseY + Math.sin(i * 0.4) * 4 * dpr;
      barrierNodes.push({ baseX: bx, baseY: by, x: bx, y: by, oscPhase: Math.random() * Math.PI * 2, vy: 0, alpha: 1 });
    }
    particles = [];
    for (let i = 0; i < AMBIENT_COUNT; i++) particles.push(spawnAmbient(true));
    fallen = [];
    for (let i = 0; i < FALLEN_MAX; i++) fallen.push({ x: 0, y: 0, vx: 0, vy: 0, r: 0, alpha: 0, active: false });
  }

  function spawnAmbient(scatter: boolean): AParticle {
    return { x: Math.random() * W, y: scatter ? Math.random() * (barrierBaseY - 20 * dpr) : -(5 + Math.random() * 15) * dpr, vx: (Math.random() - 0.5) * 0.12 * dpr, vy: (0.1 + Math.random() * 0.1) * dpr, r: (1.2 + Math.random() * 1.0) * dpr, alpha: 0.04 + Math.random() * 0.04, wPhase: Math.random() * Math.PI * 2, crossing: false, crossProgress: 0, fallenVy: 0 };
  }

  function resetAmbient(p: AParticle) {
    p.x = Math.random() * W; p.y = -(5 + Math.random() * 15) * dpr; p.vx = (Math.random() - 0.5) * 0.12 * dpr; p.vy = (0.1 + Math.random() * 0.1) * dpr; p.r = (1.2 + Math.random() * 1.0) * dpr; p.alpha = 0.04 + Math.random() * 0.04; p.wPhase = Math.random() * Math.PI * 2; p.crossing = false; p.crossProgress = 0; p.fallenVy = 0;
  }

  function getPhase(f: number): number { if (f < P0_END) return 0; if (f < P1_END) return 1; if (f < P2_END) return 2; if (f < P3_END) return 3; if (f < P4_END) return 4; if (f < P5_END) return 5; return 6; }

  function getBarrierOpacity(f: number): number { const ph = getPhase(f); if (ph === 0) return 0.7; if (ph === 1) return 0.45; if (ph === 2) return 0.22; if (ph === 3) { const t = (f - P2_END) / (P3_END - P2_END); return 0.22 * (1 - t); } return 0; }

  function getBarrierConnected(f: number): number { const ph = getPhase(f); if (ph === 0) return 1.0; if (ph === 1) return 0.82; if (ph === 2) return 0.55; if (ph === 3) { const t = (f - P2_END) / (P3_END - P2_END); return Math.max(0, 0.55 - t * 0.6); } return 0; }

  function leakRate(f: number): number { const ph = getPhase(f); if (ph === 0) return 0; if (ph === 1) return 0.035; if (ph === 2) return 0.09; if (ph === 3) return 0.2; if (ph === 4) { const t = (f - P3_END) / (P4_END - P3_END); return 0.4 + t * t * 2.0; } return 0; }

  function currentFallSpeed(f: number): number { const ph = getPhase(f); if (ph < 4) return 0.35 * dpr; const t = (f - P3_END) / (P4_END - P3_END); return (0.35 + t * 2.0) * dpr; }

  function activateFallen(x: number, y: number) {
    for (let i = 0; i < fallen.length; i++) {
      if (!fallen[i].active) { fallen[i].x = x; fallen[i].y = y; fallen[i].vx = (Math.random() - 0.5) * 0.3 * dpr; fallen[i].vy = (0.04 + Math.random() * 0.12) * dpr; fallen[i].r = (1.2 + Math.random() * 1.0) * dpr; fallen[i].alpha = 0.3 + Math.random() * 0.4; fallen[i].active = true; return; }
    }
  }

  function draw() {
    ctx!.clearRect(0, 0, W, H);
    const ph = getPhase(frame);
    const bOpacity = getBarrierOpacity(frame);
    const bConnected = getBarrierConnected(frame);

    for (let i = 0; i < barrierNodes.length; i++) {
      const n = barrierNodes[i];
      if (ph <= 2) { n.x = n.baseX + Math.sin(frame * 0.015 + n.oscPhase) * 2 * dpr; n.y = n.baseY + Math.cos(frame * 0.012 + n.oscPhase * 1.3) * 2 * dpr; n.alpha = bOpacity; }
      else if (ph === 3) { n.vy += 0.012 * dpr; n.y += n.vy; n.alpha = bOpacity; }
      else { n.alpha = 0; }
    }

    if (bOpacity > 0.004) {
      ctx!.lineWidth = 1 * dpr;
      for (let i = 0; i < barrierNodes.length - 1; i++) {
        const hash = (i * 7 + Math.floor(frame / 20)) % 100;
        if (hash / 100 > bConnected) continue;
        const a = barrierNodes[i]; const b = barrierNodes[i + 1];
        if (a.alpha < 0.01 || b.alpha < 0.01) continue;
        ctx!.strokeStyle = `rgba(${PARTICLE_R},${PARTICLE_G},${PARTICLE_B},${bOpacity * 0.35})`;
        ctx!.beginPath(); ctx!.moveTo(a.x, a.y); ctx!.lineTo(b.x, b.y); ctx!.stroke();
      }
      for (let i = 0; i < barrierNodes.length; i++) {
        const n = barrierNodes[i]; if (n.alpha < 0.005) continue;
        ctx!.beginPath(); ctx!.arc(n.x, n.y, 2 * dpr, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${PARTICLE_R},${PARTICLE_G},${PARTICLE_B},${n.alpha * 0.55})`; ctx!.fill();
      }
    }

    const rate = leakRate(frame); leakAccum += rate; const fs = currentFallSpeed(frame);

    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      if (p.crossing) {
        p.crossProgress = Math.min(1, p.crossProgress + 0.1); p.fallenVy += 0.012 * dpr; p.y += p.fallenVy + fs * 0.4; p.x += p.vx;
        if (p.y > barrierBaseY + 40 * dpr) { activateFallen(p.x, p.y); resetAmbient(p); continue; }
        const cr = Math.round(PARTICLE_R + (ACCENT_R - PARTICLE_R) * p.crossProgress);
        const cg = Math.round(PARTICLE_G + (ACCENT_G - PARTICLE_G) * p.crossProgress);
        const cb = Math.round(PARTICLE_B + (ACCENT_B - PARTICLE_B) * p.crossProgress);
        const drawAlpha = 0.06 + p.crossProgress * 0.5;
        ctx!.beginPath(); ctx!.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${cr},${cg},${cb},${drawAlpha})`; ctx!.fill(); continue;
      }
      p.y += p.vy; p.x += Math.sin(frame * 0.008 + p.wPhase) * 0.12 * dpr;
      if (p.y >= barrierBaseY - 3 * dpr) {
        if (leakAccum >= 1) { p.crossing = true; p.crossProgress = 0; p.fallenVy = fs * 0.3; leakAccum -= 1; } else { resetAmbient(p); }
        continue;
      }
      ctx!.beginPath(); ctx!.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(${PARTICLE_R},${PARTICLE_G},${PARTICLE_B},${p.alpha})`; ctx!.fill();
    }

    let fallenCount = 0;
    for (let i = 0; i < fallen.length; i++) {
      const fp = fallen[i]; if (!fp.active) continue; fallenCount++;
      fp.y += fp.vy; fp.x += fp.vx; fp.vx += (Math.random() - 0.5) * 0.006 * dpr;
      fp.vx = Math.max(-0.35 * dpr, Math.min(0.35 * dpr, fp.vx));
      if (fp.y > H - 25 * dpr) fp.vy *= 0.95;
      if (fp.y > H + 10 * dpr) { fp.y = H; fp.vy = 0; }
      if (fp.x < 0) fp.x = W; if (fp.x > W) fp.x = 0;
      ctx!.beginPath(); ctx!.arc(fp.x, fp.y, fp.r, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(${ACCENT_R},${ACCENT_G},${ACCENT_B},${fp.alpha})`; ctx!.fill();
    }

    if (fallenCount > 3) {
      const density = fallenCount / FALLEN_MAX;
      const glowIntensity = Math.min(0.28, density * 0.38);
      const tideHeight = Math.min(H * 0.65, density * H * 0.75);
      const grad = ctx!.createLinearGradient(0, H, 0, H - tideHeight);
      grad.addColorStop(0, `rgba(${ACCENT_R},${ACCENT_G},${ACCENT_B},${glowIntensity})`);
      grad.addColorStop(0.4, `rgba(${ACCENT_R},${ACCENT_G},${ACCENT_B},${glowIntensity * 0.4})`);
      grad.addColorStop(1, 'rgba(217,70,239,0)');
      ctx!.fillStyle = grad; ctx!.fillRect(0, H - tideHeight, W, tideHeight);
    }

    if (ph === 5) {
      const t = (frame - P4_END) / (P5_END - P4_END);
      const pulse = 0.04 + Math.sin(t * Math.PI * 4) * 0.02;
      ctx!.fillStyle = `rgba(${ACCENT_R},${ACCENT_G},${ACCENT_B},${pulse})`; ctx!.fillRect(0, 0, W, H);
    }

    if (ph === 6) {
      const flashT = (frame - P5_END) / (CYCLE - P5_END);
      const flashAlpha = (1 - flashT) * 0.35;
      ctx!.fillStyle = `rgba(${ACCENT_R},${ACCENT_G},${ACCENT_B},${flashAlpha})`;
      ctx!.fillRect(0, barrierBaseY - 10 * dpr, W, 20 * dpr);
    }
  }

  function tick() { frame++; if (frame >= CYCLE) initState(); draw(); if (!prefersReduced) raf = requestAnimationFrame(tick); }
  function drawStatic() { frame = 0; draw(); }

  dpr = Math.min(window.devicePixelRatio || 1, 2);
  W = canvas.offsetWidth * dpr; H = canvas.offsetHeight * dpr;
  canvas.width = W; canvas.height = H;
  barrierBaseY = H * 0.33; initState();

  if (prefersReduced) requestAnimationFrame(drawStatic);
  else raf = requestAnimationFrame(tick);

  window.addEventListener('pagehide', () => { cancelAnimationFrame(raf); ro.disconnect(); });
})();
</script>
