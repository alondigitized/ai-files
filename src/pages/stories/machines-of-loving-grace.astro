  const UNLIT_R = 26, UNLIT_G = 26, UNLIT_B = 23;
  const AMB_R = 140, AMB_G = 130, AMB_B = 110;

  let W = 0, H = 0, raf = 0, frame = 0;

  const ro = new ResizeObserver(() => {
    W = canvas.offsetWidth;
    H = canvas.offsetHeight;
    canvas.width = W * devicePixelRatio;
    canvas.height = H * devicePixelRatio;
    ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
    if (nodes.length) repositionNodes();
  });
  ro.observe(canvas);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const P1_END = 240;
  const P2_END = 540;
  const P3_END = 1020;
  const P4_END = 1200;
  const P5_END = 1320;
  const CYCLE = 1560;

  const NUM_NODES = 36;
  const NUM_LIT = 7;
  const NODE_R = 4;
  const LIT_INDICES = [3, 7, 12, 16, 21, 25, 30];

  interface MapNode {
    x: number; y: number;
    baseX: number; baseY: number;
    targetX: number; targetY: number;
    alpha: number;
    litAlpha: number;
    ringWidth: number;
    glowR: number;
    isLit: boolean;
    litOrder: number;
    driftVx: number;
    driftVy: number;
    pulseOffset: number;
  }
  const nodes: MapNode[] = [];

  interface Edge { a: number; b: number; alpha: number; targetAlpha: number; }
  const edges: Edge[] = [];

  const NUM_AMB = 12;
  interface Amb { x: number; y: number; vx: number; vy: number; r: number; a: number; }
  const ambs: Amb[] = [];

  let ringX = 0, ringY = 0, ringR = 0, ringA = 0, ringActive = false;
  let ringTimer = 0;

  let seed = 42;
  function seededRand(): number {
    seed = (seed * 16807) % 2147483647;
    return (seed - 1) / 2147483646;
  }

  function generatePositions(): { x: number; y: number }[] {
    seed = 42 + Math.floor(frame / CYCLE);
    const positions: { x: number; y: number }[] = [];
    const margin = 40;
    const cellW = (W - margin * 2) / 8;

    for (let i = 0; i < NUM_NODES; i++) {
      let x = 0, y = 0;
      let tries = 0;
      do {
        if (LIT_INDICES.includes(i)) {
          const clusterCx = W * 0.6;
          const clusterCy = H * 0.45;
          x = clusterCx + (seededRand() - 0.5) * W * 0.35;
          y = clusterCy + (seededRand() - 0.5) * H * 0.55;
        } else {
          x = margin + seededRand() * (W - margin * 2);
          y = margin + seededRand() * (H - margin * 2);
        }
        tries++;
      } while (tries < 20 && positions.some(p => {
        const dx = p.x - x, dy = p.y - y;
        return dx * dx + dy * dy < (cellW * 0.5) * (cellW * 0.5);
      }));
      positions.push({ x, y });
    }
    return positions;
  }

  function buildEdges() {
    edges.length = 0;
    const litNodes = nodes.filter(n => n.isLit).sort((a, b) => a.litOrder - b.litOrder);
    for (let i = 1; i < litNodes.length; i++) {
      let bestJ = 0;
      let bestDist = Infinity;
      for (let j = 0; j < i; j++) {
        const dx = litNodes[i].x - litNodes[j].x;
        const dy = litNodes[i].y - litNodes[j].y;
        const d = dx * dx + dy * dy;
        if (d < bestDist) { bestDist = d; bestJ = j; }
      }
      edges.push({ a: nodes.indexOf(litNodes[i]), b: nodes.indexOf(litNodes[bestJ]), alpha: 0, targetAlpha: 0 });
    }
  }

  function initNodes() {
    nodes.length = 0;
    const positions = generatePositions();
    let litOrder = 0;
    for (let i = 0; i < NUM_NODES; i++) {
      const isLit = LIT_INDICES.includes(i);
      nodes.push({
        x: positions[i].x,
        y: positions[i].y,
        baseX: positions[i].x,
        baseY: positions[i].y,
        targetX: positions[i].x,
        targetY: positions[i].y,
        alpha: 0,
        litAlpha: 0,
        ringWidth: 1,
        glowR: 0,
        isLit,
        litOrder: isLit ? litOrder++ : -1,
        driftVx: (seededRand() - 0.5) * 0.06,
        driftVy: (seededRand() - 0.5) * 0.06,
        pulseOffset: seededRand() * Math.PI * 2,
      });
    }
    buildEdges();
  }

  function repositionNodes() {
    if (!nodes.length) return;
    const positions = generatePositions();
    for (let i = 0; i < Math.min(NUM_NODES, positions.length); i++) {
      nodes[i].baseX = positions[i].x;
      nodes[i].baseY = positions[i].y;
      nodes[i].targetX = positions[i].x;
      nodes[i].targetY = positions[i].y;
      nodes[i].x = positions[i].x;
      nodes[i].y = positions[i].y;
    }
    buildEdges();
  }

  function initAmb() {
    ambs.length = 0;
    for (let i = 0; i < NUM_AMB; i++) {
      ambs.push({
        x: Math.random() * (W || 800),
        y: Math.random() * (H || 380),
        vx: (Math.random() - 0.5) * 0.12,
        vy: (Math.random() - 0.5) * 0.12,
        r: 1 + Math.random() * 1.5,
        a: 0.02 + Math.random() * 0.02,
      });
    }
  }

  function shiftNodePositions() {
    seed = 1000 + Math.floor(frame / CYCLE);
    const positions = generatePositions();
    for (let i = 0; i < nodes.length; i++) {
      const shiftDist = 10 + seededRand() * 15;
      const shiftAngle = seededRand() * Math.PI * 2;
      let nx = positions[i].x + Math.cos(shiftAngle) * shiftDist;
      let ny = positions[i].y + Math.sin(shiftAngle) * shiftDist;
      nx = Math.max(30, Math.min(W - 30, nx));
      ny = Math.max(30, Math.min(H - 30, ny));
      nodes[i].targetX = nx;
      nodes[i].targetY = ny;
    }
  }

  function update() {
    const cf = frame % CYCLE;

    for (const a of ambs) {
      a.x += a.vx;
      a.y += a.vy;
      if (a.x < -10) a.x = W + 10;
      if (a.x > W + 10) a.x = -10;
      if (a.y < -10) a.y = H + 10;
      if (a.y > H + 10) a.y = -10;
    }

    if (cf < P1_END) {
      const revealedCount = Math.min(NUM_NODES, Math.floor(cf / 7) + 1);
      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        if (i < revealedCount) {
          const fadeStart = i * 7;
          const fadeProgress = Math.min(1, Math.max(0, (cf - fadeStart) / 12));
          n.alpha = fadeProgress * 0.15;
        } else {
          n.alpha = 0;
        }
        n.litAlpha = 0;
        n.ringWidth = 1;
        n.glowR = 0;
        n.x = n.baseX + n.driftVx * cf;
        n.y = n.baseY + n.driftVy * cf;
      }
      for (const e of edges) { e.alpha = 0; e.targetAlpha = 0; }
      ringActive = false;

    } else if (cf < P2_END) {
      const phase2Frame = cf - P1_END;
      const phase2Len = P2_END - P1_END;
      const litInterval = Math.floor(phase2Len / (NUM_LIT + 1));

      for (const n of nodes) {
        if (n.alpha < 0.15) n.alpha = Math.min(0.15, n.alpha + 0.005);
        n.x = n.baseX + n.driftVx * cf;
        n.y = n.baseY + n.driftVy * cf;
      }

      for (const n of nodes) {
        if (!n.isLit) continue;
        const lightFrame = n.litOrder * litInterval;
        if (phase2Frame >= lightFrame) {
          const progress = Math.min(1, (phase2Frame - lightFrame) / 40);
          n.litAlpha = progress * 0.7;
          n.ringWidth = 1 + progress;
          n.glowR = progress * 18;
          n.alpha = 0.15 + progress * 0.55;
        }
      }

      for (let ei = 0; ei < edges.length; ei++) {
        const e = edges[ei];
        const nodeA = nodes[e.a];
        const nodeB = nodes[e.b];
        if (nodeA.litAlpha > 0.1 && nodeB.litAlpha > 0.1) {
          const edgeDelay = Math.max(nodeA.litOrder, nodeB.litOrder) * litInterval + 20;
          if (phase2Frame >= edgeDelay) {
            const ep = Math.min(1, (phase2Frame - edgeDelay) / 30);
            e.alpha = ep * 0.35;
          }
        }
      }

    } else if (cf < P3_END) {
      const phase3Frame = cf - P2_END;
      for (const n of nodes) {
        n.x = n.baseX + n.driftVx * cf;
        n.y = n.baseY + n.driftVy * cf;
        if (n.isLit) {
          n.litAlpha = 0.55 + 0.15 * Math.sin(phase3Frame * 0.07 + n.pulseOffset);
          n.ringWidth = 2;
          n.glowR = 16 + 4 * Math.sin(phase3Frame * 0.05 + n.pulseOffset);
          n.alpha = 0.7;
        } else {
          n.alpha = 0.15;
        }
      }
      for (const e of edges) {
        e.alpha = 0.25 + 0.1 * Math.sin(phase3Frame * 0.052);
      }
      ringTimer++;
      if (ringTimer >= 120) {
        ringTimer = 0;
        let cx = 0, cy = 0, count = 0;
        for (const n of nodes) {
          if (n.isLit) { cx += n.x; cy += n.y; count++; }
        }
        if (count > 0) {
          ringX = cx / count;
          ringY = cy / count;
          ringR = 0;
          ringA = 0.04;
          ringActive = true;
        }
      }
      if (ringActive) {
        ringR += 0.5;
        ringA = Math.max(0, 0.04 * (1 - ringR / 120));
        if (ringA <= 0) ringActive = false;
      }

    } else if (cf < P4_END) {
      const phase4Frame = cf - P3_END;
      const phase4Len = P4_END - P3_END;
      for (const n of nodes) {
        n.x = n.baseX + n.driftVx * cf;
        n.y = n.baseY + n.driftVy * cf;
      }
      for (const e of edges) {
        const edgeFade = Math.min(1, phase4Frame / 90);
        e.alpha = Math.max(0, 0.35 * (1 - edgeFade));
      }
      const fadeInterval = Math.floor((phase4Len - 30) / NUM_LIT);
      for (const n of nodes) {
        if (!n.isLit) { n.alpha = 0.15; continue; }
        const reverseOrder = NUM_LIT - 1 - n.litOrder;
        const fadeStart = 30 + reverseOrder * fadeInterval;
        if (phase4Frame >= fadeStart) {
          const fp = Math.min(1, (phase4Frame - fadeStart) / 40);
          n.litAlpha = 0.7 * (1 - fp);
          n.ringWidth = 2 - fp;
          n.glowR = 18 * (1 - fp);
          n.alpha = 0.7 - fp * 0.55;
        }
      }
      ringActive = false;

    } else if (cf < P5_END) {
      const phase5Frame = cf - P4_END;
      const phase5Len = P5_END - P4_END;
      for (const n of nodes) {
        n.litAlpha = 0;
        n.ringWidth = 1;
        n.glowR = 0;
      }
      const fadeStart = phase5Len - 30;
      if (phase5Frame < fadeStart) {
        for (const n of nodes) { n.alpha = 0.15; }
      } else {
        const fp = (phase5Frame - fadeStart) / 30;
        for (const n of nodes) { n.alpha = 0.15 * (1 - fp); }
      }
      for (const e of edges) { e.alpha = 0; }
      ringActive = false;

    } else {
      const phase6Frame = cf - P5_END;
      if (phase6Frame === 0) shiftNodePositions();
      const fadeProgress = Math.min(1, phase6Frame / 30);
      for (const n of nodes) {
        n.baseX += (n.targetX - n.baseX) * 0.04;
        n.baseY += (n.targetY - n.baseY) * 0.04;
        n.x = n.baseX;
        n.y = n.baseY;
        n.alpha = fadeProgress * 0.15;
        n.litAlpha = 0;
        n.ringWidth = 1;
        n.glowR = 0;
      }
      for (const e of edges) { e.alpha = 0; }
      ringActive = false;
    }
  }

  function draw() {
    ctx.fillStyle = BG_COLOR;
    ctx.fillRect(0, 0, W, H);

    for (const a of ambs) {
      ctx.globalAlpha = a.a;
      ctx.fillStyle = `rgb(${AMB_R},${AMB_G},${AMB_B})`;
      ctx.beginPath();
      ctx.arc(a.x, a.y, a.r, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;

    if (ringActive && ringA > 0.002) {
      ctx.strokeStyle = `rgba(${GOLD_R},${GOLD_G},${GOLD_B},${ringA.toFixed(3)})`;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.arc(ringX, ringY, ringR, 0, Math.PI * 2);
      ctx.stroke();
    }

    for (const e of edges) {
      if (e.alpha < 0.005) continue;
      const a = nodes[e.a];
      const b = nodes[e.b];
      ctx.strokeStyle = `rgba(${GOLD_R},${GOLD_G},${GOLD_B},${e.alpha.toFixed(3)})`;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.stroke();
    }

    for (const n of nodes) {
      if (n.alpha < 0.01) continue;

      if (n.glowR > 1 && n.litAlpha > 0.05) {
        const grad = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.glowR);
        grad.addColorStop(0, `rgba(${GOLD_R},${GOLD_G},${GOLD_B},${(n.litAlpha * 0.12).toFixed(3)})`);
        grad.addColorStop(1, `rgba(${GOLD_R},${GOLD_G},${GOLD_B},0)`);
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.glowR, 0, Math.PI * 2);
        ctx.fill();
      }

      if (n.litAlpha > 0.01) {
        ctx.globalAlpha = n.litAlpha;
        ctx.fillStyle = GOLD;
        ctx.beginPath();
        ctx.arc(n.x, n.y, NODE_R, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = 1;
      }

      const ringAlpha = n.isLit && n.litAlpha > 0.1
        ? Math.min(0.7, n.alpha)
        : n.alpha;
      ctx.strokeStyle = n.isLit && n.litAlpha > 0.1
        ? `rgba(${GOLD_R},${GOLD_G},${GOLD_B},${ringAlpha.toFixed(3)})`
        : `rgba(${UNLIT_R},${UNLIT_G},${UNLIT_B},${ringAlpha.toFixed(3)})`;
      ctx.lineWidth = n.ringWidth;
      ctx.beginPath();
      ctx.arc(n.x, n.y, NODE_R, 0, Math.PI * 2);
      ctx.stroke();
    }
  }

  function tick() {
    frame++;
    update();
    draw();
    raf = requestAnimationFrame(tick);
  }

  function init() {
    initNodes();
    initAmb();
    ringTimer = 0;
    ringActive = false;
  }

  requestAnimationFrame(() => {
    init();
    if (prefersReduced) {
      for (const n of nodes) {
        n.alpha = 0.15;
        n.x = n.baseX;
        n.y = n.baseY;
        if (n.isLit) {
          n.litAlpha = 0.7;
          n.ringWidth = 2;
          n.glowR = 18;
          n.alpha = 0.7;
        }
      }
      for (const e of edges) { e.alpha = 0.35; }
      draw();
    } else {
      const io = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) { if (!raf) raf = requestAnimationFrame(tick); }
        else { cancelAnimationFrame(raf); raf = 0; }
      }, { threshold: 0.01 });
      io.observe(canvas);
      window.addEventListener('pagehide', () => { cancelAnimationFrame(raf); io.disconnect(); ro.disconnect(); });
    }
  });
})();
</script>
