---
import StoryLayout from '../../layouts/StoryLayout.astro';
import stories from '../../data/stories.json';

const story = stories.find(s => s.slug === 'alphafold')!;
---

<style is:global>
  .phantom-wrap { width: 100%; margin: 0; line-height: 0; }
  .alphafold-canvas { display: block; width: 100%; height: 380px; background: var(--bg); }

  .af-timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 2rem;
    position: relative;
    padding-left: 2rem;
  }
  .af-timeline::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: color-mix(in srgb, var(--story) 30%, transparent);
  }
  .af-tl-item {
    display: flex;
    gap: 1.25rem;
    padding: 0.75rem 0;
    position: relative;
  }
  .af-tl-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--story);
    flex-shrink: 0;
    margin-top: 3px;
    margin-left: -2rem;
    position: relative;
    z-index: 1;
    opacity: 0.6;
  }
  .af-tl-item.highlight .af-tl-dot {
    opacity: 1;
    box-shadow: 0 0 8px color-mix(in srgb, var(--story) 50%, transparent);
  }
  .af-tl-date {
    font-size: 0.78rem;
    color: var(--muted);
    min-width: 80px;
    flex-shrink: 0;
    font-weight: 600;
    letter-spacing: 0.03em;
  }
  .af-tl-text {
    font-size: 0.88rem;
    color: var(--text);
    line-height: 1.5;
  }
  .af-tl-item.highlight .af-tl-text {
    color: var(--story);
    font-weight: 600;
  }

  .score-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .score-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    text-align: center;
  }
  .score-box.winner {
    border-color: color-mix(in srgb, var(--story) 50%, transparent);
  }
  .score-box .score-val {
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 0.3rem;
  }
  .score-box.winner .score-val { color: var(--story); }
  .score-box .score-sub {
    font-size: 0.72rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .score-box .score-label {
    font-size: 0.82rem;
    color: var(--muted);
    margin-top: 0.5rem;
  }

  .db-compare {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: center;
    margin-top: 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 2rem;
  }
  .db-col {
    text-align: center;
  }
  .db-num {
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 0.3rem;
  }
  .db-col:first-child .db-num { color: var(--muted); }
  .db-col:last-child .db-num { color: var(--story); }
  .db-label {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.4;
  }
  .db-arrow {
    font-size: 1.5rem;
    color: var(--story);
    opacity: 0.5;
  }

  @media (max-width: 600px) {
    .score-compare { grid-template-columns: 1fr; }
    .db-compare { grid-template-columns: 1fr; gap: 0.75rem; }
    .db-arrow { transform: rotate(90deg); text-align: center; }
  }

  /* ── Light-theme overrides ── */
  :root[data-theme="light"] .score-box { background: #ebe5d9; border-color: #d5cfc3; }
  :root[data-theme="light"] .score-box.winner { border-color: color-mix(in srgb, var(--story) 40%, transparent); }
  :root[data-theme="light"] .db-compare { background: #ebe5d9; border-color: #d5cfc3; }
</style>

<StoryLayout story={story}>
  <div class="container">

    <section class="section" id="problem">
      <h2><span class="num">01 — The Problem</span>Fifty Years of Failure</h2>
      <p>In the half-century between 1972 and 2022, experimental scientists — using X-ray crystallography, cryo-electron microscopy, and nuclear magnetic resonance — determined the three-dimensional structures of approximately 194,000 proteins. Each structure could take years of work and cost hundreds of thousands of dollars. In July 2022, a single upload to a database added 200 million more.</p>
      <p>Proteins are the machinery of life. They catalyze chemical reactions, transport molecules, fight infections, and build tissue. A protein's function is determined by its three-dimensional shape — a shape determined, in turn, by the sequence of amino acids that compose it. In 1972, Christian Anfinsen won the Nobel Prize in Chemistry for demonstrating this principle: that a protein's amino acid sequence fully determines its structure. The question that followed consumed structural biology for the next fifty years: if the sequence determines the shape, can we predict the shape from the sequence alone?</p>
      <p>The scale of the problem was staggering. In 1969, the molecular biologist Cyrus Levinthal calculated that a typical protein could assume approximately 10<sup>300</sup> possible configurations. If a protein sampled one configuration per picosecond, it would take longer than the age of the universe to try them all. Yet real proteins fold into their correct shape in milliseconds. Nature had solved the problem. Science had not.</p>
      <p>In 1994, a biennial competition called CASP — the Critical Assessment of protein Structure Prediction — was established to measure progress. Research groups would submit predicted structures for proteins whose actual structures had been determined experimentally but not yet published. For decades, progress was incremental. A few points per competition cycle. The protein folding problem was acknowledged, studied, and unsolved.</p>

      <div class="stat-cards">
        <div class="stat-card">
          <div class="stat-num">10<sup>300</sup></div>
          <div class="stat-label">possible configurations for a typical protein</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">50</div>
          <div class="stat-label">years the folding problem resisted solution</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">194K</div>
          <div class="stat-label">structures determined experimentally over five decades</div>
        </div>
      </div>
    </section>

    <div class="phantom-wrap">
      <canvas class="alphafold-canvas" aria-hidden="true"></canvas>
    </div>
    <p class="canvas-note"><strong>The Fold</strong> — An amino acid chain drifts loosely, searching through configuration space. Then it contracts — rapidly, inevitably — into a compact structure. Cross-bonds appear. The protein holds its shape. Then it unfolds and begins again.</p>

    <section class="section" id="bet">
      <h2><span class="num">02 — The Bet</span>From Games to Genes</h2>
      <p>Demis Hassabis was a chess prodigy who reached master standard at thirteen. He designed video games at Bullfrog Productions alongside Peter Molyneux as a teenager, founded his own game studio, then pivoted to neuroscience — earning a PhD at University College London studying how the brain handles memory and imagination. His doctoral work on the link between episodic memory and imagining the future was named one of <em>Science</em> magazine's top ten breakthroughs of 2007.</p>
      <p>In 2010, Hassabis co-founded DeepMind in London with Shane Legg and Mustafa Suleyman. The company's thesis was that techniques from neuroscience could unlock general-purpose AI. Google acquired DeepMind in 2014. In March 2016, DeepMind's AlphaGo defeated Lee Sedol, the world's best Go player, 4&ndash;1 — demonstrating that deep reinforcement learning could master a domain previously thought to require human intuition.</p>
      <p>After AlphaGo, Hassabis turned the same deep-learning approach toward science. The first target was protein folding.</p>
      <p>John Jumper arrived at DeepMind in 2017. He had studied physics and mathematics at Vanderbilt University, then earned a PhD at the University of Chicago applying machine learning to protein dynamics. His background bridged exactly the gap the project required: deep knowledge of both proteins and the neural network architectures that might predict them.</p>
      <p>In December 2018, AlphaFold entered CASP13 — DeepMind's first attempt at the competition. It placed first in the Free Modeling category, scoring 68.3 in summed z-scores against 48.2 for the next closest group. The result was notable but not decisive. The protein folding problem was not solved. The signal, though, was clear: a machine learning lab with no prior structural biology publication had outperformed every academic group in the field on its first try.</p>
    </section>

    <section class="section" id="solve">
      <h2><span class="num">03 — The Solve</span>Ninety-Two Point Four</h2>
      <p>Two years later, AlphaFold 2 entered CASP14. The results, announced in November 2020, were not close.</p>
      <p>AlphaFold 2 achieved a median GDT score of 92.4 across 97 target proteins. A score above 90 is generally considered competitive with experimental methods. For approximately two-thirds of the targets, AlphaFold scored above 90. The median error in atomic positions was less than one Angstrom — roughly the width of a single atom.</p>

      <div class="score-compare">
        <div class="score-box winner">
          <div class="score-val">244.0</div>
          <div class="score-sub">AlphaFold 2</div>
          <div class="score-label">CASP14 assessor ranking</div>
        </div>
        <div class="score-box">
          <div class="score-val">90.8</div>
          <div class="score-sub">Next Best Group</div>
          <div class="score-label">CASP14 assessor ranking</div>
        </div>
      </div>

      <p>The gap was not incremental. It was a discontinuity.</p>
      <p>Andrei Lupas, Director at the Max Planck Institute for Developmental Biology and a CASP assessor, put it directly: "It's a game changer. This will change medicine. It will change research. It will change bioengineering. It will change everything."</p>

      <div class="pull-quote">
        "A stunning advance on the protein folding problem."
        <cite>— Venki Ramakrishnan, Nobel laureate and structural biologist</cite>
      </div>

      <p>John Moult, who had founded CASP in 1994 to measure exactly this kind of progress, said the problem was "in large part, solved."</p>
      <p>For the other teams at CASP14 — groups that had spent years or decades developing their own prediction methods — the results were a reckoning. They had come to a competition. What arrived was an extinction-level event in their subfield.</p>
    </section>

    <section class="section" id="release">
      <h2><span class="num">04 — The Release</span>Two Hundred Million Structures</h2>
      <p>The breakthrough would have been significant regardless. What made it transformative was what DeepMind did next.</p>
      <p>On July 15, 2021, AlphaFold 2's full methodology was published in <em>Nature</em>, in a paper by Jumper, Hassabis, and colleagues that would accumulate nearly 43,000 citations by November 2025. On the same day, DeepMind open-sourced AlphaFold's code. One week later, in partnership with EMBL-EBI, they launched the AlphaFold Protein Structure Database — initially containing predicted structures for approximately 365,000 proteins.</p>
      <p>In July 2022, one year later, DeepMind uploaded predicted structures for approximately 200 million proteins from one million species. Effectively, every protein known to science.</p>

      <div class="db-compare">
        <div class="db-col">
          <div class="db-num">194K</div>
          <div class="db-label">Protein Data Bank<br>50 years of experimental work</div>
        </div>
        <div class="db-arrow">&rarr;</div>
        <div class="db-col">
          <div class="db-num">200M</div>
          <div class="db-label">AlphaFold Database<br>One upload, July 2022</div>
        </div>
      </div>

      <p><em>Science</em> magazine named AlphaFold its 2021 Breakthrough of the Year. By late 2025, according to DeepMind, over three million researchers across 190 countries had used the database, with more than one million users in low- and middle-income countries. The open-source decision had turned a research result into infrastructure.</p>
    </section>

    <section class="section" id="prize">
      <h2><span class="num">05 — The Prize</span>The Nobel</h2>
      <p>On October 9, 2024, the Royal Swedish Academy of Sciences awarded the Nobel Prize in Chemistry to three people. Half the prize went to Demis Hassabis and John Jumper "for protein structure prediction." The other half went to David Baker, a biochemist at the University of Washington, "for computational protein design" — work that uses related techniques to design entirely new proteins that do not exist in nature.</p>
      <p>The pairing was deliberate. Hassabis and Jumper had taught a machine to read the language of proteins. Baker had taught a machine to write in it.</p>

      <div class="af-timeline">
        <div class="af-tl-item">
          <div class="af-tl-dot"></div>
          <div class="af-tl-date">1972</div>
          <div class="af-tl-text">Anfinsen wins Nobel Prize, establishing sequence determines structure</div>
        </div>
        <div class="af-tl-item">
          <div class="af-tl-dot"></div>
          <div class="af-tl-date">1994</div>
          <div class="af-tl-text">CASP competition founded to measure prediction progress</div>
        </div>
        <div class="af-tl-item">
          <div class="af-tl-dot"></div>
          <div class="af-tl-date">2018</div>
          <div class="af-tl-text">AlphaFold enters CASP13, wins Free Modeling on first attempt</div>
        </div>
        <div class="af-tl-item highlight">
          <div class="af-tl-dot"></div>
          <div class="af-tl-date">Nov 2020</div>
          <div class="af-tl-text">AlphaFold 2 wins CASP14 with 92.4 GDT — problem solved</div>
        </div>
        <div class="af-tl-item">
          <div class="af-tl-dot"></div>
          <div class="af-tl-date">Jul 2021</div>
          <div class="af-tl-text">Nature paper published, code and database open-sourced</div>
        </div>
        <div class="af-tl-item highlight">
          <div class="af-tl-dot"></div>
          <div class="af-tl-date">Jul 2022</div>
          <div class="af-tl-text">200 million protein structures uploaded — every known protein</div>
        </div>
        <div class="af-tl-item highlight">
          <div class="af-tl-dot"></div>
          <div class="af-tl-date">Oct 2024</div>
          <div class="af-tl-text">Hassabis, Jumper, and Baker awarded Nobel Prize in Chemistry</div>
        </div>
      </div>

      <p>It was the first Nobel Prize in a natural science awarded primarily for work driven by artificial intelligence. The award acknowledged not just a technical achievement but a shift in the relationship between computation and scientific discovery.</p>
    </section>

    <section class="section" id="signal">
      <h2><span class="num">06 — Signal</span>The Other Side of the Fold</h2>
      <p>The applications have been concrete. Researchers at the University of Oxford used AlphaFold to identify a critical protein in malaria vaccine development, accelerating the path from basic research to clinical trials. Scientists have used it to design enzymes that break down plastic waste more efficiently. Drug discovery pipelines across the pharmaceutical industry have integrated AlphaFold predictions into their early-stage target identification.</p>
      <p>But the same capabilities carry a second set of implications.</p>
      <p>A 2024 paper in <em>EMBO Reports</em> — titled "Security challenges by AI-assisted protein design" — identified the dual-use risks directly. The authors noted that AI-powered protein structure prediction and design reduce the time, resources, and expertise required for biological engineering. That acceleration applies to beneficial applications and harmful ones without distinction. The paper concluded that these tools could "shorten the risk chain for biological weapon development" by lowering the barrier for non-experts.</p>
      <p>This is not hypothetical. The same tools that allow a researcher to design a better enzyme or a novel therapeutic allow anyone with access to design a protein that folds into a shape optimized for harm. The database is open. The code is open. The barrier that once existed — years of training, millions of dollars of equipment, institutional access — has been compressed into a laptop and a download link.</p>
      <p>The protein folding problem is solved. The protein design problem is just beginning. That the same technology serves both applications is not a flaw. It is the nature of foundational capability. The fold goes both ways.</p>
    </section>

  </div>
</StoryLayout>

<script>
(function () {
  const canvas = document.querySelector('.alphafold-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  // --- Palette ---
  const INDIGO = '#6366f1';
  const IND_R = 99, IND_G = 102, IND_B = 241;
  const BG_COLOR = getComputedStyle(document.documentElement).getPropertyValue('--bg').trim() || '#f5f0e8';
  const isLight = document.documentElement.dataset.theme === 'light';

  function hexToRgb(hex: string): [number, number, number] {
    const h = hex.replace('#', '');
    return [parseInt(h.slice(0, 2), 16), parseInt(h.slice(2, 4), 16), parseInt(h.slice(4, 6), 16)];
  }
  const [bgR, bgG, bgB] = hexToRgb(BG_COLOR.startsWith('#') ? BG_COLOR : (isLight ? '#f5f0e8' : '#0d0d0d'));

  // --- State ---
  let W = 0, H = 0, raf = 0, frame = 0;

  // --- Resize ---
  const ro = new ResizeObserver(() => {
    W = canvas.offsetWidth;
    H = canvas.offsetHeight;
    canvas.width = W * devicePixelRatio;
    canvas.height = H * devicePixelRatio;
    ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
  });
  ro.observe(canvas);

  // --- Reduced motion ---
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // --- Chain particles ---
  const NUM_CHAIN = 24;
  interface ChainNode {
    x: number; y: number;
    tx: number; ty: number; // target (folded position)
    sx: number; sy: number; // search-phase drift origin
    vx: number; vy: number;
    r: number;
    alpha: number;
    angle: number; // for search jitter
    speed: number;
  }
  const chain: ChainNode[] = [];

  // --- Ambient particles ---
  const NUM_AMB = 14;
  interface Amb { x: number; y: number; vx: number; vy: number; r: number; a: number; }
  const ambs: Amb[] = [];

  // --- Folded positions: compact cluster ---
  function foldedPositions(cx: number, cy: number): { x: number; y: number }[] {
    const pts: { x: number; y: number }[] = [];
    const layers = [
      { count: 1, radius: 0 },
      { count: 6, radius: 18 },
      { count: 10, radius: 36 },
      { count: 7, radius: 52 },
    ];
    let idx = 0;
    for (const layer of layers) {
      for (let i = 0; i < layer.count && idx < NUM_CHAIN; i++) {
        const angle = (i / layer.count) * Math.PI * 2 + layer.radius * 0.1;
        pts.push({
          x: cx + Math.cos(angle) * layer.radius,
          y: cy + Math.sin(angle) * layer.radius,
        });
        idx++;
      }
    }
    return pts;
  }

  // --- Unfolded positions: spread chain ---
  function unfoldedPositions(w: number, h: number): { x: number; y: number }[] {
    const pts: { x: number; y: number }[] = [];
    const margin = 60;
    const usableW = w - margin * 2;
    const cy = h / 2;
    for (let i = 0; i < NUM_CHAIN; i++) {
      const t = i / (NUM_CHAIN - 1);
      const x = margin + t * usableW;
      const y = cy + Math.sin(t * Math.PI * 3) * 40 + (Math.random() - 0.5) * 20;
      pts.push({ x, y });
    }
    return pts;
  }

  function initChain() {
    chain.length = 0;
    const uPos = unfoldedPositions(W || 800, H || 380);
    const fPos = foldedPositions((W || 800) / 2, (H || 380) / 2);
    for (let i = 0; i < NUM_CHAIN; i++) {
      chain.push({
        x: uPos[i].x, y: uPos[i].y,
        tx: fPos[i].x, ty: fPos[i].y,
        sx: uPos[i].x, sy: uPos[i].y,
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        r: 3 + Math.random() * 1.5,
        alpha: 0.8,
        angle: Math.random() * Math.PI * 2,
        speed: 0.008 + Math.random() * 0.006,
      });
    }
  }

  function initAmb() {
    ambs.length = 0;
    for (let i = 0; i < NUM_AMB; i++) {
      ambs.push({
        x: Math.random() * (W || 800),
        y: Math.random() * (H || 380),
        vx: (Math.random() - 0.5) * 0.25,
        vy: (Math.random() - 0.5) * 0.25,
        r: 1 + Math.random() * 1.5,
        a: isLight ? 0.06 : 0.04,
      });
    }
  }

  // --- Phase timing ---
  const SEARCH = 200;  // chain drifts loosely
  const FOLD = 80;     // chain contracts to cluster
  const HOLD = 140;    // compact cluster holds, gently breathing
  const UNFOLD = 80;   // cluster expands back
  const PAUSE = 40;    // brief rest
  const CYCLE = SEARCH + FOLD + HOLD + UNFOLD + PAUSE; // 540

  let glowAlpha = 0;

  function update() {
    const cf = frame % CYCLE;

    // Ambient drift
    for (const a of ambs) {
      a.x += a.vx; a.y += a.vy;
      if (a.x < -10) a.x = W + 10;
      if (a.x > W + 10) a.x = -10;
      if (a.y < -10) a.y = H + 10;
      if (a.y > H + 10) a.y = -10;
    }

    // Recalculate targets on resize
    const fPos = foldedPositions(W / 2, H / 2);
    const uPos = unfoldedPositions(W, H);

    if (cf < SEARCH) {
      // Search phase: chain drifts with gentle jitter
      glowAlpha = 0;
      for (let i = 0; i < NUM_CHAIN; i++) {
        const p = chain[i];
        p.angle += p.speed;
        p.sx = uPos[i].x;
        p.sy = uPos[i].y;
        const jx = Math.sin(p.angle * 1.7 + i * 0.5) * 12;
        const jy = Math.cos(p.angle * 1.3 + i * 0.3) * 10;
        p.x = p.sx + jx + Math.sin(frame * 0.005 + i) * 8;
        p.y = p.sy + jy + Math.cos(frame * 0.004 + i * 0.7) * 6;
        p.tx = fPos[i].x;
        p.ty = fPos[i].y;
        p.alpha = 0.65 + Math.sin(frame * 0.02 + i * 0.5) * 0.15;
      }
    } else if (cf < SEARCH + FOLD) {
      // Fold phase: contract to cluster
      const t = (cf - SEARCH) / FOLD;
      const ease = t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
      glowAlpha = t > 0.8 ? (t - 0.8) / 0.2 * 0.4 : 0;
      for (let i = 0; i < NUM_CHAIN; i++) {
        const p = chain[i];
        p.x = p.sx + (p.tx - p.sx) * ease;
        p.y = p.sy + (p.ty - p.sy) * ease;
        p.alpha = 0.65 + ease * 0.35;
      }
    } else if (cf < SEARCH + FOLD + HOLD) {
      // Hold phase: compact cluster, gentle breathing
      const ht = (cf - SEARCH - FOLD) / HOLD;
      const breath = Math.sin(ht * Math.PI * 4) * 2;
      glowAlpha = Math.max(0, 0.4 - ht * 0.3);
      for (let i = 0; i < NUM_CHAIN; i++) {
        const p = chain[i];
        const dx = p.tx - W / 2;
        const dy = p.ty - H / 2;
        const d = Math.sqrt(dx * dx + dy * dy) || 1;
        p.x = p.tx + (dx / d) * breath;
        p.y = p.ty + (dy / d) * breath;
        p.alpha = 1.0;
      }
    } else if (cf < SEARCH + FOLD + HOLD + UNFOLD) {
      // Unfold phase: expand back to chain
      const t = (cf - SEARCH - FOLD - HOLD) / UNFOLD;
      const ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
      glowAlpha = 0;
      for (let i = 0; i < NUM_CHAIN; i++) {
        const p = chain[i];
        p.sx = uPos[i].x + Math.sin(frame * 0.005 + i) * 8;
        p.sy = uPos[i].y + Math.cos(frame * 0.004 + i * 0.7) * 6;
        p.x = p.tx + (p.sx - p.tx) * ease;
        p.y = p.ty + (p.sy - p.ty) * ease;
        p.alpha = 1.0 - ease * 0.35;
      }
    } else {
      // Pause
      glowAlpha = 0;
      for (let i = 0; i < NUM_CHAIN; i++) {
        const p = chain[i];
        p.x = uPos[i].x + Math.sin(frame * 0.005 + i) * 8;
        p.y = uPos[i].y + Math.cos(frame * 0.004 + i * 0.7) * 6;
        p.alpha = 0.65;
      }
    }
  }

  function draw() {
    ctx.fillStyle = BG_COLOR;
    ctx.fillRect(0, 0, W, H);

    // Ambient particles
    const ambColor = isLight ? '30,30,30' : '232,232,232';
    for (const a of ambs) {
      ctx.globalAlpha = a.a;
      ctx.fillStyle = `rgb(${ambColor})`;
      ctx.beginPath();
      ctx.arc(a.x, a.y, a.r, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;

    // Fold glow
    if (glowAlpha > 0.005) {
      const grad = ctx.createRadialGradient(W / 2, H / 2, 0, W / 2, H / 2, 90);
      grad.addColorStop(0, `rgba(${IND_R},${IND_G},${IND_B},${(glowAlpha * 0.5).toFixed(3)})`);
      grad.addColorStop(0.5, `rgba(${IND_R},${IND_G},${IND_B},${(glowAlpha * 0.15).toFixed(3)})`);
      grad.addColorStop(1, `rgba(${IND_R},${IND_G},${IND_B},0)`);
      ctx.fillStyle = grad;
      ctx.beginPath();
      ctx.arc(W / 2, H / 2, 90, 0, Math.PI * 2);
      ctx.fill();
    }

    // Chain bonds (lines between sequential particles)
    ctx.lineWidth = 1;
    ctx.strokeStyle = `rgba(${IND_R},${IND_G},${IND_B},0.12)`;
    ctx.beginPath();
    for (let i = 0; i < NUM_CHAIN - 1; i++) {
      const a = chain[i], b = chain[i + 1];
      const dx = b.x - a.x, dy = b.y - a.y;
      if (dx * dx + dy * dy < 15000) {
        ctx.moveTo(a.x, a.y);
        ctx.lineTo(b.x, b.y);
      }
    }
    ctx.stroke();

    // Cross-bonds in folded state (proximity-based)
    const cf = frame % CYCLE;
    if (cf >= SEARCH && cf < SEARCH + FOLD + HOLD) {
      ctx.strokeStyle = `rgba(${IND_R},${IND_G},${IND_B},0.06)`;
      ctx.lineWidth = 0.5;
      for (let i = 0; i < NUM_CHAIN; i++) {
        for (let j = i + 2; j < NUM_CHAIN; j++) {
          const a = chain[i], b = chain[j];
          const dx = b.x - a.x, dy = b.y - a.y;
          const d2 = dx * dx + dy * dy;
          if (d2 < 2500) {
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }
    }

    // Chain particles
    for (const p of chain) {
      if (p.alpha < 0.02) continue;
      // Glow
      ctx.globalAlpha = p.alpha * 0.15;
      ctx.fillStyle = `rgb(${IND_R},${IND_G},${IND_B})`;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r * 3, 0, Math.PI * 2);
      ctx.fill();
      // Core
      ctx.globalAlpha = p.alpha;
      ctx.fillStyle = INDIGO;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;
  }

  function tick() {
    frame++;
    update();
    draw();
    raf = requestAnimationFrame(tick);
  }

  function init() {
    initChain();
    initAmb();
  }

  const io = new IntersectionObserver(([e]) => {
    if (e.isIntersecting) { if (!raf) raf = requestAnimationFrame(tick); }
    else { cancelAnimationFrame(raf); raf = 0; }
  }, { threshold: 0.01 });

  requestAnimationFrame(() => {
    init();
    if (prefersReduced) {
      // Static: show folded state
      const fPos = foldedPositions(W / 2, H / 2);
      for (let i = 0; i < NUM_CHAIN; i++) {
        chain[i].x = fPos[i].x;
        chain[i].y = fPos[i].y;
        chain[i].alpha = 1;
      }
      glowAlpha = 0.15;
      draw();
    } else {
      io.observe(canvas);
    }
  });

  window.addEventListener('pagehide', () => {
    cancelAnimationFrame(raf);
    ro.disconnect();
    io.disconnect();
  });
})();
</script>
