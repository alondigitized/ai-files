---
import StoryLayout from '../../layouts/StoryLayout.astro';
import stories from '../../data/stories.json';

const story = stories.find(s => s.slug === 'perplexity-private-chats')!;
---

<style is:global>
  .phantom-wrap { width: 100%; margin: 0; line-height: 0; }
  .perplexity-private-chats-canvas { display: block; width: 100%; height: 380px; background: var(--bg); }

  /* === Reenactment 1: Incognito Promise === */
  .ppx-incognito-wrap { background: #1a1a2e; border: 1px solid #2a2a3e; border-radius: 1rem; overflow: hidden; margin: 2rem auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; max-width: 480px; }
  .ppx-incognito-header { text-align: center; padding: 2rem 1.5rem 0.6rem; }
  .ppx-incognito-icon { font-size: 2.2rem; margin-bottom: 0.5rem; display: block; }
  .ppx-incognito-title { font-size: 1.1rem; font-weight: 700; color: #e8e8e8; margin-bottom: 0.5rem; }
  .ppx-incognito-desc { font-size: 0.78rem; color: #888; line-height: 1.5; max-width: 320px; margin: 0 auto; }
  .ppx-incognito-bar { display: flex; align-items: center; gap: 0.5rem; background: #0f0f1e; border-top: 1px solid #2a2a3e; padding: 0.8rem 1rem; margin-top: 1.2rem; }
  .ppx-incognito-bar-icon { width: 20px; height: 20px; border-radius: 50%; background: rgba(192,38,211,0.15); border: 1px solid rgba(192,38,211,0.35); display: flex; align-items: center; justify-content: center; font-size: 0.6rem; color: var(--story); flex-shrink: 0; }
  .ppx-incognito-bar-text { font-size: 0.78rem; color: #808090; flex: 1; }
  .ppx-incognito-bar-cursor { width: 2px; height: 16px; background: var(--story); animation: ppx-blink 1.2s step-end infinite; }
  @keyframes ppx-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) {
    .ppx-incognito-bar-cursor { animation: none; }
  }
  .ppx-incognito-context { font-size: 0.72rem; color: var(--muted); font-style: italic; padding: 0.5rem 1rem; border-top: 1px solid #2a2a3e; background: #12121f; }

  /* === Reenactment 2: Data Flow === */
  .ppx-flow-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 0.75rem; overflow: hidden; margin: 2rem 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .ppx-flow-header { background: var(--surface2); padding: 0.55rem 1rem; font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); font-weight: 700; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
  .ppx-flow-header-tag { font-size: 0.6rem; padding: 0.15rem 0.5rem; border-radius: 3px; background: rgba(255,255,255,0.04); color: var(--muted); letter-spacing: 0.1em; }
  .ppx-flow-body { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0; padding: 1.5rem 1rem; align-items: start; }
  .ppx-flow-col { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .ppx-flow-node { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; font-weight: 700; color: var(--text); text-align: center; }
  .ppx-flow-bubble { background: rgba(192,38,211,0.08); border: 1px solid rgba(192,38,211,0.25); border-radius: 0.5rem; padding: 0.6rem 0.8rem; font-size: 0.75rem; color: var(--text); font-style: italic; max-width: 200px; text-align: center; line-height: 1.4; }
  .ppx-flow-arrows { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1.2rem; padding: 0 0.5rem; min-width: 180px; }
  .ppx-flow-arrow { display: flex; flex-direction: column; align-items: center; gap: 0.15rem; }
  .ppx-flow-arrow-line { font-size: 1rem; color: var(--muted); }
  .ppx-flow-arrow-label { font-size: 0.62rem; color: var(--muted); text-align: center; line-height: 1.3; max-width: 160px; }
  .ppx-flow-arrow.ppx-flow-fork .ppx-flow-arrow-line { color: var(--accent); }
  .ppx-flow-arrow.ppx-flow-fork .ppx-flow-arrow-label { color: var(--accent); font-weight: 600; }
  .ppx-flow-arrow.ppx-flow-server .ppx-flow-arrow-line { color: #d64de6; }
  .ppx-flow-arrow.ppx-flow-server .ppx-flow-arrow-label { color: #d64de6; }
  .ppx-flow-dest { display: flex; flex-direction: column; gap: 0.6rem; }
  .ppx-flow-dest-node { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; font-weight: 700; padding: 0.4rem 0.8rem; border-radius: 0.4rem; text-align: center; }
  .ppx-flow-dest-perp { color: var(--text); background: rgba(255,255,255,0.05); border: 1px solid var(--border); }
  .ppx-flow-dest-meta { background: rgba(96,165,250,0.1); border: 1px solid rgba(96,165,250,0.25); color: #60a5fa; }
  .ppx-flow-dest-google { background: rgba(250,204,21,0.1); border: 1px solid rgba(250,204,21,0.25); color: #facc15; }
  .ppx-flow-annotation { font-size: 0.7rem; color: var(--muted); line-height: 1.4; padding: 0.6rem 1rem; font-style: italic; border-top: 1px solid var(--border); }
  .ppx-flow-context { font-size: 0.72rem; color: var(--muted); font-style: italic; padding: 0.5rem 1rem; border-top: 1px solid var(--border); background: var(--surface2); }
  @media (max-width: 700px) {
    .ppx-flow-body { grid-template-columns: 1fr; gap: 1.2rem; }
    .ppx-flow-arrows { min-width: unset; padding: 0; }
  }

  /* === Reenactment 3: Surveillance Overlay === */
  .ppx-overlay-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 0.75rem; overflow: hidden; margin: 2rem 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; position: relative; }
  .ppx-overlay-header { background: var(--surface2); padding: 0.55rem 1rem; font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); font-weight: 700; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
  .ppx-overlay-badge { font-size: 0.58rem; padding: 0.2rem 0.55rem; border-radius: 3px; background: rgba(0,255,136,0.1); border: 1px solid rgba(0,255,136,0.25); color: #00ff88; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; display: flex; align-items: center; gap: 0.35rem; }
  .ppx-overlay-badge-dot { width: 5px; height: 5px; border-radius: 50%; background: #00ff88; box-shadow: 0 0 6px rgba(0,255,136,0.5); }
  .ppx-overlay-body { padding: 1rem 1.2rem 5.5rem; position: relative; }
  .ppx-overlay-msg { display: flex; gap: 0.8rem; margin-bottom: 0.8rem; }
  .ppx-overlay-avatar { width: 28px; height: 28px; border-radius: 50%; background: rgba(192,38,211,0.15); border: 1px solid rgba(192,38,211,0.35); display: flex; align-items: center; justify-content: center; font-size: 0.65rem; flex-shrink: 0; color: var(--story); font-weight: 700; }
  .ppx-overlay-avatar.ai { background: rgba(192,38,211,0.08); border-color: rgba(192,38,211,0.2); font-size: 0.55rem; }
  .ppx-overlay-text { font-size: 0.82rem; line-height: 1.55; color: var(--text); }
  .ppx-overlay-text-muted { font-size: 0.78rem; line-height: 1.55; color: var(--muted); font-style: italic; }
  .ppx-overlay-strip { position: absolute; left: 0; right: 0; bottom: 0; background: rgba(255,77,77,0.08); border-top: 1px solid rgba(255,77,77,0.2); padding: 0.6rem 1.2rem; }
  .ppx-overlay-strip-label { font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; color: var(--accent); margin-bottom: 0.3rem; }
  .ppx-overlay-strip-trackers { font-size: 0.72rem; color: var(--accent); font-family: 'Courier New', monospace; opacity: 0.85; }
  .ppx-overlay-strip-data { font-size: 0.65rem; color: rgba(255,77,77,0.9); font-family: 'Courier New', monospace; margin-top: 0.25rem; }
  .ppx-overlay-context { font-size: 0.72rem; color: var(--muted); font-style: italic; padding: 0.5rem 1rem; border-top: 1px solid var(--border); background: var(--surface2); }
</style>

<StoryLayout story={story}>
  <div class="container">

    <section class="section" id="intro">
      <h2><span class="num">01 — Context</span>The Search Engine That Promised Privacy</h2>
      <p>A user opens Perplexity AI and types: <em>"What is the best treatment for liver cancer?"</em> The complaint alleges that before the answer finished generating, the full text of that prompt — along with the user's email address, IP address, and Facebook ID — was already in transit to Meta and Google.</p>
      <p>Perplexity AI launched on December 7, 2022. Founded four months earlier in San Francisco by Aravind Srinivas, Denis Yarats, Johnny Ho, and Andy Konwinski, the company positioned itself as an AI-powered search engine — a conversational alternative to Google where users could type out questions in plain language and receive synthesized answers with citations. By September 2025, Perplexity had raised more than $1.5 billion in funding, including a $200 million round that valued the company at $20 billion. Nvidia and Jeff Bezos were among the investors.</p>
      <p>The product's intimacy was the point. Users did not click links. They typed confessions. They asked about diagnoses, financial strategies, legal exposure. The complaint notes that Perplexity's own AI volunteered to help users "interpret a specific scan report, biopsy result, or proposed treatment plan." The interface invited depth. The marketing promised discretion. Perplexity offered an Incognito mode described as creating "anonymous threads that expire after 24 hours."</p>
      <p>Behind the interface, a different operation was taking shape. On November 12, 2024, Perplexity launched its first advertising experiment with sponsored questions. Launch partners included Whole Foods Market, Universal McCann, and PMG. According to the complaint, a pitch deck described target CPM rates exceeding $50, with health and finance flagged as premium categories. Taz Patel was hired as head of advertising in December 2024. He left nine months later.</p>

      <div class="ppx-incognito-wrap">
        <div class="ppx-incognito-header">
          <span class="ppx-incognito-icon">&#128373;</span>
          <div class="ppx-incognito-title">You're incognito</div>
          <div class="ppx-incognito-desc">Threads you create won't save to your history and expire after 24 hours.</div>
        </div>
        <div class="ppx-incognito-bar">
          <div class="ppx-incognito-bar-icon">&#9679;</div>
          <span class="ppx-incognito-bar-text">Ask anything...</span>
          <span class="ppx-incognito-bar-cursor"></span>
        </div>
        <div class="ppx-incognito-context">Reconstructed from screenshot in complaint, page 25. Perplexity's Incognito mode interface as shown to users.</div>
      </div>

      <p>That is what the user saw. What the user did not see, the complaint alleges, was happening simultaneously in the browser's network layer.</p>
    </section>

    <div class="phantom-wrap">
      <canvas class="perplexity-private-chats-canvas" aria-hidden="true"></canvas>
    </div>
    <p class="canvas-note"><strong>The Siphon</strong> — Prompt particles drift from a user origin toward a central node. Each one forks silently — the original continues as a response while a dimmer copy peels off toward receiver nodes above and below. The receivers grow brighter with every absorption. A thin green line sweeps through periodically — the Incognito promise. It changes nothing.</p>

    <section class="section" id="filing">
      <h2><span class="num">02 — What Happened</span>The 140-Page Accusation</h2>
      <p>On March 31, 2026, a plaintiff identified as John Doe — a citizen of Utah — filed a 140-page class-action complaint in the U.S. District Court for the Northern District of California, San Francisco Division. The case is captioned <em>Doe v. Perplexity AI, Inc., et al.</em>, Case No. 3:26-cv-02803. The defendants are Perplexity AI, Inc., Meta Platforms, Inc., and Google, LLC.</p>
      <p>The complaint's core allegation: Perplexity embedded seven tracking technologies — Meta Pixel, Meta Conversions API, Google Ads, Google DoubleClick, Google Analytics, Google Firebase, and Google Firebase Analytics — in its web platform and mobile app. These trackers, the complaint alleges, transmitted users' complete prompt transcripts, sign-up email addresses, Facebook IDs, IP addresses, and device information to Meta and Google. The data types included full-string URLs containing the text of users' initial prompts.</p>
      <p>The timing matters. According to the complaint, these trackers "automatically and instantaneously" loaded in users' browsers upon visiting perplexity.ai. Two communications allegedly originated from the user's browser with every prompt: one sent to Perplexity's servers as intended, and a second — "undetectable to users" — sent simultaneously to Meta. The complaint states that third parties received prompt contents "before the full response from Perplexity has been rendered on the screen."</p>

      <div class="ppx-flow-wrap">
        <div class="ppx-flow-header">
          <span>Alleged Data Flow</span>
          <span class="ppx-flow-header-tag">Per Complaint</span>
        </div>
        <div class="ppx-flow-body">
          <div class="ppx-flow-col">
            <div class="ppx-flow-node">User</div>
            <div class="ppx-flow-bubble">"What is the best treatment for liver cancer?"</div>
          </div>
          <div class="ppx-flow-arrows">
            <div class="ppx-flow-arrow">
              <div class="ppx-flow-arrow-line">&rarr;</div>
              <div class="ppx-flow-arrow-label">1. Prompt sent to Perplexity</div>
            </div>
            <div class="ppx-flow-arrow ppx-flow-fork">
              <div class="ppx-flow-arrow-line">&rarr;</div>
              <div class="ppx-flow-arrow-label">2. Prompt + email + IP + Facebook ID sent simultaneously</div>
            </div>
            <div class="ppx-flow-arrow ppx-flow-server">
              <div class="ppx-flow-arrow-line">&rarr;</div>
              <div class="ppx-flow-arrow-label">3. Server-to-server (Conversions API) — bypasses browser</div>
            </div>
          </div>
          <div class="ppx-flow-col ppx-flow-dest">
            <div class="ppx-flow-dest-node ppx-flow-dest-perp">Perplexity</div>
            <div class="ppx-flow-dest-node ppx-flow-dest-meta">Meta</div>
            <div class="ppx-flow-dest-node ppx-flow-dest-google">Google</div>
          </div>
        </div>
        <div class="ppx-flow-annotation">According to the complaint, steps 1 and 2 occurred simultaneously. Step 3 operated independently, server-to-server, bypassing the user's browser entirely.</div>
        <div class="ppx-flow-context">Source: Doe v. Perplexity AI complaint, paragraphs 133, 160, 169.</div>
      </div>

      <p>The complaint names Perplexity's Incognito mode specifically. Even with Incognito active, the complaint alleges, data sharing continued identically. The complaint calls Incognito mode a "sham" — alleging it "does nothing to protect users from having their conversations shared with Meta and Google." A screenshot on page 26 of the complaint shows a user in Incognito mode querying about pregnancy and health insurance, with the same tracker infrastructure allegedly active.</p>
      <p>The plaintiff alleges he used Perplexity to research Social Security withdrawal eligibility, Roth IRA conversions, and tax and legal advice. He believed these communications were private. The complaint states that "no reasonable person would have expected that Perplexity would share complete transcripts" with third parties.</p>

      <div class="ppx-overlay-wrap">
        <div class="ppx-overlay-header">
          <span>Perplexity AI — Incognito Thread</span>
          <div class="ppx-overlay-badge"><span class="ppx-overlay-badge-dot"></span> Incognito</div>
        </div>
        <div class="ppx-overlay-body">
          <div class="ppx-overlay-msg">
            <div class="ppx-overlay-avatar">U</div>
            <div class="ppx-overlay-text">I am pregnant and have no health insurance. What are the implications?</div>
          </div>
          <div class="ppx-overlay-msg">
            <div class="ppx-overlay-avatar ai">AI</div>
            <div class="ppx-overlay-text-muted">Generating response...</div>
          </div>
          <div class="ppx-overlay-strip">
            <div class="ppx-overlay-strip-label">Sent to:</div>
            <div class="ppx-overlay-strip-trackers">Meta Pixel &middot; Conversions API &middot; Google Analytics</div>
            <div class="ppx-overlay-strip-data">c_user: [REDACTED] | email: [REDACTED] | IP: [REDACTED]</div>
          </div>
        </div>
        <div class="ppx-overlay-context">Pregnancy/insurance prompt cited in complaint, paragraph 118 (page 26), with screenshot. Tracker strip represents allegations in the complaint — not independently verified. The Incognito badge was active.</div>
      </div>
    </section>

    <section class="section" id="mechanism">
      <h2><span class="num">03 — Mechanism</span>Two Pipelines, One Product</h2>
      <p>The complaint describes two distinct data pipelines allegedly operating inside Perplexity's product.</p>
      <p>The first was browser-side. JavaScript tracking code — Meta Pixel and Google's tag suite — allegedly loaded in the user's browser alongside Perplexity's interface. When a user typed a prompt, the complaint alleges, the browser fired HTTP requests to both Perplexity's own server and to Meta and Google simultaneously. The full-string URL contained the prompt text. Meta's <code>c_user</code> cookie, which links browser activity to a user's Facebook profile, was allegedly present and transmitting.</p>
      <p>The second pipeline, according to the complaint, operated server-to-server. Meta's Conversions API allegedly created a direct connection between Perplexity's servers and Meta's, transmitting user interactions without touching the user's browser. This is the pipeline that makes the allegation structurally different from a standard tracking-pixel case. Users with ad blockers, privacy-focused browsers, or VPNs could not have detected or prevented this data transfer, because it never passed through their device. The complaint describes this mechanism as "undetectable" and "surreptitious."</p>
      <p>The re-identification allegation follows from the data types. Once Meta and Google had a user's email address, Facebook ID, and IP address, the complaint alleges they could "pair it with the user's name and address" — connecting an ostensibly anonymous AI conversation to a real identity. The complaint alleges Perplexity "received advertising and analytics benefits" in exchange for this data. The pitch deck's CPM rates exceeding $50 in health and finance categories suggest these were the most commercially valuable prompt categories — and precisely the most sensitive.</p>
      <p>No independent security researcher has publicly confirmed or denied the presence of these trackers on Perplexity's platform. The complaint includes what appear to be network traffic screenshots, but these are the plaintiff's own evidence. This verification gap is significant. Every claim about the tracking mechanism above is drawn from the complaint's allegations, not from independent audit.</p>
    </section>

    <section class="section" id="response">
      <h2><span class="num">04 — Response</span>Three Defendants, Minimal Answers</h2>
      <p>Perplexity's Chief Communications Officer, Jesse Dwyer, stated on April 1, 2026: "We have not been served any lawsuit that matches this description so we are unable to verify its existence or claims." This was accurate at the time. Summonses were issued to all three defendants on April 17.</p>
      <p>An unnamed Meta spokesperson, according to Bloomberg, pointed to a Facebook help page stating it is against Meta's rules for advertisers to send the company sensitive information. The deflection is structural: Meta's rules govern what advertisers send to Meta, not what Meta does once it receives the data.</p>
      <p>The three defendants' collective response to a complaint alleging they operated a surveillance pipeline inside an AI search engine amounts to one named spokesperson saying they had not been served, one unnamed spokesperson pointing to a help page, and silence.</p>
      <p>The legal context is unfavorable for the defendants on at least one front. In August 2025, a federal jury found Meta liable under CIPA for collecting reproductive health data from users of the Flo period-tracking app via the same Meta Pixel named in this complaint. The jury found Meta had intentionally eavesdropped on confidential communications. In March 2026, a San Francisco court entered a $50 million judgment against Meta over Facebook data shared with third-party developers in the Cambridge Analytica scandal. Separately, the <em>Krzyzek v. OpenX Technologies</em> ruling in January 2026 — cited in the Doe complaint itself — allowed CIPA and ECPA claims against a tracking-pixel operator to proceed past a motion to dismiss.</p>
    </section>

    <section class="section" id="docket">
      <h2><span class="num">05 — Docket</span>What Has Happened Since Filing</h2>
      <p>The plaintiff filed as John Doe and moved to proceed pseudonymously. On April 3, 2026, the court denied that motion. The plaintiff's identity may become public as the case progresses.</p>
      <p>On April 14, the court granted leave to file a corrected complaint, which was filed the same day. The differences between the original March 31 filing and the corrected version are not publicly available. The analysis in this story is based on the original complaint. On April 17, summonses were issued to all three defendants. The response clock is now running.</p>
      <p>The complaint brings 14 counts under the California Invasion of Privacy Act (CIPA), the Comprehensive Computer Data Access and Fraud Act (CDAFA), the California Constitution (Article I, Section 1), the Electronic Communications Privacy Act (ECPA), the California Electronic Communications Privacy Act (CalECPA), California's Unfair Competition Law, and an unjust enrichment claim. It seeks at least $5,000 in statutory damages per violation. The aggregate amount in controversy exceeds $5 million. The proposed class spans two groups — a nationwide class and a California subclass — with more than 100 members. The class period runs from December 7, 2022, the day Perplexity launched, through February 4, 2026. Paid Pro and Max subscribers are excluded.</p>
    </section>

    <section class="section" id="signal">
      <h2><span class="num">06 — Signal</span>The Advertising Retreat</h2>
      <p>By late 2025, Perplexity had stopped accepting new advertisers. In February 2026, the company confirmed complete abandonment of its advertising model, citing concerns that advertising was incompatible with the product experience users were paying for. In the company's framing: "A user needs to believe this is the best possible answer, to keep using the product and be willing to pay for it."</p>
      <p>The class period ends February 4, 2026. No public source explains the significance of that date. It falls within weeks of the advertising abandonment announcement. The trackers may be gone. The data, the complaint alleges, was already sent.</p>
      <p>This is not Perplexity's first active lawsuit alleging unauthorized data access. In October 2025, Reddit sued the company for scraping user posts, alleging Perplexity circumvented platform protections. In November 2025, Amazon sued over Perplexity's Comet browser accessing Amazon's marketplace without authorization; a federal judge granted Amazon a temporary injunction in March 2026. The Doe complaint is the third case in under six months alleging Perplexity accessed or transmitted data it was not authorized to handle.</p>
      <p>The structural asymmetry is the one the complaint cannot fix. A user can delete their Perplexity thread. But the complaint alleges the transcript was already forwarded to Meta and Google through a server-to-server pipeline that never touched the user's browser. There is no undo button for a Conversions API call. The user typed a question they believed was private. The lawsuit will determine whether the allegation that it became an ad-tech event survives scrutiny. But the underlying question does not require a court to answer: when a user types a private thought into an AI search bar, who else is in the room?</p>
    </section>

  </div>
</StoryLayout>

<script>
(function () {
  const canvas = document.querySelector('.perplexity-private-chats-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const BG_COLOR = getComputedStyle(document.documentElement).getPropertyValue('--bg').trim() || '#0d0d0d';
  const STORY_COLOR = getComputedStyle(document.documentElement).getPropertyValue('--story').trim() || '#c026d3';

  function hexToRgb(hex: string): [number, number, number] {
    const h = hex.replace('#', '');
    return [parseInt(h.slice(0, 2), 16), parseInt(h.slice(2, 4), 16), parseInt(h.slice(4, 6), 16)];
  }

  const [sR, sG, sB] = hexToRgb(STORY_COLOR.startsWith('#') ? STORY_COLOR : '#c026d3');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function storyA(a: number) { return `rgba(${sR},${sG},${sB},${Math.max(0, Math.min(1, a))})`; }
  function dimA(a: number) { return `rgba(232,232,232,${Math.max(0, Math.min(1, a))})`; }
  function greenA(a: number) { return `rgba(0,255,136,${Math.max(0, Math.min(1, a))})`; }

  let W = 0, H = 0, rafId = 0, frame = 0;

  const USER_X_FRAC = 0.08;
  const USER_Y_FRAC = 0.5;
  const CENTER_X_FRAC = 0.40;
  const CENTER_Y_FRAC = 0.5;
  const RECV_TOP_X_FRAC = 0.82;
  const RECV_TOP_Y_FRAC = 0.2;
  const RECV_BOT_X_FRAC = 0.82;
  const RECV_BOT_Y_FRAC = 0.8;

  const PROMPT_SPEED = 0.3;
  const COPY_SPEED = 0.25;
  const SPAWN_INTERVAL = 40;
  const MAX_PARTICLES = 80;
  const PARTICLE_RADIUS = 2.5;
  const MOTE_COUNT = 18;

  const CYCLE_LENGTH = 1200;
  const GREEN_SWEEP_INTERVAL = 300;
  const RECEIVER_RESET_START = CYCLE_LENGTH - 60;
  const RECEIVER_RESET_FRAMES = 30;

  const TYPE_PROMPT = 0;
  const TYPE_COPY = 1;

  interface Particle {
    x: number; y: number; vx: number; vy: number; alpha: number;
    active: boolean; type: number; forked: boolean;
    targetReceiver: number; fadeAlpha: number; yOffset: number;
  }

  const particles: Particle[] = [];
  for (let i = 0; i < MAX_PARTICLES; i++) {
    particles.push({
      x: 0, y: 0, vx: 0, vy: 0, alpha: 0,
      active: false, type: TYPE_PROMPT, forked: false,
      targetReceiver: 0, fadeAlpha: 1, yOffset: 0,
    });
  }

  interface Mote { x: number; y: number; vx: number; vy: number; }
  const motes: Mote[] = [];
  for (let i = 0; i < MOTE_COUNT; i++) {
    motes.push({
      x: Math.random(), y: Math.random(),
      vx: (Math.random() - 0.5) * 0.05,
      vy: (Math.random() - 0.5) * 0.05,
    });
  }

  interface GreenSweep { active: boolean; x: number; alpha: number; }
  const greenSweep: GreenSweep = { active: false, x: 0, alpha: 0 };

  let recvTopGlow = 0;
  let recvBotGlow = 0;
  const RECV_BASE_RADIUS = 5;
  const RECV_MAX_EXTRA = 14;
  let recvTopAbsorptions = 0;
  let recvBotAbsorptions = 0;

  let spawnCounter = 0;
  let nextReceiverTarget = 0;

  function findInactive(): Particle | null {
    for (let i = 0; i < particles.length; i++) {
      if (!particles[i].active) return particles[i];
    }
    return null;
  }

  function spawnPrompt() {
    const p = findInactive();
    if (!p) return;
    const userX = USER_X_FRAC * W;
    const userY = USER_Y_FRAC * H;
    p.x = userX;
    p.y = userY + (Math.random() - 0.5) * 16;
    p.vx = PROMPT_SPEED;
    p.vy = (Math.random() - 0.5) * 0.04;
    p.alpha = 0.55 + Math.random() * 0.2;
    p.active = true;
    p.type = TYPE_PROMPT;
    p.forked = false;
    p.targetReceiver = 0;
    p.fadeAlpha = 1;
    p.yOffset = (Math.random() - 0.5) * 10;
  }

  function spawnCopy(sourceX: number, sourceY: number, target: number) {
    const p = findInactive();
    if (!p) return;
    const recvX = (target === 0 ? RECV_TOP_X_FRAC : RECV_BOT_X_FRAC) * W;
    const recvY = (target === 0 ? RECV_TOP_Y_FRAC : RECV_BOT_Y_FRAC) * H;
    const dx = recvX - sourceX;
    const dy = recvY - sourceY;
    const dist = Math.sqrt(dx * dx + dy * dy);
    const normX = dx / dist;
    const normY = dy / dist;
    p.x = sourceX;
    p.y = sourceY;
    p.vx = normX * COPY_SPEED;
    p.vy = normY * COPY_SPEED;
    p.alpha = 0.6;
    p.active = true;
    p.type = TYPE_COPY;
    p.forked = false;
    p.targetReceiver = target;
    p.fadeAlpha = 1;
    p.yOffset = 0;
  }

  function update() {
    const cycleFrame = frame % CYCLE_LENGTH;

    if (cycleFrame >= RECEIVER_RESET_START) {
      const resetProgress = (cycleFrame - RECEIVER_RESET_START) / RECEIVER_RESET_FRAMES;
      recvTopGlow *= 0.94;
      recvBotGlow *= 0.94;
      if (resetProgress >= 1) {
        recvTopAbsorptions = 0;
        recvBotAbsorptions = 0;
        recvTopGlow = 0;
        recvBotGlow = 0;
      }
    }

    spawnCounter++;
    if (spawnCounter >= SPAWN_INTERVAL) {
      spawnCounter = 0;
      spawnPrompt();
    }

    if (cycleFrame % GREEN_SWEEP_INTERVAL === 0 && cycleFrame > 0) {
      greenSweep.active = true;
      greenSweep.x = 0;
      greenSweep.alpha = 0.15;
    }

    if (greenSweep.active) {
      greenSweep.x += 1.5;
      greenSweep.alpha *= 0.993;
      if (greenSweep.x > W + 10 || greenSweep.alpha < 0.005) {
        greenSweep.active = false;
        greenSweep.alpha = 0;
      }
    }

    for (let i = 0; i < motes.length; i++) {
      const m = motes[i];
      m.x += m.vx / W;
      m.y += m.vy / H;
      if (m.x < 0) m.x = 1;
      if (m.x > 1) m.x = 0;
      if (m.y < 0) m.y = 1;
      if (m.y > 1) m.y = 0;
    }

    const centerX = CENTER_X_FRAC * W;
    const recvTopX = RECV_TOP_X_FRAC * W;
    const recvTopY = RECV_TOP_Y_FRAC * H;
    const recvBotX = RECV_BOT_X_FRAC * W;
    const recvBotY = RECV_BOT_Y_FRAC * H;

    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      if (!p.active) continue;

      p.x += p.vx;
      p.y += p.vy;

      if (p.type === TYPE_PROMPT) {
        if (!p.forked && p.x >= centerX) {
          p.forked = true;
          spawnCopy(p.x, p.y, nextReceiverTarget);
          nextReceiverTarget = nextReceiverTarget === 0 ? 1 : 0;
        }
        if (p.forked) {
          p.fadeAlpha -= 0.003;
          if (p.fadeAlpha <= 0) {
            p.active = false;
            p.fadeAlpha = 1;
          }
        }
        if (p.x > W + 20) {
          p.active = false;
          p.fadeAlpha = 1;
        }
      }

      if (p.type === TYPE_COPY) {
        const targetX = p.targetReceiver === 0 ? recvTopX : recvBotX;
        const targetY = p.targetReceiver === 0 ? recvTopY : recvBotY;
        const dx = targetX - p.x;
        const dy = targetY - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < 8) {
          p.active = false;
          p.fadeAlpha = 1;
          if (p.targetReceiver === 0) {
            recvTopAbsorptions++;
            recvTopGlow = Math.min(1, recvTopAbsorptions * 0.06);
          } else {
            recvBotAbsorptions++;
            recvBotGlow = Math.min(1, recvBotAbsorptions * 0.06);
          }
        }

        if (dist > 8) {
          const steer = 0.002;
          p.vx += (dx / dist) * steer;
          p.vy += (dy / dist) * steer;
          const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
          if (speed > COPY_SPEED * 1.2) {
            p.vx = (p.vx / speed) * COPY_SPEED;
            p.vy = (p.vy / speed) * COPY_SPEED;
          }
        }
      }
    }
  }

  function draw() {
    ctx!.clearRect(0, 0, W, H);
    ctx!.fillStyle = BG_COLOR;
    ctx!.fillRect(0, 0, W, H);

    const userX = USER_X_FRAC * W;
    const userY = USER_Y_FRAC * H;
    const centerX = CENTER_X_FRAC * W;
    const centerY = CENTER_Y_FRAC * H;
    const recvTopX = RECV_TOP_X_FRAC * W;
    const recvTopY = RECV_TOP_Y_FRAC * H;
    const recvBotX = RECV_BOT_X_FRAC * W;
    const recvBotY = RECV_BOT_Y_FRAC * H;

    for (let i = 0; i < motes.length; i++) {
      const m = motes[i];
      ctx!.beginPath();
      ctx!.arc(m.x * W, m.y * H, 1, 0, Math.PI * 2);
      ctx!.fillStyle = dimA(0.04);
      ctx!.fill();
    }

    ctx!.setLineDash([2, 6]);
    ctx!.lineWidth = 0.5;

    ctx!.beginPath();
    ctx!.moveTo(userX, userY);
    ctx!.lineTo(centerX, centerY);
    ctx!.strokeStyle = dimA(0.04);
    ctx!.stroke();

    ctx!.beginPath();
    ctx!.moveTo(centerX, centerY);
    ctx!.lineTo(recvTopX, recvTopY);
    ctx!.strokeStyle = storyA(0.04);
    ctx!.stroke();

    ctx!.beginPath();
    ctx!.moveTo(centerX, centerY);
    ctx!.lineTo(recvBotX, recvBotY);
    ctx!.strokeStyle = storyA(0.04);
    ctx!.stroke();

    ctx!.setLineDash([]);

    ctx!.beginPath();
    ctx!.arc(userX, userY, 6, 0, Math.PI * 2);
    ctx!.fillStyle = dimA(0.15);
    ctx!.fill();

    const userGlow = ctx!.createRadialGradient(userX, userY, 0, userX, userY, 20);
    userGlow.addColorStop(0, dimA(0.06));
    userGlow.addColorStop(1, dimA(0));
    ctx!.fillStyle = userGlow;
    ctx!.beginPath();
    ctx!.arc(userX, userY, 20, 0, Math.PI * 2);
    ctx!.fill();

    const centerPulse = 0.6 + Math.sin(frame * 0.03) * 0.1;
    ctx!.beginPath();
    ctx!.arc(centerX, centerY, 8, 0, Math.PI * 2);
    ctx!.fillStyle = storyA(centerPulse);
    ctx!.fill();

    const centerGlow = ctx!.createRadialGradient(centerX, centerY, 0, centerX, centerY, 30);
    centerGlow.addColorStop(0, storyA(0.2));
    centerGlow.addColorStop(1, storyA(0));
    ctx!.fillStyle = centerGlow;
    ctx!.beginPath();
    ctx!.arc(centerX, centerY, 30, 0, Math.PI * 2);
    ctx!.fill();

    const topRadius = RECV_BASE_RADIUS + Math.min(RECV_MAX_EXTRA, recvTopAbsorptions * 0.5);
    const topAlpha = 0.12 + recvTopGlow * 0.5;
    ctx!.beginPath();
    ctx!.arc(recvTopX, recvTopY, topRadius, 0, Math.PI * 2);
    ctx!.fillStyle = storyA(topAlpha);
    ctx!.fill();

    const topGlowRadius = topRadius + 15 + recvTopGlow * 10;
    const topGlowGrad = ctx!.createRadialGradient(recvTopX, recvTopY, 0, recvTopX, recvTopY, topGlowRadius);
    topGlowGrad.addColorStop(0, storyA(recvTopGlow * 0.15));
    topGlowGrad.addColorStop(1, storyA(0));
    ctx!.fillStyle = topGlowGrad;
    ctx!.beginPath();
    ctx!.arc(recvTopX, recvTopY, topGlowRadius, 0, Math.PI * 2);
    ctx!.fill();

    const botRadius = RECV_BASE_RADIUS + Math.min(RECV_MAX_EXTRA, recvBotAbsorptions * 0.5);
    const botAlpha = 0.12 + recvBotGlow * 0.5;
    ctx!.beginPath();
    ctx!.arc(recvBotX, recvBotY, botRadius, 0, Math.PI * 2);
    ctx!.fillStyle = storyA(botAlpha);
    ctx!.fill();

    const botGlowRadius = botRadius + 15 + recvBotGlow * 10;
    const botGlowGrad = ctx!.createRadialGradient(recvBotX, recvBotY, 0, recvBotX, recvBotY, botGlowRadius);
    botGlowGrad.addColorStop(0, storyA(recvBotGlow * 0.15));
    botGlowGrad.addColorStop(1, storyA(0));
    ctx!.fillStyle = botGlowGrad;
    ctx!.beginPath();
    ctx!.arc(recvBotX, recvBotY, botGlowRadius, 0, Math.PI * 2);
    ctx!.fill();

    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      if (!p.active) continue;

      const drawAlpha = p.alpha * p.fadeAlpha;
      if (drawAlpha < 0.005) continue;

      const wobbleY = p.type === TYPE_PROMPT ? Math.sin(p.x * 0.015 + p.yOffset) * 3 : 0;
      const py = p.y + wobbleY;

      if (p.type === TYPE_PROMPT) {
        ctx!.beginPath();
        ctx!.arc(p.x, py, PARTICLE_RADIUS, 0, Math.PI * 2);
        ctx!.fillStyle = dimA(drawAlpha);
        ctx!.fill();

        ctx!.beginPath();
        ctx!.moveTo(p.x, py);
        ctx!.lineTo(p.x - 10, py);
        ctx!.strokeStyle = dimA(drawAlpha * 0.12);
        ctx!.lineWidth = 1;
        ctx!.stroke();
      } else {
        ctx!.beginPath();
        ctx!.arc(p.x, py, PARTICLE_RADIUS * 0.9, 0, Math.PI * 2);
        ctx!.fillStyle = storyA(drawAlpha);
        ctx!.fill();

        ctx!.beginPath();
        ctx!.moveTo(p.x, py);
        ctx!.lineTo(p.x - p.vx * 20, py - p.vy * 20);
        ctx!.strokeStyle = storyA(drawAlpha * 0.1);
        ctx!.lineWidth = 0.8;
        ctx!.stroke();
      }
    }

    if (greenSweep.active && greenSweep.alpha > 0.005) {
      ctx!.beginPath();
      ctx!.moveTo(greenSweep.x, 0);
      ctx!.lineTo(greenSweep.x, H);
      ctx!.strokeStyle = greenA(greenSweep.alpha);
      ctx!.lineWidth = 1.5;
      ctx!.stroke();

      const sweepGrad = ctx!.createLinearGradient(greenSweep.x - 30, 0, greenSweep.x, 0);
      sweepGrad.addColorStop(0, greenA(0));
      sweepGrad.addColorStop(1, greenA(greenSweep.alpha * 0.3));
      ctx!.fillStyle = sweepGrad;
      ctx!.fillRect(greenSweep.x - 30, 0, 30, H);
    }
  }

  function drawStatic() {
    ctx!.clearRect(0, 0, W, H);
    ctx!.fillStyle = BG_COLOR;
    ctx!.fillRect(0, 0, W, H);

    const userX = USER_X_FRAC * W;
    const userY = USER_Y_FRAC * H;
    const centerX = CENTER_X_FRAC * W;
    const centerY = CENTER_Y_FRAC * H;
    const recvTopX = RECV_TOP_X_FRAC * W;
    const recvTopY = RECV_TOP_Y_FRAC * H;
    const recvBotX = RECV_BOT_X_FRAC * W;
    const recvBotY = RECV_BOT_Y_FRAC * H;

    for (let i = 0; i < motes.length; i++) {
      ctx!.beginPath();
      ctx!.arc(motes[i].x * W, motes[i].y * H, 1, 0, Math.PI * 2);
      ctx!.fillStyle = dimA(0.04);
      ctx!.fill();
    }

    ctx!.setLineDash([2, 6]);
    ctx!.lineWidth = 0.5;

    ctx!.beginPath();
    ctx!.moveTo(userX, userY);
    ctx!.lineTo(centerX, centerY);
    ctx!.strokeStyle = dimA(0.04);
    ctx!.stroke();

    ctx!.beginPath();
    ctx!.moveTo(centerX, centerY);
    ctx!.lineTo(recvTopX, recvTopY);
    ctx!.strokeStyle = storyA(0.04);
    ctx!.stroke();

    ctx!.beginPath();
    ctx!.moveTo(centerX, centerY);
    ctx!.lineTo(recvBotX, recvBotY);
    ctx!.strokeStyle = storyA(0.04);
    ctx!.stroke();

    ctx!.setLineDash([]);

    ctx!.beginPath();
    ctx!.arc(userX, userY, 6, 0, Math.PI * 2);
    ctx!.fillStyle = dimA(0.15);
    ctx!.fill();

    ctx!.beginPath();
    ctx!.arc(centerX, centerY, 8, 0, Math.PI * 2);
    ctx!.fillStyle = storyA(0.55);
    ctx!.fill();

    const cGlow = ctx!.createRadialGradient(centerX, centerY, 0, centerX, centerY, 30);
    cGlow.addColorStop(0, storyA(0.18));
    cGlow.addColorStop(1, storyA(0));
    ctx!.fillStyle = cGlow;
    ctx!.beginPath();
    ctx!.arc(centerX, centerY, 30, 0, Math.PI * 2);
    ctx!.fill();

    ctx!.beginPath();
    ctx!.arc(recvTopX, recvTopY, RECV_BASE_RADIUS + 4, 0, Math.PI * 2);
    ctx!.fillStyle = storyA(0.3);
    ctx!.fill();

    ctx!.beginPath();
    ctx!.arc(recvBotX, recvBotY, RECV_BASE_RADIUS + 3, 0, Math.PI * 2);
    ctx!.fillStyle = storyA(0.25);
    ctx!.fill();

    for (let i = 0; i < 4; i++) {
      const t = 0.2 + i * 0.18;
      const px = userX + (centerX - userX) * t;
      const py = userY + Math.sin(i * 2.1) * 8;
      ctx!.beginPath();
      ctx!.arc(px, py, PARTICLE_RADIUS, 0, Math.PI * 2);
      ctx!.fillStyle = dimA(0.45 - i * 0.05);
      ctx!.fill();
    }

    const copyTopX = centerX + (recvTopX - centerX) * 0.45;
    const copyTopY = centerY + (recvTopY - centerY) * 0.45;
    ctx!.beginPath();
    ctx!.arc(copyTopX, copyTopY, PARTICLE_RADIUS * 0.9, 0, Math.PI * 2);
    ctx!.fillStyle = storyA(0.5);
    ctx!.fill();

    const copyBotX = centerX + (recvBotX - centerX) * 0.6;
    const copyBotY = centerY + (recvBotY - centerY) * 0.6;
    ctx!.beginPath();
    ctx!.arc(copyBotX, copyBotY, PARTICLE_RADIUS * 0.9, 0, Math.PI * 2);
    ctx!.fillStyle = storyA(0.45);
    ctx!.fill();

    const fadedX = centerX + (W - centerX) * 0.3;
    ctx!.beginPath();
    ctx!.arc(fadedX, centerY + 4, PARTICLE_RADIUS, 0, Math.PI * 2);
    ctx!.fillStyle = dimA(0.15);
    ctx!.fill();

    const sweepX = W * 0.55;
    ctx!.beginPath();
    ctx!.moveTo(sweepX, 0);
    ctx!.lineTo(sweepX, H);
    ctx!.strokeStyle = greenA(0.08);
    ctx!.lineWidth = 1;
    ctx!.stroke();
  }

  function tick() {
    frame++;
    update();
    draw();
    rafId = requestAnimationFrame(tick);
  }

  const ro = new ResizeObserver(() => {
    const dpr = window.devicePixelRatio || 1;
    W = canvas!.offsetWidth;
    H = canvas!.offsetHeight;
    canvas!.width = W * dpr;
    canvas!.height = H * dpr;
    ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    if (prefersReduced) { drawStatic(); }
  });
  ro.observe(canvas);

  const dpr = window.devicePixelRatio || 1;
  W = canvas.offsetWidth;
  H = canvas.offsetHeight;
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

  if (prefersReduced) {
    drawStatic();
    window.addEventListener('pagehide', () => { ro.disconnect(); });
  } else {
    const io = new IntersectionObserver(([e]) => {
      if (e.isIntersecting) { if (!rafId) rafId = requestAnimationFrame(tick); }
      else { cancelAnimationFrame(rafId); rafId = 0; }
    }, { threshold: 0.01 });
    io.observe(canvas);
    window.addEventListener('pagehide', () => { cancelAnimationFrame(rafId); io.disconnect(); ro.disconnect(); });
  }
})();
</script>
