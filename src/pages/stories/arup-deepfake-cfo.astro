            <span class="arup-call-tile-icon" aria-hidden="true">👤</span>
            <span class="arup-call-tile-label">CFO</span>
            <span class="arup-call-tile-role">UK Head Office</span>
          </div>
          <div class="arup-call-tile arup-call-tile-fake">
            <div class="arup-call-tile-scanline"></div>
            <span class="arup-call-tile-icon" aria-hidden="true">👤</span>
            <span class="arup-call-tile-label">Senior Colleague</span>
            <span class="arup-call-tile-role">Finance</span>
          </div>
          <div class="arup-call-tile arup-call-tile-fake">
            <div class="arup-call-tile-scanline"></div>
