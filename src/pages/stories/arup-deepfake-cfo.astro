  const P_FORM_END = 60;
  const P_APPROACH_END = 240;
  const P_TRUST_END = 360;
  const P_DISSOLVE_END = 540;
  const P_AFTER_END = 660;
  const CYCLE = 720;

  const DUST_COUNT = 14;
  const NODE_COUNT = 5;

  let W = 0, H = 0, raf = 0, frame = 0;
  let dpr = 1;

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  interface CallNode {
    baseX: number; baseY: number; x: number; y: number;
    pulseRate: number; pulsePhase: number;
    alpha: number; baseAlpha: number; coreRadius: number;
    ringAlpha: number; scanlineStart: number; dissolved: boolean;
  }
  interface Employee { x: number; y: number; baseX: number; targetX: number; haloAlpha: number; alpha: number; }
  interface Dust { x: number; y: number; vx: number; vy: number; alpha: number; r: number; }

  let nodes: CallNode[] = [];
  let employee: Employee = { x: 0, y: 0, baseX: 0, targetX: 0, haloAlpha: 0, alpha: 0 };
  let dust: Dust[] = [];

  function easeInOut(t: number): number { return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2; }
  function easeIn(t: number): number { return t * t; }

  function initState() {
    frame = 0;
    nodes = [];
    const arcCX = W * 0.62, arcCY = H * 0.5, arcRX = W * 0.12, arcRY = H * 0.32;
    for (let i = 0; i < NODE_COUNT; i++) {
      const angle = -0.6 + (1.2 * i) / (NODE_COUNT - 1);
      const bx = arcCX + Math.sin(angle) * arcRX;
      const by = arcCY - Math.cos(angle) * arcRY;
      nodes.push({ baseX: bx, baseY: by, x: bx, y: by, pulseRate: 0.03 + Math.random() * 0.015, pulsePhase: Math.random() * Math.PI * 2, alpha: 0, baseAlpha: 0.4, coreRadius: (4.5 + Math.random() * 1.5) * dpr, ringAlpha: 0, scanlineStart: -1, dissolved: false });
    }
    const empX = W * 0.12;
    employee = { x: empX, y: H * 0.5, baseX: empX, targetX: arcCX - arcRX * 0.3, haloAlpha: 0, alpha: 0 };
    dust = [];
    for (let i = 0; i < DUST_COUNT; i++) {
      dust.push({ x: Math.random() * W, y: Math.random() * H, vx: (Math.random() - 0.5) * 0.08 * dpr, vy: (Math.random() - 0.5) * 0.08 * dpr, alpha: 0.03 + Math.random() * 0.04, r: (0.8 + Math.random() * 0.8) * dpr });
    }
  }

  const ro = new ResizeObserver(() => {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    W = canvas!.offsetWidth * dpr; H = canvas!.offsetHeight * dpr;
    canvas!.width = W; canvas!.height = H;
    initState();
    if (prefersReduced) requestAnimationFrame(drawStatic);
  });
  ro.observe(canvas);

  function draw() {
    ctx!.clearRect(0, 0, W, H);
    for (let i = 0; i < dust.length; i++) {
      const d = dust[i];
      d.x += d.vx; d.y += d.vy;
      if (d.x < 0) d.x = W; if (d.x > W) d.x = 0;
      if (d.y < 0) d.y = H; if (d.y > H) d.y = 0;
      ctx!.beginPath(); ctx!.arc(d.x, d.y, d.r, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(${OFF_R},${OFF_G},${OFF_B},${d.alpha})`; ctx!.fill();
    }

    const f = frame;
    for (let i = 0; i < nodes.length; i++) {
      const n = nodes[i];
      if (f < P_FORM_END) {
        const t = f / P_FORM_END; n.alpha = n.baseAlpha * easeIn(t); n.x = n.baseX; n.y = n.baseY; n.ringAlpha = 0; n.dissolved = false; n.scanlineStart = -1;
      } else if (f < P_APPROACH_END) {
        const t = (f - P_FORM_END) / (P_APPROACH_END - P_FORM_END);
        n.alpha = 0.4 + 0.3 * easeInOut(t);
        n.x = n.baseX - 1.5 * dpr * easeInOut(t) + Math.sin(f * n.pulseRate + n.pulsePhase) * 1.5 * dpr;
        n.y = n.baseY + Math.cos(f * n.pulseRate * 0.7 + n.pulsePhase) * 1.5 * dpr;
      } else if (f < P_TRUST_END) {
        n.alpha = 0.7;
        n.x = n.baseX - 1.5 * dpr + Math.sin(f * n.pulseRate + n.pulsePhase) * 1.0 * dpr;
        n.y = n.baseY + Math.cos(f * n.pulseRate * 0.7 + n.pulsePhase) * 1.0 * dpr;
      } else if (f < P_DISSOLVE_END) {
        const dissolveOrder = [0, 4, 1, 3, 2];
        const startOffset = dissolveOrder[i] * 30;
        const dissolveStart = P_TRUST_END + startOffset;
        if (f >= dissolveStart && n.scanlineStart < 0) n.scanlineStart = f;
        if (n.scanlineStart >= 0) {
          const dt = f - n.scanlineStart;
          if (dt < 50) { n.alpha = 0.7 * (1 - (dt / 50) * 0.8); n.ringAlpha = dt / 50; }
          else { n.dissolved = true; n.alpha = 0; const fadeS = P_DISSOLVE_END - 30; n.ringAlpha = f > fadeS ? Math.max(0, 1 - (f - fadeS) / 30) : 0.5; }
        } else {
          n.alpha = 0.7; n.x = n.baseX - 1.5 * dpr + Math.sin(f * n.pulseRate + n.pulsePhase) * 1.0 * dpr;
          n.y = n.baseY + Math.cos(f * n.pulseRate * 0.7 + n.pulsePhase) * 1.0 * dpr;
        }
      } else if (f < P_AFTER_END) {
        const t = (f - P_DISSOLVE_END) / (P_AFTER_END - P_DISSOLVE_END);
        n.alpha = 0; n.ringAlpha = Math.max(0, 0.35 * (1 - t)); n.dissolved = true;
      } else {
        const t = (f - P_AFTER_END) / (CYCLE - P_AFTER_END);
        n.x = n.baseX; n.y = n.baseY; n.alpha = 0.4 * easeInOut(Math.min(1, t)); n.ringAlpha = 0; n.dissolved = false; n.scanlineStart = -1;
      }
    }

    if (f >= P_FORM_END * 0.5 && f < P_DISSOLVE_END) {
      let lineAlpha = 0.06;
      if (f < P_FORM_END) lineAlpha = 0.06 * (f / P_FORM_END);
      else if (f >= P_APPROACH_END * 0.8 && f < P_TRUST_END) lineAlpha = 0.04 + Math.sin(f * 0.15) * 0.03;
      else if (f >= P_TRUST_END) lineAlpha = 0.06 * (1 - (f - P_TRUST_END) / (P_DISSOLVE_END - P_TRUST_END));
      if (lineAlpha > 0.003) {
        ctx!.strokeStyle = `rgba(${ACCENT_R},${ACCENT_G},${ACCENT_B},${lineAlpha})`; ctx!.lineWidth = 1 * dpr;
        for (let i = 0; i < nodes.length - 1; i++) { ctx!.beginPath(); ctx!.moveTo(nodes[i].x, nodes[i].y); ctx!.lineTo(nodes[i + 1].x, nodes[i + 1].y); ctx!.stroke(); }
      }
    }

    for (let i = 0; i < nodes.length; i++) {
      const n = nodes[i];
      if (n.alpha > 0.005) {
        ctx!.beginPath(); ctx!.arc(n.x, n.y, n.coreRadius * 2.5, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${ACCENT_R},${ACCENT_G},${ACCENT_B},${n.alpha * 0.12})`; ctx!.fill();
        ctx!.beginPath(); ctx!.arc(n.x, n.y, n.coreRadius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${ACCENT_R},${ACCENT_G},${ACCENT_B},${n.alpha})`; ctx!.fill();
      }
      if (n.scanlineStart >= 0 && !n.dissolved) {
        const dt = f - n.scanlineStart; const scanAlpha = Math.min(0.6, dt * 0.02); const scanR = n.coreRadius * 1.8;
        ctx!.save(); ctx!.beginPath(); ctx!.arc(n.x, n.y, scanR, 0, Math.PI * 2); ctx!.clip();
        const sp = 2 * dpr; ctx!.fillStyle = `rgba(${OFF_R},${OFF_G},${OFF_B},${scanAlpha})`;
        for (let sy = n.y - scanR; sy < n.y + scanR; sy += sp * 2) {
          if (Math.sin(sy * 13.7 + f * 0.5) > 0.2) { ctx!.fillRect(n.x - scanR + Math.sin(sy * 7.3 + f * 0.3) * 3 * dpr, sy, scanR * 2, 1 * dpr); }
        }
        ctx!.restore();
      }
      if (n.ringAlpha > 0.005) {
        ctx!.beginPath(); ctx!.arc(n.x, n.y, n.coreRadius * 1.6, 0, Math.PI * 2);
        ctx!.strokeStyle = `rgba(${ACCENT_R},${ACCENT_G},${ACCENT_B},${n.ringAlpha * 0.4})`; ctx!.lineWidth = 1.2 * dpr; ctx!.stroke();
      }
    }

    if (f < P_FORM_END) { employee.alpha = 0.7 * easeIn(f / P_FORM_END); employee.x = employee.baseX; employee.haloAlpha = 0; }
    else if (f < P_APPROACH_END) {
      const t = (f - P_FORM_END) / (P_APPROACH_END - P_FORM_END);
      employee.x = employee.baseX + (employee.targetX - employee.baseX) * easeInOut(t);
      employee.alpha = 0.7; employee.y = H * 0.5 + Math.sin(f * 0.02) * 3 * dpr; employee.haloAlpha = 0;
    } else if (f < P_TRUST_END) {
      employee.x = employee.targetX; employee.alpha = 0.8; employee.y = H * 0.5;
      employee.haloAlpha = 0.15 * easeInOut(Math.min(1, ((f - P_APPROACH_END) / (P_TRUST_END - P_APPROACH_END)) * 1.5));
    } else if (f < P_DISSOLVE_END) {
      const t = (f - P_TRUST_END) / (P_DISSOLVE_END - P_TRUST_END);
      employee.haloAlpha = 0.15 * (1 - easeIn(Math.min(1, t * 2))); employee.alpha = 0.8;
      employee.x = employee.targetX; employee.y = H * 0.5;
      if (nodes.every(n => n.dissolved)) {
        const lastD = P_TRUST_END + 4 * 30 + 50; const since = f - lastD;
        if (since >= 0 && since < 20) {
          const fa = 0.3 * (1 - since / 20); const fr = (20 + (since / 20) * 30) * dpr;
          ctx!.beginPath(); ctx!.arc(employee.x, employee.y, fr, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(${RED_R},${RED_G},${RED_B},${fa})`; ctx!.fill();
        }
      }
    } else if (f < P_AFTER_END) {
      const t = (f - P_DISSOLVE_END) / (P_AFTER_END - P_DISSOLVE_END);
      employee.x = employee.targetX - t * 30 * dpr; employee.alpha = 0.8 - t * 0.3; employee.haloAlpha = 0; employee.y = H * 0.5;
    } else {
      const t = (f - P_AFTER_END) / (CYCLE - P_AFTER_END);
      employee.x = employee.baseX; employee.y = H * 0.5; employee.alpha = 0.5 * easeInOut(Math.min(1, t)); employee.haloAlpha = 0;
    }

    if (employee.haloAlpha > 0.005) {
      ctx!.beginPath(); ctx!.arc(employee.x, employee.y, 8 * dpr, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(${ACCENT_R},${ACCENT_G},${ACCENT_B},${employee.haloAlpha})`; ctx!.fill();
    }
    if (employee.alpha > 0.005) {
      ctx!.beginPath(); ctx!.arc(employee.x, employee.y, 6 * dpr, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(${OFF_R},${OFF_G},${OFF_B},${employee.alpha * 0.15})`; ctx!.fill();
      ctx!.beginPath(); ctx!.arc(employee.x, employee.y, 3 * dpr, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(${OFF_R},${OFF_G},${OFF_B},${employee.alpha})`; ctx!.fill();
    }
  }

  function drawStatic() { frame = P_TRUST_END - 10; draw(); }

  function tick() { frame++; if (frame >= CYCLE) initState(); draw(); if (!prefersReduced) raf = requestAnimationFrame(tick); }

  dpr = Math.min(window.devicePixelRatio || 1, 2);
  W = canvas.offsetWidth * dpr; H = canvas.offsetHeight * dpr;
  canvas.width = W; canvas.height = H;
  initState();

  if (prefersReduced) { requestAnimationFrame(drawStatic); }
  else {
    const io = new IntersectionObserver(([e]) => {
      if (e.isIntersecting) { if (!raf) raf = requestAnimationFrame(tick); }
      else { cancelAnimationFrame(raf); raf = 0; }
    }, { threshold: 0.01 });
    io.observe(canvas);
    window.addEventListener('pagehide', () => { cancelAnimationFrame(raf); ro.disconnect(); io.disconnect(); });
  }
})();
</script>
