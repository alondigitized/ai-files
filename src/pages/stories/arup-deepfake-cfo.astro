          <div class="arup-ledger-row"><span class="arup-ledger-num">05</span><span class="arup-ledger-date">Jan 17</span><span class="arup-ledger-acct">Acct ****-3318</span><span class="arup-ledger-amt">$14,000,000</span></div>
          <div class="arup-ledger-row"><span class="arup-ledger-num">06</span><span class="arup-ledger-date">Jan 17</span><span class="arup-ledger-acct">Acct ****-5527</span><span class="arup-ledger-amt">$13,200,000</span></div>
          <div class="arup-ledger-row"><span class="arup-ledger-num">07</span><span class="arup-ledger-date">Jan 18</span><span class="arup-ledger-acct">Acct ****-7201</span><span class="arup-ledger-amt">$12,900,000</span></div>
          <div class="arup-ledger-row"><span class="arup-ledger-num">08</span><span class="arup-ledger-date">Jan 18</span><span class="arup-ledger-acct">Acct ****-9045</span><span class="arup-ledger-amt">$14,400,000</span></div>
          <div class="arup-ledger-row"><span class="arup-ledger-num">09</span><span class="arup-ledger-date">Jan 19</span><span class="arup-ledger-acct">Acct ****-6183</span><span class="arup-ledger-amt">$13,700,000</span></div>
          <div class="arup-ledger-row"><span class="arup-ledger-num">10</span><span class="arup-ledger-date">Jan 19</span><span class="arup-ledger-acct">Acct ****-3318</span><span class="arup-ledger-amt">$12,600,000</span></div>
          <div class="arup-ledger-row"><span class="arup-ledger-num">11</span><span class="arup-ledger-date">Jan 20</span><span class="arup-ledger-acct">Acct ****-5527</span><span class="arup-ledger-amt">$14,100,000</span></div>
