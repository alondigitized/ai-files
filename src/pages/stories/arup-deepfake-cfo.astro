          <div class="arup-ledger-row"><span class="arup-ledger-num">13</span><span class="arup-ledger-date">Jan 21</span><span class="arup-ledger-acct">Acct ****-9045</span><span class="arup-ledger-amt">$13,000,000</span></div>
          <div class="arup-ledger-row"><span class="arup-ledger-num">14</span><span class="arup-ledger-date">Jan 21</span><span class="arup-ledger-acct">Acct ****-6183</span><span class="arup-ledger-amt">$12,500,000</span></div>
          <div class="arup-ledger-row"><span class="arup-ledger-num">15</span><span class="arup-ledger-date">Jan 22</span><span class="arup-ledger-acct">Acct ****-5527</span><span class="arup-ledger-amt">$14,200,000</span></div>
        </div>
