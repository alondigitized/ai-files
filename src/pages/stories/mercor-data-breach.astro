<script>
(function () {
  const canvas = document.querySelector('.mercor-data-breach-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const ACCENT_RGB = '168,85,247';
  const RED_RGB = '255,77,77';
  const WHITE_RGB = '232,232,232';
  const PARTICLE_COUNT = 40;
  const CHAIN_COUNT = 14;
  const TOP_COUNT = 4;
  const MAX_SIGNALS = 8;

  const PHASE_CALM = 360;
  const PHASE_FRACTURE = 390;
  const PHASE_BEAM_HIT = 420;
  const PHASE_FLICKER_END = 480;
  const PHASE_HOLD_END = 600;
  const CYCLE_LENGTH = 660;

  let W = 0, H = 0, raf = 0, frame = 0;
  let isVisible = true;
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  interface BottomParticle { x: number; y: number; vy: number; vx: number; alpha: number; radius: number; absorbed: boolean; absorbFrame: number; }
  interface ChainNode { x: number; y: number; baseAlpha: number; phaseOffset: number; fractured: boolean; fractureAlpha: number; }
  interface TopNode { x: number; y: number; radius: number; phaseOffset: number; flickering: boolean; }
  interface SignalDot { x: number; y: number; targetX: number; targetY: number; alpha: number; active: boolean; }

  const particles: BottomParticle[] = [];
  const chainNodes: ChainNode[] = [];
  const topNodes: TopNode[] = [];
  const signals: SignalDot[] = [];

  let beamActive = false, beamY = 0, beamX = 0, beamTargetY = 0;
  let fractureIndex = -1, targetTopIndex = -1;
  let ringActive = false, ringX = 0, ringY = 0, ringRadius = 0, ringAlpha = 0;

  function makeParticle(): BottomParticle {
    return {
      x: Math.random() * W,
      y: H * (0.85 + Math.random() * 0.15),
      vy: -(0.15 + Math.random() * 0.1),
      vx: (Math.random() - 0.5) * 0.15,
      alpha: 0.06 + Math.random() * 0.06,
      radius: 1 + Math.random() * 0.8,
      absorbed: false,
      absorbFrame: 0,
    };
  }
  function resetParticle(p: BottomParticle) {
    p.x = Math.random() * W;
    p.y = H * (0.92 + Math.random() * 0.08);
    p.vy = -(0.15 + Math.random() * 0.1);
    p.vx = (Math.random() - 0.5) * 0.15;
    p.alpha = 0.06 + Math.random() * 0.06;
    p.radius = 1 + Math.random() * 0.8;
    p.absorbed = false;
    p.absorbFrame = 0;
  }
  function fullInit() {
    particles.length = 0;
    for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(makeParticle());
    chainNodes.length = 0;
    const chainY = H * 0.6;
    for (let i = 0; i < CHAIN_COUNT; i++) {
      const t = (i + 0.5) / CHAIN_COUNT;
      chainNodes.push({
        x: W * (0.04 + t * 0.92),
        y: chainY + (Math.random() - 0.5) * 8,
        baseAlpha: 0.4 + Math.random() * 0.15,
        phaseOffset: Math.random() * Math.PI * 2,
        fractured: false,
        fractureAlpha: 0,
      });
    }
    topNodes.length = 0;
    const topY = H * 0.15;
    for (let i = 0; i < TOP_COUNT; i++) {
      const t = (i + 0.5) / TOP_COUNT;
      topNodes.push({
        x: W * (0.1 + t * 0.8),
        y: topY + (Math.random() - 0.5) * 10,
        radius: 6 + Math.random() * 2,
        phaseOffset: Math.random() * Math.PI * 2,
        flickering: false,
      });
    }
    signals.length = 0;
    for (let i = 0; i < MAX_SIGNALS; i++) signals.push({ x: 0, y: 0, targetX: 0, targetY: 0, alpha: 0, active: false });
    beamActive = false;
    ringActive = false;
    fractureIndex = -1;
    targetTopIndex = -1;
    frame = 0;
  }

  const ro = new ResizeObserver(() => {
    W = canvas.offsetWidth;
    H = canvas.offsetHeight;
    canvas.width = W * window.devicePixelRatio;
    canvas.height = H * window.devicePixelRatio;
    ctx.setTransform(window.devicePixelRatio, 0, 0, window.devicePixelRatio, 0, 0);
    fullInit();
    if (prefersReduced) drawStatic();
  });
  ro.observe(canvas);

  const io = new IntersectionObserver(([entry]) => {
    const wasVisible = isVisible;
    isVisible = entry.isIntersecting;
    if (isVisible && !wasVisible && !prefersReduced) {
      raf = requestAnimationFrame(tick);
    }
  }, { threshold: 0.05 });
  io.observe(canvas);

  function spawnSignal() {
    for (let i = 0; i < signals.length; i++) {
      if (!signals[i].active) {
        const srcIdx = Math.floor(Math.random() * chainNodes.length);
        const src = chainNodes[srcIdx];
        if (src.fractured) continue;
        let nearest = 0, nearDist = Infinity;
        for (let j = 0; j < topNodes.length; j++) {
          const dx = topNodes[j].x - src.x;
          const dy = topNodes[j].y - src.y;
          const d = dx * dx + dy * dy;
          if (d < nearDist) { nearDist = d; nearest = j; }
        }
        signals[i].x = src.x;
        signals[i].y = src.y;
        signals[i].targetX = topNodes[nearest].x;
        signals[i].targetY = topNodes[nearest].y;
        signals[i].alpha = 0.15;
        signals[i].active = true;
        return;
      }
    }
  }

  function update() {
    const cycle = frame % CYCLE_LENGTH;
    const chainY = H * 0.6;

    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      if (p.absorbed) {
        const af = frame - p.absorbFrame;
        if (af > 10) resetParticle(p);
        else p.radius = Math.max(0, p.radius * (1 - af / 10));
        continue;
      }
      p.y += p.vy;
      p.x += p.vx;
      p.vx += (Math.random() - 0.5) * 0.02;
      p.vx *= 0.99;
      if (p.y <= chainY + 10 && p.y >= chainY - 15) {
        p.absorbed = true;
        p.absorbFrame = frame;
      }
      if (p.y < chainY - 20) resetParticle(p);
      if (p.x < 0) p.x = W;
      if (p.x > W) p.x = 0;
    }

    if (cycle % 80 === 0 && cycle < PHASE_CALM) spawnSignal();
    for (let i = 0; i < signals.length; i++) {
      const s = signals[i];
      if (!s.active) continue;
      const dx = s.targetX - s.x;
      const dy = s.targetY - s.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 3) { s.active = false; continue; }
      s.x += (dx / dist) * 0.5;
      s.y += (dy / dist) * 0.5;
      s.alpha *= 0.997;
      if (s.alpha < 0.01) s.active = false;
    }

    if (cycle === PHASE_CALM) {
      fractureIndex = Math.floor(CHAIN_COUNT / 2) + Math.floor(Math.random() * 3) - 1;
      chainNodes[fractureIndex].fractured = true;
      chainNodes[fractureIndex].fractureAlpha = 0;
    }
    if (cycle >= PHASE_CALM && cycle < PHASE_CALM + 15 && fractureIndex >= 0) {
      chainNodes[fractureIndex].fractureAlpha = Math.min(1, (cycle - PHASE_CALM) / 15);
    }
    if (cycle === PHASE_FRACTURE && fractureIndex >= 0) {
      beamActive = true;
      beamX = chainNodes[fractureIndex].x;
      beamY = chainNodes[fractureIndex].y;
      let nearest = 0, nearDist = Infinity;
      for (let j = 0; j < topNodes.length; j++) {
        const dx = topNodes[j].x - beamX;
        const dy = topNodes[j].y - beamY;
        const d = dx * dx + dy * dy;
        if (d < nearDist) { nearDist = d; nearest = j; }
      }
      targetTopIndex = nearest;
      beamTargetY = topNodes[nearest].y;
    }
    if (beamActive && cycle >= PHASE_FRACTURE && cycle < PHASE_BEAM_HIT) {
      beamY -= 2;
      if (beamY <= beamTargetY) beamY = beamTargetY;
    }
    if (cycle === PHASE_BEAM_HIT && targetTopIndex >= 0) {
      topNodes[targetTopIndex].flickering = true;
      ringActive = true;
      ringX = topNodes[targetTopIndex].x;
      ringY = topNodes[targetTopIndex].y;
      ringRadius = 0;
      ringAlpha = 0.5;
    }
    if (ringActive) {
      ringRadius += 0.8;
      ringAlpha *= 0.97;
      if (ringRadius > 50 || ringAlpha < 0.01) ringActive = false;
    }
    if (cycle === PHASE_FLICKER_END) {
      if (targetTopIndex >= 0) topNodes[targetTopIndex].flickering = false;
      beamActive = false;
    }
    if (cycle === CYCLE_LENGTH - 1) {
      if (fractureIndex >= 0) {
        chainNodes[fractureIndex].fractured = false;
        chainNodes[fractureIndex].fractureAlpha = 0;
      }
      fractureIndex = -1;
      targetTopIndex = -1;
      beamActive = false;
      ringActive = false;
    }
  }

  function draw() {
    if (!ctx) return;
    ctx.clearRect(0, 0, W, H);
    const cycle = frame % CYCLE_LENGTH;

    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      if (p.radius <= 0) continue;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${WHITE_RGB},${p.alpha})`;
      ctx.fill();
      if (p.absorbed) {
        const af = frame - p.absorbFrame;
        if (af < 6) {
          const flashA = 0.3 * (1 - af / 6);
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.radius + 4, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${ACCENT_RGB},${flashA})`;
          ctx.fill();
        }
      }
    }

    for (let i = 0; i < chainNodes.length - 1; i++) {
      const a = chainNodes[i];
      const b = chainNodes[i + 1];
      if (fractureIndex >= 0 && cycle >= PHASE_CALM) {
        if (i === fractureIndex || i === fractureIndex - 1) {
          if (cycle < PHASE_HOLD_END) continue;
          const resetProgress = (cycle - PHASE_HOLD_END) / (CYCLE_LENGTH - PHASE_HOLD_END);
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = `rgba(${ACCENT_RGB},${0.15 * resetProgress})`;
          ctx.lineWidth = 1;
          ctx.stroke();
          continue;
        }
      }
      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.strokeStyle = `rgba(${ACCENT_RGB},0.15)`;
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    for (let i = 0; i < chainNodes.length; i++) {
      const n = chainNodes[i];
      const pulse = Math.sin(frame * 0.026 + n.phaseOffset) * 0.15 + 0.5;
      let nodeAlpha = n.baseAlpha * pulse;
      let nodeColor = ACCENT_RGB;
      let nodeRadius = 3;
      if (n.fractured && cycle >= PHASE_CALM && cycle < PHASE_HOLD_END) {
        const redMix = n.fractureAlpha;
        nodeColor = RED_RGB;
        nodeAlpha = 0.4 + redMix * 0.3;
        nodeRadius = 3 + redMix * 1.5;
      }
      if (n.fractured && cycle >= PHASE_HOLD_END) {
        const resetProgress = (cycle - PHASE_HOLD_END) / (CYCLE_LENGTH - PHASE_HOLD_END);
        nodeColor = resetProgress > 0.5 ? ACCENT_RGB : RED_RGB;
        nodeAlpha = 0.4 * (1 - resetProgress) + n.baseAlpha * pulse * resetProgress;
        n.fractureAlpha = 1 - resetProgress;
      }
      ctx.beginPath();
      ctx.arc(n.x, n.y, nodeRadius, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${nodeColor},${nodeAlpha})`;
      ctx.fill();
      if (nodeAlpha > 0.3) {
        ctx.beginPath();
        ctx.arc(n.x, n.y, nodeRadius + 6, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${nodeColor},${nodeAlpha * 0.15})`;
        ctx.fill();
      }
    }

    for (let i = 0; i < signals.length; i++) {
      const s = signals[i];
      if (!s.active) continue;
      ctx.beginPath();
      ctx.arc(s.x, s.y, 1.5, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${ACCENT_RGB},${s.alpha})`;
      ctx.fill();
    }

    for (let i = 0; i < topNodes.length; i++) {
      const tn = topNodes[i];
      const pulse = Math.sin(frame * 0.015 + tn.phaseOffset) * 0.08 + 0.5;
      let nodeAlpha = pulse;
      let nodeColor = WHITE_RGB;
      let r = tn.radius;
      if (tn.flickering && cycle >= PHASE_BEAM_HIT && cycle < PHASE_FLICKER_END) {
        const flickFrame = cycle - PHASE_BEAM_HIT;
        if (flickFrame % 8 < 4) { nodeColor = RED_RGB; nodeAlpha = 0.6; }
        else { nodeColor = ACCENT_RGB; nodeAlpha = 0.5; }
        r = tn.radius + Math.sin(flickFrame * 0.5) * 1.5;
      }
      if (i === targetTopIndex && cycle >= PHASE_FLICKER_END && cycle < PHASE_HOLD_END) {
        nodeColor = WHITE_RGB;
        nodeAlpha = pulse;
      }
      if (i === targetTopIndex && cycle >= PHASE_HOLD_END) {
        const resetProgress = (cycle - PHASE_HOLD_END) / (CYCLE_LENGTH - PHASE_HOLD_END);
        nodeColor = WHITE_RGB;
        nodeAlpha = pulse * (0.7 + resetProgress * 0.3);
      }
      ctx.beginPath();
      ctx.arc(tn.x, tn.y, r + 12, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${nodeColor},${nodeAlpha * 0.06})`;
      ctx.fill();
      ctx.beginPath();
      ctx.arc(tn.x, tn.y, r + 5, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${nodeColor},${nodeAlpha * 0.12})`;
      ctx.fill();
      ctx.beginPath();
      ctx.arc(tn.x, tn.y, r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${nodeColor},${nodeAlpha})`;
      ctx.fill();
    }

    if (beamActive && fractureIndex >= 0) {
      const srcNode = chainNodes[fractureIndex];
      const beamStartY = srcNode.y;
      const currentBeamY = Math.max(beamY, beamTargetY);
      ctx.beginPath();
      ctx.moveTo(beamX, beamStartY);
      ctx.lineTo(beamX, currentBeamY);
      ctx.strokeStyle = `rgba(${ACCENT_RGB},0.7)`;
      ctx.lineWidth = 3;
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(beamX, beamStartY);
      ctx.lineTo(beamX, currentBeamY);
      ctx.strokeStyle = `rgba(${ACCENT_RGB},0.15)`;
      ctx.lineWidth = 10;
      ctx.stroke();
    }

    if (ringActive) {
      ctx.beginPath();
      ctx.arc(ringX, ringY, ringRadius, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(${RED_RGB},${ringAlpha})`;
      ctx.lineWidth = 1.5;
      ctx.stroke();
    }
  }

  function drawStatic() {
    if (!ctx || W === 0 || H === 0) return;
    const chainY = H * 0.6;
    for (let i = 0; i < 30; i++) {
      const x = W * (0.05 + Math.random() * 0.9);
      const y = H * (0.7 + Math.random() * 0.25);
      ctx.beginPath();
      ctx.arc(x, y, 1 + Math.random() * 0.8, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${WHITE_RGB},${0.06 + Math.random() * 0.06})`;
      ctx.fill();
    }
    const tempChain: { x: number; y: number }[] = [];
    for (let i = 0; i < CHAIN_COUNT; i++) {
      const t = (i + 0.5) / CHAIN_COUNT;
      tempChain.push({ x: W * (0.04 + t * 0.92), y: chainY + (Math.random() - 0.5) * 6 });
    }
    for (let i = 0; i < tempChain.length - 1; i++) {
      ctx.beginPath();
      ctx.moveTo(tempChain[i].x, tempChain[i].y);
      ctx.lineTo(tempChain[i + 1].x, tempChain[i + 1].y);
      ctx.strokeStyle = `rgba(${ACCENT_RGB},0.15)`;
      ctx.lineWidth = 1;
      ctx.stroke();
    }
    for (let i = 0; i < tempChain.length; i++) {
      ctx.beginPath();
      ctx.arc(tempChain[i].x, tempChain[i].y, 3, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${ACCENT_RGB},0.45)`;
      ctx.fill();
    }
    const topY = H * 0.15;
    for (let i = 0; i < TOP_COUNT; i++) {
      const t = (i + 0.5) / TOP_COUNT;
      const x = W * (0.1 + t * 0.8);
      const r = 6 + Math.random() * 2;
      ctx.beginPath();
      ctx.arc(x, topY, r + 5, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${WHITE_RGB},0.06)`;
      ctx.fill();
      ctx.beginPath();
      ctx.arc(x, topY, r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${WHITE_RGB},0.5)`;
      ctx.fill();
    }
  }

  function tick() {
    if (!isVisible) return;
    update();
    draw();
    frame++;
    raf = requestAnimationFrame(tick);
  }

  if (prefersReduced) {
    requestAnimationFrame(() => { if (W > 0 && H > 0) drawStatic(); });
  } else {
    requestAnimationFrame(() => { raf = requestAnimationFrame(tick); });
  }

  window.addEventListener('pagehide', () => {
    cancelAnimationFrame(raf);
    ro.disconnect();
    io.disconnect();
  });
})();
</script>
