  :root[data-theme="light"] .mri-perf-section-label,
  :root[data-theme="light"] .mri-perf-mean-num,
  :root[data-theme="light"] .mri-perf-range-row.high .mri-perf-score,
  :root[data-theme="light"] .mri-perf-range-row.mean-line .mri-perf-condition,
  :root[data-theme="light"] .mri-perf-range-row.mean-line .mri-perf-score,
  :root[data-theme="light"] .mri-perf-gap,
  :root[data-theme="light"] .mri-boundary-panel.validated .mri-boundary-header,
