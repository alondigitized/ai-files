    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--surface2, var(--surface));
    border-bottom: 1px solid var(--border);
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .mri-archive-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--story);
  }
  .mri-archive-body {
    padding: 1.25rem;
  }
  .mri-archive-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.35rem 0;
    font-size: 0.82rem;
    line-height: 1.5;
    border-bottom: 1px solid var(--border);
  }
  .mri-archive-row:last-child {
    border-bottom: none;
  }
  .mri-archive-label {
    color: var(--muted);
  }
  .mri-archive-value {
    color: var(--text);
    font-weight: 700;
    text-align: right;
  }
  .mri-archive-value.accent {
