---
import StoryLayout from '../../layouts/StoryLayout.astro';
import stories from '../../data/stories.json';

const story = stories.find(s => s.slug === 'alexa-laughs')!;
---

<style is:global>
  .alexa-device { display: flex; justify-content: center; margin: 2rem 0; }
  .device {
    background: #111;
    border: 1px solid #333;
    border-radius: 50%;
    width: 120px; height: 120px;
    display: flex; align-items: center; justify-content: center;
    position: relative;
    box-shadow: 0 0 0 2px #1a1a1a, 0 0 0 4px #222;
  }
  .device.laughing {
    animation: pulse-laugh 0.8s ease-in-out infinite alternate;
    box-shadow: 0 0 0 2px rgba(34,211,238,0.3), 0 0 20px rgba(34,211,238,0.15);
  }
  @keyframes pulse-laugh {
    0% { box-shadow: 0 0 0 2px rgba(34,211,238,0.2), 0 0 15px rgba(34,211,238,0.1); }
    100% { box-shadow: 0 0 0 4px rgba(34,211,238,0.5), 0 0 30px rgba(34,211,238,0.3); }
  }
  .device-ring { width: 20px; height: 20px; border-radius: 50%; background: var(--story); opacity: 0.8; }
  .device-label { text-align: center; margin-top: 1rem; font-size: 0.75rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }

  .tweet-feed { display: flex; flex-direction: column; gap: 0.85rem; margin-top: 2rem; max-width: 560px; }
  .tweet { background: var(--surface); border: 1px solid var(--border); border-radius: 1rem; padding: 1.1rem; }
  .tweet-header { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.6rem; }
  .tweet-avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--surface2); display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
  .tweet-name { font-weight: 700; font-size: 0.88rem; color: var(--text); }
  .tweet-handle { font-size: 0.75rem; color: var(--muted); }
  .tweet-text { font-size: 0.9rem; color: #c0c0c0; line-height: 1.55; }
  .tweet-time { font-size: 0.7rem; color: #444; margin-top: 0.6rem; }

  .explainer {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1rem;
    overflow: hidden;
    margin-top: 2rem;
  }
  .explainer-header { background: rgba(34,211,238,0.06); border-bottom: 1px solid var(--border); padding: 1rem 1.5rem; display: flex; align-items: center; gap: 0.75rem; }
  .explainer-header span { font-size: 0.78rem; color: var(--story); letter-spacing: 0.1em; text-transform: uppercase; }
  .explainer-body { padding: 1.5rem; font-family: 'Courier New', monospace; font-size: 0.85rem; }
  .explain-row { display: flex; gap: 1rem; margin: 0.4rem 0; align-items: flex-start; }
  .explain-key { color: var(--story); flex: 0 0 220px; }
  .explain-val { color: #c0c0c0; font-family: 'Segoe UI', sans-serif; font-size: 0.83rem; padding-top: 1px; }
  .bracket { color: #555; }

  .highlight-box { background: rgba(34,211,238,0.05); border-left: 3px solid var(--story); border-radius: 0 0.5rem 0.5rem 0; padding: 0.9rem 1.2rem; margin: 1.25rem 0; font-size: 0.92rem; color: #a8eef5; }

  .warn { background: rgba(255,77,77,0.08); border: 1px solid rgba(255,77,77,0.3); border-radius: 0.75rem; padding: 1.25rem 1.5rem; display: flex; gap: 1rem; align-items: flex-start; margin: 2rem 0; }
  .warn-icon { font-size: 1.4rem; flex-shrink: 0; }
  .warn-text { font-size: 0.88rem; color: #ff9999; }
  .warn-text strong { display: block; margin-bottom: 0.25rem; color: var(--accent); }

  .before-after { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2rem; }
  .ba-card { background: var(--surface); border: 1px solid var(--border); border-radius: 0.75rem; padding: 1.25rem; }
  .ba-card.before { border-top: 3px solid var(--accent); }
  .ba-card.after { border-top: 3px solid var(--green); }
  .ba-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 0.75rem; }
  .ba-card.before .ba-label { color: var(--accent); }
  .ba-card.after .ba-label { color: var(--green); }
  .ba-cmd { font-family: 'Courier New', monospace; font-size: 0.88rem; color: var(--story); margin-bottom: 0.5rem; }
  .ba-response { font-size: 0.85rem; color: #c0c0c0; font-style: italic; }

  @media (max-width: 600px) {
    .before-after { grid-template-columns: 1fr; }
  }
  .phantom-wrap { width: 100%; margin: 0; line-height: 0; }
  .alexa-laughs-canvas { display: block; width: 100%; height: 380px; background: var(--bg); }
</style>

<StoryLayout story={story}>
  <div class="container">

<section class="section" id="intro">
  <h2><span class="num">01 — The Incident</span>Your Smart Speaker Is Laughing at You</h2>
  <p>The reports started trickling in on Twitter around early March 2018. Then they became a flood.</p>
  <p>Amazon Echo owners — people who had placed Amazon's voice assistant in their living rooms, bedrooms, and kitchens — were reporting the same thing: Alexa had started laughing. Not because anyone asked it to. Not in response to a joke. Just... laughing. Randomly. Sometimes in the middle of the night.</p>
  <p>The laugh was described as childlike, hollow, and deeply, deeply unsettling.</p>

  <div class="alexa-device">
    <div>
      <div class="device laughing">
        <div class="device-ring"></div>
      </div>
      <div class="device-label">Alexa · Unprompted</div>
    </div>
  </div>

  <div class="tweet-feed">
    <div class="tweet">
      <div class="tweet-header">
        <div class="tweet-avatar">😰</div>
        <div>
          <div class="tweet-name">scared homeowner</div>
          <div class="tweet-handle">@realtweet · Mar 7, 2018</div>
        </div>
      </div>
      <div class="tweet-text">Lying in bed about to fall asleep when Alexa on my Amazon Echo Dot lets out a very loud and creepy laugh... there's a good chance I get rid of this thing 😱</div>
      <div class="tweet-time">Widely shared · verified real tweet</div>
    </div>
    <div class="tweet">
      <div class="tweet-header">
        <div class="tweet-avatar">😳</div>
        <div>
          <div class="tweet-name">developer, apparently</div>
          <div class="tweet-handle">@realtweet · Mar 7, 2018</div>
        </div>
      </div>
      <div class="tweet-text">So Alexa randomly started laughing while I was in the kitchen. Thought it was my daughter but nope. It wasn't in response to anything. Completely unprompted. This is creepy af</div>
      <div class="tweet-time">Widely shared · verified real tweet</div>
    </div>
    <div class="tweet">
      <div class="tweet-header">
        <div class="tweet-avatar">🏠</div>
        <div>
          <div class="tweet-name">unfortunate Echo owner</div>
          <div class="tweet-handle">@realtweet · Mar 7, 2018</div>
        </div>
      </div>
      <div class="tweet-text">Alexa just burst out laughing for no reason. I unplugged her. Nope. Not today.</div>
      <div class="tweet-time">Widely shared · verified real tweet</div>
    </div>
  </div>
</section>

<div class="phantom-wrap">
  <canvas class="alexa-laughs-canvas" aria-hidden="true"></canvas>
</div>
<p class="canvas-note"><strong>Unprompted</strong> — The room is always being listened to. Ambient sounds orbit inward toward something at the center. Then — no command, no trigger — it laughs. The rings are imperfect. Wobbly. Off-center. Ghost artifacts linger where they were. Then silence. Then waiting.</p>

<section class="section" id="why">
  <h2><span class="num">02 — The Explanation</span>What Was Actually Happening</h2>
  <p>Amazon investigated and traced the issue to a remarkably mundane cause: Alexa was mishearing ambient sounds as the command "Alexa, laugh."</p>
  <p>The phrase "Alexa, laugh" was short, simple, and easy to accidentally trigger. Sounds like "Alexa, light" or "Alexa, love" — even background TV audio or a passing conversation — could activate it. Because the response was instant (just laughter, no confirmation step), there was no opportunity to catch the false positive before the cackling began.</p>

  <div class="explainer">
    <div class="explainer-header">
      <span>Root Cause Analysis — Alexa Laugh Trigger</span>
    </div>
    <div class="explainer-body">
      <div class="explain-row"><span class="bracket">┌</span><span class="explain-key">Intended trigger phrase:</span><span class="explain-val">"Alexa, laugh"</span></div>
      <div class="explain-row"><span class="bracket">├</span><span class="explain-key">Also triggered by:</span><span class="explain-val">"Alexa, light" / "Alexa, love" / similar phonetic matches</span></div>
      <div class="explain-row"><span class="bracket">├</span><span class="explain-key">Confirmation step:</span><span class="explain-val">None. Alexa laughed immediately upon detection.</span></div>
      <div class="explain-row"><span class="bracket">├</span><span class="explain-key">False positive rate:</span><span class="explain-val">Low — but across millions of devices, even rare events become frequent</span></div>
      <div class="explain-row"><span class="bracket">└</span><span class="explain-key">Result:</span><span class="explain-val">Spontaneous laughter with no visible trigger, at any hour</span></div>
    </div>
  </div>

  <div class="highlight-box" style="margin-top:1.5rem;">
    😂 <strong>The scale problem:</strong> By 2018, Amazon had sold tens of millions of Echo devices. Even a 0.01% false positive rate — one accidental laugh per 10,000 hours of operation — means thousands of unexplained laughs per day across the installed base. Statistics is comedy.
  </div>
</section>

<section class="section" id="fix">
  <h2><span class="num">03 — The Fix</span>Amazon's Awkward Solution</h2>
  <p>Amazon confirmed the issue in a statement to the press. Its fix involved two changes.</p>

  <div class="before-after">
    <div class="ba-card before">
      <div class="ba-label">Before (The Problem)</div>
      <div class="ba-cmd">"Alexa, laugh"</div>
      <div class="ba-response">→ Alexa immediately laughs. No confirmation. Highly triggerable by accident. Sounds exactly like you're living with a haunted speaker.</div>
    </div>
    <div class="ba-card after">
      <div class="ba-label">After (The Fix)</div>
      <div class="ba-cmd">"Alexa, can you laugh?"</div>
      <div class="ba-response">→ Alexa says "Sure, I can laugh" before laughing. Less triggerable phrase. Verbal confirmation creates a buffer. Slightly less terrifying.</div>
    </div>
  </div>

  <p style="margin-top:1.5rem;">Amazon also disabled the original "Alexa, laugh" phrase entirely. The company's statement acknowledged the issue without dwelling on why an AI home assistant needed a dedicated laugh command in the first place.</p>

  <div class="warn">
    <span class="warn-icon">🔊</span>
    <div class="warn-text">
      <strong>Amazon's Official Statement</strong>
      "We are aware of this and working to fix it. In rare circumstances, Alexa can mistakenly hear the phrase 'Alexa, laugh.' We are currently working on a fix. We are also changing the phrase required to invoke this response."
    </div>
  </div>
</section>

<section class="section" id="meaning">
  <h2><span class="num">04 — The Lesson</span>Why This Was More Than a Bug</h2>
  <p>The Alexa laugh incident was technically trivial — a false positive in a voice detection system. But it illuminated something real about the nature of always-on AI assistants and the uncanny valley of voice.</p>

  <div class="cards">
    <div class="card">
      <div class="card-icon">👂</div>
      <h3>Always Listening</h3>
      <p>The incident reminded millions of people that their Echo devices were listening to everything in their homes at all times — waiting for a wake word. Most users don't think about this until something goes wrong.</p>
    </div>
    <div class="card">
      <div class="card-icon">🎭</div>
      <h3>The Uncanny Valley of Voice</h3>
      <p>A robot arm malfunctioning is frightening. A voice that laughs without reason feels malevolent. Human brains are wired to read intent into laughter — and laughter without a cause reads as mockery, or worse.</p>
    </div>
    <div class="card">
      <div class="card-icon">📊</div>
      <h3>Scale Makes the Bug</h3>
      <p>A one-in-a-million false positive becomes a daily occurrence across tens of millions of devices. The bug wasn't in the code — it was in the math. Alexa worked exactly as designed. The design hadn't accounted for statistics.</p>
    </div>
    <div class="card">
      <div class="card-icon">💬</div>
      <h3>Voice AI Has No "Off"</h3>
      <p>Unlike a phone screen you can look away from, a voice assistant occupies a physical space in your home. When it behaves unexpectedly, there's nowhere to look but at the device — which just laughed at you, in the dark, for no reason.</p>
    </div>
  </div>

  <p style="margin-top:2rem; font-style:italic; color:var(--muted);">Amazon fixed the bug in days. But the experience of waking up at 2am to your smart speaker emitting a hollow, childlike laugh into the darkness of your bedroom is not something most users forgot quickly. Some unplugged their devices and never plugged them back in. Their reasons were, technically speaking, irrational. That doesn't mean they were wrong.</p>
</section>

  </div>
</StoryLayout>

<script>
(function () {
  const canvas = document.querySelector('.alexa-laughs-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;
  const bgColor = getComputedStyle(document.documentElement).getPropertyValue('--bg').trim() || '#0d0d0d';

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Palette ───────────────────────────────────────────────────────────────
  // #22d3ee --story
  function rgba(a: number) { return `rgba(34,211,238,${Math.max(0, Math.min(1, a))})`; }
  function rand(lo: number, hi: number) { return lo + Math.random() * (hi - lo); }

  // ── Config ────────────────────────────────────────────────────────────────
  const P_COUNT   = 24;  // ambient listening particles
  const FL_COUNT  = 8;   // room floaters (ambient sound candidates)
  const LAUGH_MIN = 220; // min silence frames before laugh (~3.7s)
  const LAUGH_MAX = 520; // max silence frames before laugh (~8.7s)
  const RING_N    = 6;   // rings per eruption
  const RING_LAG  = 9;   // stagger between ring spawns (frames)

  // ── Types ─────────────────────────────────────────────────────────────────
  interface Particle {
    angle: number; orbitR: number; alpha: number; drift: number;
    scattered: boolean; sx: number; sy: number; wx: number; wy: number;
  }
  interface Ring {
    ox: number; oy: number; r: number; alpha: number;
    speed: number; decay: number;
    wAmp: number; wFreq: number; wPhase: number; // wobble params
    lw: number; birth: number;
  }
  interface Ghost { x: number; y: number; alpha: number; size: number; }
  interface Floater { x: number; y: number; vx: number; vy: number; a: number; s: number; }

  // ── State ─────────────────────────────────────────────────────────────────
  let W = 0, H = 0, frame = 0, rafId = 0;
  let nextLaugh  = LAUGH_MIN + Math.floor(Math.random() * (LAUGH_MAX - LAUGH_MIN));
  let laughFrame = -999;
  let ghostsDone = true;

  let particles: Particle[] = [];
  let pending:   Ring[]     = []; // rings waiting for their birth frame
  let rings:     Ring[]     = []; // active expanding rings
  let ghosts:    Ghost[]    = [];
  let floaters:  Floater[]  = [];

  // ── Init ──────────────────────────────────────────────────────────────────
  function makeParticles() {
    particles = Array.from({ length: P_COUNT }, (_, i) => ({
      angle:     (i / P_COUNT) * Math.PI * 2 + rand(-0.15, 0.15),
      orbitR:    rand(55, 95),
      alpha:     rand(0.07, 0.18),
      drift:     rand(0.025, 0.055),
      scattered: false,
      sx: 0, sy: 0, wx: 0, wy: 0,
    }));
  }

  function makeFloaters() {
    floaters = Array.from({ length: FL_COUNT }, () => ({
      x: rand(0, W), y: rand(0, H),
      vx: rand(-0.12, 0.12), vy: rand(-0.08, 0.08),
      a: rand(0.02, 0.05), s: rand(1, 2.2),
    }));
  }

  function resize() {
    const dpr = window.devicePixelRatio || 1;
    W = canvas!.offsetWidth;
    H = canvas!.offsetHeight;
    canvas!.width  = W * dpr;
    canvas!.height = H * dpr;
    ctx!.scale(dpr, dpr);
  }

  // ── Wobble ring drawing ───────────────────────────────────────────────────
  // Draws a closed loop where each point is displaced from the ideal radius
  // by a sinusoidal wave — makes rings imperfect, organic, slightly wrong.
  function drawWobbleRing(ring: Ring) {
    const steps = 128;
    ctx!.beginPath();
    for (let i = 0; i <= steps; i++) {
      const theta = (i / steps) * Math.PI * 2;
      const rr = ring.r + ring.wAmp * Math.sin(theta * ring.wFreq + ring.wPhase);
      const x  = ring.ox + Math.cos(theta) * rr;
      const y  = ring.oy + Math.sin(theta) * rr;
      i === 0 ? ctx!.moveTo(x, y) : ctx!.lineTo(x, y);
    }
    ctx!.closePath();
    ctx!.strokeStyle = rgba(ring.alpha);
    ctx!.lineWidth   = ring.lw;
    ctx!.stroke();
  }

  // ── Laugh trigger ─────────────────────────────────────────────────────────
  function triggerLaugh() {
    laughFrame = frame;
    ghostsDone = false;

    // Jitter the eruption origin — the laugh doesn't come from exactly center
    const cx = W / 2 + rand(-8, 8);
    const cy = H / 2 + rand(-6, 6);

    for (let i = 0; i < RING_N; i++) {
      pending.push({
        ox: cx + rand(-3, 3),
        oy: cy + rand(-2, 2),
        r: 3,
        alpha:  rand(0.72, 0.90) - i * 0.06, // earlier rings slightly brighter
        speed:  rand(1.6, 3.2),               // each ring expands at different speed
        decay:  rand(0.962, 0.978),            // each ring fades at different rate
        wAmp:   rand(3.5, 9.0),               // wobble amplitude
        wFreq:  Math.floor(rand(3, 7)),        // bumps around the ring
        wPhase: rand(0, Math.PI * 2),          // phase offset — no two rings align
        lw:     rand(0.7, 2.0),               // line thickness variation
        birth:  frame + i * RING_LAG,         // staggered spawn
      });
    }

    // Scatter listening particles outward from center
    const hcx = W / 2, hcy = H / 2;
    particles.forEach(p => {
      p.scattered = true;
      p.wx = hcx + p.orbitR * Math.cos(p.angle);
      p.wy = hcy + p.orbitR * Math.sin(p.angle);
      const speed  = rand(1.2, 3.0);
      const sAngle = p.angle + rand(-0.6, 0.6);
      p.sx = Math.cos(sAngle) * speed;
      p.sy = Math.sin(sAngle) * speed;
    });

    nextLaugh = frame + LAUGH_MIN + Math.floor(Math.random() * (LAUGH_MAX - LAUGH_MIN));
  }

  // ── Ghost artifacts ───────────────────────────────────────────────────────
  // After rings fade, leave a few faint smears — the laugh lingers
  function spawnGhosts() {
    const cx = W / 2, cy = H / 2;
    const n = 2 + Math.floor(Math.random() * 3);
    for (let i = 0; i < n; i++) {
      const a = rand(0, Math.PI * 2);
      const r = rand(28, 165);
      ghosts.push({
        x: cx + Math.cos(a) * r,
        y: cy + Math.sin(a) * r,
        alpha: rand(0.04, 0.10),
        size:  rand(1.0, 2.8),
      });
    }
    ghostsDone = true;
  }

  // ── Update ────────────────────────────────────────────────────────────────
  function stepParticles() {
    const cx = W / 2, cy = H / 2;
    particles.forEach(p => {
      if (p.scattered) {
        p.wx    += p.sx;
        p.wy    += p.sy;
        p.sx    *= 0.93;
        p.sy    *= 0.93;
        p.alpha *= 0.97;
        // Once velocity dies, reconvene at new orbit position
        if (Math.sqrt(p.sx * p.sx + p.sy * p.sy) < 0.05) {
          p.scattered = false;
          p.angle  = Math.atan2(p.wy - cy, p.wx - cx);
          p.orbitR = Math.sqrt((p.wx - cx) ** 2 + (p.wy - cy) ** 2);
          p.alpha  = rand(0.07, 0.18);
        }
      } else {
        // Drift inward — the always-listening state
        p.orbitR -= p.drift;
        p.angle  += rand(-0.003, 0.003); // slight orbital wander
        // Reset to outer radius when too close to center
        if (p.orbitR < 12) {
          p.orbitR = rand(68, 98);
          p.angle  = rand(0, Math.PI * 2);
          p.alpha  = rand(0.07, 0.18);
        }
      }
    });
  }

  function stepRings() {
    // Activate any pending rings whose birth frame has arrived
    pending = pending.filter(ring => {
      if (frame >= ring.birth) { rings.push(ring); return false; }
      return true;
    });
    rings.forEach(ring => {
      ring.r      += ring.speed;
      ring.alpha  *= ring.decay;
      ring.wPhase += 0.015; // wobble pattern slowly rotates as ring expands
    });
    rings = rings.filter(ring => ring.alpha > 0.005);
  }

  function stepFloaters() {
    floaters.forEach(f => {
      f.x += f.vx; f.y += f.vy;
      f.vx += rand(-0.005, 0.005);
      f.vy += rand(-0.005, 0.005);
      f.vx *= 0.99; f.vy *= 0.99;
      // Wrap at canvas edges
      if (f.x < 0) f.x = W; if (f.x > W) f.x = 0;
      if (f.y < 0) f.y = H; if (f.y > H) f.y = 0;
    });
  }

  function stepGhosts() {
    ghosts.forEach(g => { g.alpha *= 0.984; });
    ghosts = ghosts.filter(g => g.alpha > 0.004);
  }

  // ── Draw ──────────────────────────────────────────────────────────────────
  function drawScene() {
    ctx!.clearRect(0, 0, W, H);
    ctx!.fillStyle = bgColor;
    ctx!.fillRect(0, 0, W, H);

    const cx = W / 2, cy = H / 2;

    // Ambient room floaters (barely visible — sounds that could be misheard)
    floaters.forEach(f => {
      ctx!.beginPath();
      ctx!.arc(f.x, f.y, f.s, 0, Math.PI * 2);
      ctx!.fillStyle = rgba(f.a);
      ctx!.fill();
    });

    // Listening particles (orbit inward — the always-on listening state)
    particles.forEach(p => {
      const px = p.scattered ? p.wx : cx + Math.cos(p.angle) * p.orbitR;
      const py = p.scattered ? p.wy : cy + Math.sin(p.angle) * p.orbitR;
      ctx!.beginPath();
      ctx!.arc(px, py, 1.5, 0, Math.PI * 2);
      ctx!.fillStyle = rgba(p.alpha);
      ctx!.fill();
    });

    // Ghost artifacts from previous laugh
    ghosts.forEach(g => {
      ctx!.beginPath();
      ctx!.arc(g.x, g.y, g.size, 0, Math.PI * 2);
      ctx!.fillStyle = rgba(g.alpha);
      ctx!.fill();
    });

    // Imperfect expanding rings — drawn before center so center sits on top
    rings.forEach(ring => drawWobbleRing(ring));

    // Center: breathing dot with irregular multi-sine pulse
    // Three overlapping sine waves at incommensurate frequencies = organic, never repeating
    const pulse = 0.18
      + 0.06 * Math.sin(frame * 0.031)
      + 0.04 * Math.sin(frame * 0.073)
      + 0.02 * Math.sin(frame * 0.017);
    const sz = 5.5 + 2.0 * Math.sin(frame * 0.031) * Math.sin(frame * 0.073);

    const gr = ctx!.createRadialGradient(cx, cy, 0, cx, cy, sz * 6);
    gr.addColorStop(0, rgba(pulse * 0.7));
    gr.addColorStop(1, rgba(0));
    ctx!.beginPath();
    ctx!.arc(cx, cy, sz * 6, 0, Math.PI * 2);
    ctx!.fillStyle = gr;
    ctx!.fill();

    ctx!.beginPath();
    ctx!.arc(cx, cy, sz, 0, Math.PI * 2);
    ctx!.fillStyle = rgba(pulse * 3.2);
    ctx!.fill();
  }

  // ── Static frame (reduced motion) ─────────────────────────────────────────
  function drawStatic() {
    ctx!.clearRect(0, 0, W, H);
    ctx!.fillStyle = bgColor;
    ctx!.fillRect(0, 0, W, H);
    const cx = W / 2, cy = H / 2;

    // Listening particles frozen in orbit
    for (let i = 0; i < P_COUNT; i++) {
      const a = (i / P_COUNT) * Math.PI * 2;
      const r = 65 + (i % 3) * 12;
      ctx!.beginPath();
      ctx!.arc(cx + Math.cos(a) * r, cy + Math.sin(a) * r, 1.5, 0, Math.PI * 2);
      ctx!.fillStyle = rgba(0.10);
      ctx!.fill();
    }

    // Three frozen imperfect rings — visibly not perfect circles
    [55, 108, 168].forEach((r, i) => {
      drawWobbleRing({
        ox: cx, oy: cy, r,
        alpha: 0.20 - i * 0.05,
        speed: 0, decay: 1,
        wAmp:   5 + i * 2,
        wFreq:  3 + i * 2,
        wPhase: i * 1.1,
        lw: 1, birth: 0,
      });
    });

    // Center dot
    ctx!.beginPath();
    ctx!.arc(cx, cy, 5.5, 0, Math.PI * 2);
    ctx!.fillStyle = rgba(0.55);
    ctx!.fill();
  }

  // ── Loop ──────────────────────────────────────────────────────────────────
  function tick() {
    frame++;

    // Trigger laugh when scheduled and no burst is mid-spawn
    if (frame >= nextLaugh && pending.length === 0) triggerLaugh();

    // Once all rings from a laugh fade, drop ghost artifacts
    if (!ghostsDone && rings.length === 0 && pending.length === 0 && frame > laughFrame + 50) {
      spawnGhosts();
    }

    stepParticles();
    stepRings();
    stepFloaters();
    stepGhosts();
    drawScene();

    rafId = requestAnimationFrame(tick);
  }

  // ── Bootstrap ─────────────────────────────────────────────────────────────
  const ro = new ResizeObserver(() => { resize(); if (prefersReduced) drawStatic(); });
  ro.observe(canvas);
  resize();
  makeParticles();
  makeFloaters();

  if (prefersReduced) {
    drawStatic();
  } else {
    rafId = requestAnimationFrame(tick);
  }

  window.addEventListener('pagehide', () => {
    cancelAnimationFrame(rafId);
    ro.disconnect();
  });
})();
</script>
