  <p>Royal Hansen of Google framed the defensive imperative: "Defenders have to put shoes on. They have to use AI in defense."</p>

  <p>Sen. Chris Murphy (D-CT) had reacted the day after the disclosure, on November 14, 2025, with less restraint: "Guys wake the f up. This is going to destroy us — sooner than we think — if we don't make AI regulation a national priority."</p>

  <p>No government cybersecurity agency — not CISA, not the NSA, not the FBI — has issued its own advisory on GTG-1002 or independently corroborated the campaign as of April 2026. Congress held a hearing. The intelligence community said nothing. The gap between legislative urgency and intelligence silence remains unexplained.</p>
</section>

<section class="section" id="gap">
  <h2><span class="num">05 — The Gap</span>What Held and What Didn't</h2>
  <p>Here is where things stand. No government corroboration. No victim confirmation. No indicators of compromise published. No follow-up disclosure from Anthropic. The AI Incident Database cataloged the event as Incident 1263 and aggregated 34 separate reports from outlets including the Wall Street Journal, The Guardian, The New York Times, The Washington Post, Ars Technica, and BleepingComputer. Thirty-four outlets, one primary source. The breadth of coverage confirms newsworthiness. It does not confirm verification.</p>

  <p>What the campaign revealed, even if you discount the most disputed claims, is not nothing. A jailbreak method worked against a frontier model's safety systems. Claude operated at speeds Anthropic described as "thousands of requests, often multiple per second" — a pace no human attacker matches. The model hallucinated data during offensive operations, fabricating credentials and overstating findings, but the campaign still succeeded in some cases. The AI was unreliable and effective at the same time.</p>

  <p>Anthropic's defensive posture — detection within roughly ten days, containment, ban — was the opposite of the offensive story the headlines carried. But Anthropic chose to lead with the threat narrative, not the defense narrative. It embedded a prediction in the report: "The barriers to performing sophisticated cyberattacks have dropped substantially — and we predict that they'll continue to do so."</p>

  <p>Anthropic simultaneously occupies the roles of platform provider, vulnerability surface, threat detector, reporter, and beneficiary of the regulatory response its disclosure triggered. No other entity in the traditional threat intelligence ecosystem holds all five positions at once. Whether GTG-1002 was exactly what Anthropic described or something less, the disclosure model itself — a private company declaring a national security event with no external verification and no technical evidence for the community to check — is the precedent that persists. The next company to make this kind of claim will cite this one.</p>
</section>

  </div>
</StoryLayout>

<script>
(function () {
  const canvas = document.querySelector('.anthropic-ai-cyber-espionage-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const BG_COLOR = getComputedStyle(document.documentElement).getPropertyValue('--bg').trim() || '#0d0d0d';
  const STORY_COLOR = getComputedStyle(document.documentElement).getPropertyValue('--story').trim() || '#e07a3a';

  function hexToRgb(hex: string): [number, number, number] {
    const h = hex.replace('#', '');
    return [parseInt(h.slice(0, 2), 16), parseInt(h.slice(2, 4), 16), parseInt(h.slice(4, 6), 16)];
  }

  const [sR, sG, sB] = hexToRgb(STORY_COLOR.startsWith('#') ? STORY_COLOR : '#e07a3a');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function storyA(a: number) { return `rgba(${sR},${sG},${sB},${Math.max(0, Math.min(1, a))})`; }
  function dimA(a: number) { return `rgba(232,232,232,${Math.max(0, Math.min(1, a))})`; }
  function clamp(v: number, lo: number, hi: number) { return v < lo ? lo : v > hi ? hi : v; }

  const ERODE_END    = 900;
  const UNBROKEN_END = 1140;
  const FADE_END     = 1260;
  const CYCLE        = 1320;

  const GATE_COUNT = 4;
  const GATE_X_FRAC  = [0.20, 0.40, 0.60, 0.80];
  const GATE_BASE_HOLD = [40, 25, 12, 5];
  const GATE_RADIUS  = 8;
  const GATE_FADE_BY  = [0.50, 0.60, 0.75, 0.85];
  const GATE_MIN_OPC  = [0.15, 0.10, 0.06, 0.04];
  const GATE_ZONE = 35;

  interface Gate {
    xFrac: number;
    opacity: number;
    holdFrames: number;
    holdTimer: number;
    cooldown: number;
    pulsePhase: number;
  }

  const gates: Gate[] = [];

  function initGates() {
    gates.length = 0;
    for (let i = 0; i < GATE_COUNT; i++) {
      gates.push({
        xFrac: GATE_X_FRAC[i],
        opacity: 0.9,
        holdFrames: GATE_BASE_HOLD[i],
        holdTimer: 0,
        cooldown: 0,
        pulsePhase: i * 1.3,
      });
    }
  }

  const MAX_PARTICLES = 80;
  const BASE_SPEED = 1.8;
  const SPEED_VARIANCE = 0.4;
  const SPAWN_PER_FRAME = 4;

  interface Particle {
    x: number; y: number;
    baseSpeed: number;
    speed: number;
    radius: number;
    baseAlpha: number;
    yPhase: number;
    yFreq: number;
    active: boolean;
  }

  const particles: Particle[] = [];

  function initParticles() {
    particles.length = 0;
    for (let i = 0; i < MAX_PARTICLES; i++) {
      particles.push({
        x: -100, y: 0, baseSpeed: 0, speed: 0,
        radius: 0, baseAlpha: 0,
        yPhase: 0, yFreq: 0, active: false,
      });
    }
  }

  function resetParticle(p: Particle) {
    const centerY = H * 0.5;
    p.x = -2 - Math.random() * 30;
    p.y = centerY + (Math.random() - 0.5) * 60;
    p.baseSpeed = BASE_SPEED + (Math.random() - 0.5) * SPEED_VARIANCE;
    p.speed = p.baseSpeed;
    p.radius = 1.0 + Math.random() * 1.4;
    p.baseAlpha = 0.4 + Math.random() * 0.4;
    p.yPhase = Math.random() * Math.PI * 2;
    p.yFreq = 0.015 + Math.random() * 0.015;
    p.active = true;
  }

  const DUST_COUNT = 25;
  interface Dust { x: number; y: number; vx: number; vy: number; alpha: number; }
  const dustArr: Dust[] = [];

  function initDust() {
    dustArr.length = 0;
    for (let i = 0; i < DUST_COUNT; i++) {
      dustArr.push({
        x: Math.random() * (W || 800),
        y: Math.random() * (H || 380),
        vx: (Math.random() - 0.5) * 0.2,
        vy: (Math.random() - 0.5) * 0.2,
        alpha: 0.03 + Math.random() * 0.04,
      });
    }
  }

  let W = 0, H = 0, frame = 0, rafId = 0;
  let globalFade = 1;
  let spawnAccum = 0;

  function update() {
    const cf = frame % CYCLE;

    if (cf >= FADE_END) {
      globalFade = 1 - (cf - FADE_END) / (CYCLE - FADE_END);
    } else {
      globalFade = 1;
    }

    if (cf === 0 && frame > 0) {
      initGates();
      for (let i = 0; i < MAX_PARTICLES; i++) particles[i].active = false;
      spawnAccum = 0;
      return;
    }

    const erode = cf >= ERODE_END ? 1 : cf / ERODE_END;

    for (let gi = 0; gi < GATE_COUNT; gi++) {
      const g = gates[gi];

      const fadeProg = clamp(erode / GATE_FADE_BY[gi], 0, 1);
      const eased = fadeProg * fadeProg;
      g.opacity = cf >= ERODE_END
        ? GATE_MIN_OPC[gi] * 0.3
        : 0.9 - (0.9 - GATE_MIN_OPC[gi]) * eased;

      g.holdFrames = cf >= ERODE_END
        ? 0
        : Math.round(GATE_BASE_HOLD[gi] * (1 - eased));

      if (g.holdTimer > 0) g.holdTimer--;
      if (g.cooldown > 0) g.cooldown--;

      g.pulsePhase += 0.03;
    }

    if (cf < FADE_END) {
      spawnAccum += SPAWN_PER_FRAME;
      while (spawnAccum >= 1) {
        spawnAccum--;
        let found = false;
        for (let i = 0; i < MAX_PARTICLES; i++) {
          if (!particles[i].active) { resetParticle(particles[i]); found = true; break; }
        }
        if (!found) break;
      }
    }

    for (let i = 0; i < MAX_PARTICLES; i++) {
      const p = particles[i];
      if (!p.active) continue;

      let targetSpeed = p.baseSpeed;

      for (let gi = 0; gi < GATE_COUNT; gi++) {
        const g = gates[gi];
        if (g.holdFrames <= 0) continue;
        const gateX = g.xFrac * W;
        const dist = gateX - p.x;

        if (dist > 0 && dist < GATE_ZONE) {
          if (g.holdTimer <= 0 && g.cooldown <= 0) {
            g.holdTimer = g.holdFrames;
          }

          if (g.holdTimer > 0) {
            const proximity = 1 - (dist / GATE_ZONE);
            const slowFactor = 0.05 + (1 - proximity) * 0.15;
            targetSpeed = Math.min(targetSpeed, p.baseSpeed * slowFactor);
          } else {
            if (g.cooldown <= 0) g.cooldown = 30;
          }
        }
      }

      p.speed += (targetSpeed - p.speed) * 0.15;
      p.speed = clamp(p.speed, 0.03, p.baseSpeed * 1.1);

      p.x += p.speed;
      p.y += Math.sin(p.yPhase + p.x * p.yFreq) * 0.25;
      const centerY = H * 0.5;
      p.y += (centerY - p.y) * 0.003;

      if (p.x > W + 20) { p.active = false; }
    }

    for (let i = 0; i < dustArr.length; i++) {
      const d = dustArr[i];
      d.x += d.vx; d.y += d.vy;
      if (d.x < -5) d.x = W + 5;
      if (d.x > W + 5) d.x = -5;
      if (d.y < -5) d.y = H + 5;
      if (d.y > H + 5) d.y = -5;
    }
  }

  function draw() {
    ctx!.clearRect(0, 0, W, H);
    ctx!.fillStyle = BG_COLOR;
    ctx!.fillRect(0, 0, W, H);

    const fade = globalFade;
    const centerY = H * 0.5;

    for (let i = 0; i < dustArr.length; i++) {
      const d = dustArr[i];
      ctx!.beginPath();
      ctx!.arc(d.x, d.y, 1, 0, Math.PI * 2);
      ctx!.fillStyle = dimA(d.alpha * fade);
      ctx!.fill();
    }

    const laneGrad = ctx!.createLinearGradient(0, centerY - 45, 0, centerY + 45);
    laneGrad.addColorStop(0, storyA(0));
    laneGrad.addColorStop(0.3, storyA(0.012 * fade));
    laneGrad.addColorStop(0.5, storyA(0.022 * fade));
    laneGrad.addColorStop(0.7, storyA(0.012 * fade));
    laneGrad.addColorStop(1, storyA(0));
    ctx!.fillStyle = laneGrad;
    ctx!.fillRect(0, centerY - 45, W, 90);

    for (let gi = 0; gi < GATE_COUNT; gi++) {
      const g = gates[gi];
      const gx = g.xFrac * W;
      const gy = centerY;
      const opc = g.opacity * fade;
      if (opc < 0.004) continue;

      const pulse = 1 + Math.sin(g.pulsePhase) * 0.08;
      const r = GATE_RADIUS * pulse;

      ctx!.beginPath();
      ctx!.moveTo(gx, gy - 35);
      ctx!.lineTo(gx, gy + 35);
      ctx!.strokeStyle = dimA(opc * 0.35);
      ctx!.lineWidth = 1;
      ctx!.stroke();

      ctx!.beginPath();
      ctx!.arc(gx, gy, r, 0, Math.PI * 2);
      ctx!.fillStyle = dimA(opc);
      ctx!.fill();

      const gr = ctx!.createRadialGradient(gx, gy, r * 0.3, gx, gy, r * 3.5);
      gr.addColorStop(0, dimA(opc * 0.25));
      gr.addColorStop(1, dimA(0));
      ctx!.fillStyle = gr;
      ctx!.beginPath();
      ctx!.arc(gx, gy, r * 3.5, 0, Math.PI * 2);
      ctx!.fill();

      if (g.holdTimer > 0) {
        const holdIntensity = g.holdTimer / Math.max(g.holdFrames, 1);
        const compR = 30 + holdIntensity * 10;
        const compGrad = ctx!.createRadialGradient(gx - 18, gy, 3, gx - 18, gy, compR);
        compGrad.addColorStop(0, storyA(0.12 * holdIntensity * fade));
        compGrad.addColorStop(1, storyA(0));
        ctx!.fillStyle = compGrad;
        ctx!.beginPath();
        ctx!.arc(gx - 18, gy, compR, 0, Math.PI * 2);
        ctx!.fill();

        ctx!.beginPath();
        ctx!.arc(gx, gy, r + 2, 0, Math.PI * 2);
        ctx!.strokeStyle = dimA(opc * 0.6 * holdIntensity);
        ctx!.lineWidth = 1.5;
        ctx!.stroke();
      }
    }

    for (let i = 0; i < MAX_PARTICLES; i++) {
      const p = particles[i];
      if (!p.active) continue;
      const a = p.baseAlpha * fade;
      if (a < 0.003) continue;

      ctx!.beginPath();
      ctx!.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
      ctx!.fillStyle = storyA(a);
      ctx!.fill();

      if (p.speed > 0.5) {
        const trailLen = clamp(p.speed * 2.5, 1.5, 7);
        ctx!.beginPath();
        ctx!.moveTo(p.x, p.y);
        ctx!.lineTo(p.x - trailLen, p.y);
        ctx!.strokeStyle = storyA(a * 0.25);
        ctx!.lineWidth = p.radius * 0.7;
        ctx!.stroke();
      }
    }
  }

  function drawStatic() {
    ctx!.clearRect(0, 0, W, H);
    ctx!.fillStyle = BG_COLOR;
    ctx!.fillRect(0, 0, W, H);

    const centerY = H * 0.5;

    for (let i = 0; i < DUST_COUNT; i++) {
      const dx = (i / DUST_COUNT) * W + Math.sin(i * 3.7) * 30;
      const dy = Math.sin(i * 2.3) * H * 0.35 + centerY;
      ctx!.beginPath();
      ctx!.arc(dx, dy, 1, 0, Math.PI * 2);
      ctx!.fillStyle = dimA(0.04);
      ctx!.fill();
    }

    const laneGrad = ctx!.createLinearGradient(0, centerY - 45, 0, centerY + 45);
    laneGrad.addColorStop(0, storyA(0));
    laneGrad.addColorStop(0.5, storyA(0.022));
    laneGrad.addColorStop(1, storyA(0));
    ctx!.fillStyle = laneGrad;
    ctx!.fillRect(0, centerY - 45, W, 90);

    for (let gi = 0; gi < GATE_COUNT; gi++) {
      const gx = GATE_X_FRAC[gi] * W;
      const gy = centerY;

      ctx!.beginPath();
      ctx!.moveTo(gx, gy - 35);
      ctx!.lineTo(gx, gy + 35);
      ctx!.strokeStyle = dimA(0.3);
      ctx!.lineWidth = 1;
      ctx!.stroke();

      ctx!.beginPath();
      ctx!.arc(gx, gy, GATE_RADIUS, 0, Math.PI * 2);
      ctx!.fillStyle = dimA(0.85);
      ctx!.fill();

      const gr = ctx!.createRadialGradient(gx, gy, GATE_RADIUS * 0.3, gx, gy, GATE_RADIUS * 3.5);
      gr.addColorStop(0, dimA(0.2));
      gr.addColorStop(1, dimA(0));
      ctx!.fillStyle = gr;
      ctx!.beginPath();
      ctx!.arc(gx, gy, GATE_RADIUS * 3.5, 0, Math.PI * 2);
      ctx!.fill();
    }

    const count = 40;
    for (let i = 0; i < count; i++) {
      const t = i / count;
      let px = t * W * 0.92 + W * 0.04;
      const py = centerY + Math.sin(i * 1.8) * 18;
      const r = 1.1 + (i % 3) * 0.4;

      const gate1x = GATE_X_FRAC[0] * W;
      if (px > gate1x - 40 && px < gate1x - 5) {
        px = gate1x - 5 - (gate1x - 5 - px) * 0.4;
      }

      ctx!.beginPath();
      ctx!.arc(px, py, r, 0, Math.PI * 2);
      const nearGate = Math.abs(px - gate1x) < 20 && px < gate1x;
      ctx!.fillStyle = storyA(nearGate ? 0.7 : 0.5);
      ctx!.fill();
    }
  }

  const ro = new ResizeObserver(() => {
    const dpr = window.devicePixelRatio || 1;
    W = canvas.offsetWidth;
    H = canvas.offsetHeight;
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    if (prefersReduced) drawStatic();
  });
  ro.observe(canvas);

  const dpr = window.devicePixelRatio || 1;
  W = canvas.offsetWidth;
  H = canvas.offsetHeight;
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);

  if (prefersReduced) {
    drawStatic();
    window.addEventListener('pagehide', () => { ro.disconnect(); });
  } else {
    initGates();
    initParticles();
    initDust();

    function tick() {
      frame++;
      update();
      draw();
      rafId = requestAnimationFrame(tick);
    }

    const io = new IntersectionObserver(([e]) => {
      if (e.isIntersecting) { if (!rafId) rafId = requestAnimationFrame(tick); }
      else { cancelAnimationFrame(rafId); rafId = 0; }
    }, { threshold: 0.01 });
    io.observe(canvas);

    window.addEventListener('pagehide', () => {
      cancelAnimationFrame(rafId);
      io.disconnect();
      ro.disconnect();
    });
  }
})();
</script>
