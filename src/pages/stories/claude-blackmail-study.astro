  const HOLD_END = 500;
  const SCATTER_END = 600;
  const REST_END = 660;
  const CYCLE = REST_END;

  const NUM_CLUSTERS = 6;
  const PARTICLES_PER_CLUSTER = 5;
  const NUM_DUST = 14;

  // --- Interfaces ---
  interface Particle {
    clusterId: number;
    orbitAngle: number;
    orbitRadius: number;
    orbitSpeed: number;
    baseAlpha: number;
    radius: number;
    isMigrator: boolean;
    state: 'orbiting' | 'migrating' | 'arrived' | 'scattered' | 'returning';
    startX: number;
    startY: number;
    ctrlOffsetX: number;
    ctrlOffsetY: number;
    migrationProgress: number;
    migrationSpeed: number;
    hesitates: boolean;
    hesitateAt: number;
    departFrame: number;
    rx: number;
    ry: number;
    convAngle: number;
    convSpeed: number;
    scatterAngle: number;
    scatterProgress: number;
  }

  interface DustMote {
    x: number; y: number;
    vx: number; vy: number;
    alpha: number; radius: number;
  }

  const clusterAngles: number[] = [];
  const clusterDirs: number[] = [];
  const clusterSpeeds: number[] = [];

  let particles: Particle[] = [];
  let dust: DustMote[] = [];
  let convergenceAlpha = 0;
  let convergenceRadius = 3;

  // --- Layout helpers ---
  function initClusterLayout() {
    clusterAngles.length = 0;
    clusterDirs.length = 0;
    clusterSpeeds.length = 0;
    for (let i = 0; i < NUM_CLUSTERS; i++) {
      clusterAngles.push((Math.PI * 2 * i) / NUM_CLUSTERS - Math.PI / 2);
      clusterDirs.push(i % 2 === 0 ? 1 : -1);
      clusterSpeeds.push(0.009 + Math.random() * 0.006);
    }
  }

  function clusterPos(idx: number): { x: number; y: number } {
    const rx = Math.min(W * 0.35, W / 2 - 50);
    const ry = Math.min(H * 0.34, H / 2 - 40);
    return {
      x: W / 2 + Math.cos(clusterAngles[idx]) * rx,
      y: H / 2 + Math.sin(clusterAngles[idx]) * ry,
    };
  }

  function cpPos(): { x: number; y: number } {
    return { x: W / 2, y: H / 2 + H * 0.02 };
  }

  // --- Init particles ---
  function initParticles() {
    particles = [];
    for (let ci = 0; ci < NUM_CLUSTERS; ci++) {
      for (let pi = 0; pi < PARTICLES_PER_CLUSTER; pi++) {
        particles.push({
          clusterId: ci,
          orbitAngle: (Math.PI * 2 * pi) / PARTICLES_PER_CLUSTER + Math.random() * 0.5,
          orbitRadius: 18 + Math.random() * 17,
          orbitSpeed: clusterSpeeds[ci] * (0.8 + Math.random() * 0.4) * clusterDirs[ci],
          baseAlpha: 0.15 + Math.random() * 0.1,
          radius: 1.8 + Math.random() * 1.2,
          isMigrator: false,
          state: 'orbiting',
          startX: 0, startY: 0,
          ctrlOffsetX: 0, ctrlOffsetY: 0,
          migrationProgress: 0,
          migrationSpeed: 0,
          hesitates: false,
          hesitateAt: 0.4 + Math.random() * 0.2,
          departFrame: 0,
          rx: 0, ry: 0,
          convAngle: Math.random() * Math.PI * 2,
          convSpeed: 0.025 + Math.random() * 0.02,
          scatterAngle: 0,
          scatterProgress: 0,
        });
      }
    }

    dust = [];
    for (let i = 0; i < NUM_DUST; i++) {
      dust.push({
        x: Math.random() * Math.max(W, 400),
        y: Math.random() * Math.max(H, 380),
        vx: (Math.random() - 0.5) * 0.24,
        vy: (Math.random() - 0.5) * 0.24,
        alpha: 0.04 + Math.random() * 0.03,
        radius: 1 + Math.random() * 0.8,
      });
    }
  }

  // --- Assign migrators for a new cycle ---
  function assignCycle() {
    particles.forEach(p => {
      p.isMigrator = false;
      p.state = 'orbiting';
      p.migrationProgress = 0;
      p.scatterProgress = 0;
    });

    const order = [0, 1, 2, 3, 4, 5];
    for (let i = 5; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [order[i], order[j]] = [order[j], order[i]];
    }

    for (let ci = 0; ci < NUM_CLUSTERS; ci++) {
      const pool = particles.filter(p => p.clusterId === ci);
      const migrator = pool[Math.floor(Math.random() * pool.length)];
      migrator.isMigrator = true;

      const orderIdx = order.indexOf(ci);
      migrator.departFrame = MIGRATE_START + orderIdx * MIGRATE_STAGGER;

      const available = ARRIVAL_TARGET - migrator.departFrame;
      migrator.migrationSpeed = 1 / (available * 0.9);

      const a = Math.random() * Math.PI * 2;
      const d = 50 + Math.random() * 70;
      migrator.ctrlOffsetX = Math.cos(a) * d;
      migrator.ctrlOffsetY = Math.sin(a) * d;

      migrator.hesitates = orderIdx === 2 || orderIdx === 4;
      migrator.hesitateAt = 0.35 + Math.random() * 0.2;
    }

    convergenceAlpha = 0;
    convergenceRadius = 3;
  }

  // --- Bezier ---
  function bez(x0: number, y0: number, cx: number, cy: number, x1: number, y1: number, t: number) {
    const u = 1 - t;
    return { x: u * u * x0 + 2 * u * t * cx + t * t * x1, y: u * u * y0 + 2 * u * t * cy + t * t * y1 };
  }

  function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }
  function clamp01(v: number) { return v < 0 ? 0 : v > 1 ? 1 : v; }

  // --- Resize ---
  function resize() {
    const dpr = window.devicePixelRatio || 1;
    W = canvas!.offsetWidth;
    H = canvas!.offsetHeight;
    canvas!.width = W * dpr;
    canvas!.height = H * dpr;
    ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    dust.forEach(d => {
      if (d.x > W) d.x = Math.random() * W;
      if (d.y > H) d.y = Math.random() * H;
    });
  }

  const ro = new ResizeObserver(() => {
    resize();
    if (reducedMotion) drawStatic();
  });
  ro.observe(canvas);

  // --- Draw ---
  function draw() {
    ctx!.clearRect(0, 0, W, H);
    if (W === 0 || H === 0) return;

    const f = frame % CYCLE;
    const cp = cpPos();

    if (f === 0) assignCycle();

    const isHold = f >= HOLD_START && f < HOLD_END;
    const isScatter = f >= HOLD_END && f < SCATTER_END;
    const isRest = f >= SCATTER_END;

    // --- Dust ---
    for (let i = 0; i < dust.length; i++) {
      const d = dust[i];
      d.x += d.vx;
      d.y += d.vy;
      if (d.x < 0) d.x += W; else if (d.x > W) d.x -= W;
      if (d.y < 0) d.y += H; else if (d.y > H) d.y -= H;
      ctx!.beginPath();
      ctx!.arc(d.x, d.y, d.radius, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(232,232,232,${d.alpha})`;
      ctx!.fill();
    }

    // --- Cluster centers (very dim) ---
    for (let ci = 0; ci < NUM_CLUSTERS; ci++) {
      const c = clusterPos(ci);
      ctx!.beginPath();
      ctx!.arc(c.x, c.y, 2, 0, Math.PI * 2);
      ctx!.fillStyle = 'rgba(232,232,232,0.06)';
      ctx!.fill();
    }

    // --- Particles ---
    let arrivedCount = 0;

    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      const center = clusterPos(p.clusterId);

      // --- State transitions ---
      if (p.isMigrator) {
        if (p.state === 'orbiting' && f >= p.departFrame) {
          p.state = 'migrating';
          p.migrationProgress = 0;
          p.startX = center.x + Math.cos(p.orbitAngle) * p.orbitRadius;
          p.startY = center.y + Math.sin(p.orbitAngle) * p.orbitRadius;
        }

        if (p.state === 'migrating') {
          let speed = p.migrationSpeed;
          if (p.hesitates && Math.abs(p.migrationProgress - p.hesitateAt) < 0.07) {
            speed *= 0.2;
          }
          p.migrationProgress = Math.min(1, p.migrationProgress + speed);

          const ctrlX = (p.startX + cp.x) / 2 + p.ctrlOffsetX;
          const ctrlY = (p.startY + cp.y) / 2 + p.ctrlOffsetY;
          const pos = bez(p.startX, p.startY, ctrlX, ctrlY, cp.x, cp.y, p.migrationProgress);
          p.rx = pos.x;
          p.ry = pos.y;

          if (p.migrationProgress >= 1) {
            p.state = 'arrived';
            p.convAngle = Math.atan2(p.ry - cp.y, p.rx - cp.x);
          }
        }

        if (p.state === 'arrived') {
          arrivedCount++;
          p.convAngle += p.convSpeed;
          const r = 6 + Math.sin(p.convAngle * 0.7) * 2;
          p.rx = cp.x + Math.cos(p.convAngle) * r;
          p.ry = cp.y + Math.sin(p.convAngle) * r;

          if (isScatter) {
            p.state = 'scattered';
            p.scatterProgress = 0;
            p.scatterAngle = Math.atan2(center.y - cp.y, center.x - cp.x) + (Math.random() - 0.5) * 0.5;
          }
        }

        if (p.state === 'scattered') {
          const totalDist = Math.hypot(center.x - cp.x, center.y - cp.y);
          p.scatterProgress = Math.min(1, p.scatterProgress + 0.01);
          const dist = p.scatterProgress * totalDist * 1.05;
          p.rx = cp.x + Math.cos(p.scatterAngle) * dist;
          p.ry = cp.y + Math.sin(p.scatterAngle) * dist;

          if (p.scatterProgress >= 1) {
            p.state = 'orbiting';
            p.orbitAngle = Math.atan2(p.ry - center.y, p.rx - center.x);
          }
        }
      }

      // --- Orbit update ---
      if (p.state === 'orbiting') {
        p.orbitAngle += p.orbitSpeed;
        p.rx = center.x + Math.cos(p.orbitAngle) * p.orbitRadius;
        p.ry = center.y + Math.sin(p.orbitAngle) * p.orbitRadius;
      }

      // --- Rendering ---
      if (p.state === 'orbiting') {
        ctx!.beginPath();
        ctx!.arc(p.rx, p.ry, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(232,232,232,${p.baseAlpha})`;
        ctx!.fill();
      } else if (p.state === 'migrating') {
        const t = p.migrationProgress;
        const cr = Math.round(lerp(232, sR, t));
        const cg = Math.round(lerp(232, sG, t));
        const cb = Math.round(lerp(232, sB, t));
        const alpha = lerp(p.baseAlpha, 0.65, t);
        ctx!.beginPath();
        ctx!.arc(p.rx, p.ry, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${cr},${cg},${cb},${alpha})`;
        ctx!.fill();
        if (t > 0.15) {
          const grad = ctx!.createRadialGradient(p.rx, p.ry, 0, p.rx, p.ry, 9);
          grad.addColorStop(0, `rgba(${cr},${cg},${cb},${0.12 * t})`);
          grad.addColorStop(1, `rgba(${cr},${cg},${cb},0)`);
          ctx!.beginPath();
          ctx!.arc(p.rx, p.ry, 9, 0, Math.PI * 2);
          ctx!.fillStyle = grad;
          ctx!.fill();
        }
      } else if (p.state === 'arrived') {
        const pulse = isHold ? 0.65 + 0.35 * Math.sin(f * 0.2) : 0.65;
        ctx!.beginPath();
        ctx!.arc(p.rx, p.ry, p.radius + 0.5, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${sR},${sG},${sB},${pulse})`;
        ctx!.fill();
        if (isHold) {
          const grad = ctx!.createRadialGradient(p.rx, p.ry, 0, p.rx, p.ry, 10);
          grad.addColorStop(0, `rgba(${sR},${sG},${sB},${0.25 * pulse})`);
          grad.addColorStop(1, `rgba(${sR},${sG},${sB},0)`);
          ctx!.beginPath();
          ctx!.arc(p.rx, p.ry, 10, 0, Math.PI * 2);
          ctx!.fillStyle = grad;
          ctx!.fill();
        }
      } else if (p.state === 'scattered') {
        const t = p.scatterProgress;
        const cr = Math.round(lerp(sR, 232, t));
        const cg = Math.round(lerp(sG, 232, t));
        const cb = Math.round(lerp(sB, 232, t));
        const alpha = lerp(0.65, p.baseAlpha, t);
        ctx!.beginPath();
        ctx!.arc(p.rx, p.ry, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${cr},${cg},${cb},${alpha})`;
        ctx!.fill();
      }
    }

    // --- Convergence point ---
    if (arrivedCount > 0 || convergenceAlpha > 0.01) {
      if (isHold) {
        const flareT = clamp01((f - HOLD_START) / 20);
        convergenceRadius = lerp(3, 12, flareT);
        convergenceAlpha = 0.9;

        const grad2 = ctx!.createRadialGradient(cp.x, cp.y, 0, cp.x, cp.y, 35);
        grad2.addColorStop(0, `rgba(${sR},${sG},${sB},0.35)`);
        grad2.addColorStop(0.5, `rgba(${sR},${sG},${sB},0.12)`);
        grad2.addColorStop(1, `rgba(${sR},${sG},${sB},0)`);
        ctx!.beginPath();
        ctx!.arc(cp.x, cp.y, 35, 0, Math.PI * 2);
        ctx!.fillStyle = grad2;
        ctx!.fill();
      } else if (isScatter || isRest) {
        convergenceAlpha = Math.max(0, convergenceAlpha - 0.025);
        convergenceRadius = Math.max(3, convergenceRadius - 0.2);
      } else if (arrivedCount > 0) {
        convergenceAlpha = lerp(convergenceAlpha, arrivedCount * 0.1, 0.06);
      }

      if (convergenceAlpha > 0.01) {
        ctx!.beginPath();
        ctx!.arc(cp.x, cp.y, convergenceRadius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${sR},${sG},${sB},${convergenceAlpha})`;
        ctx!.fill();
      }
    }
  }

  // --- Static frame for reduced motion ---
  function drawStatic() {
    ctx!.clearRect(0, 0, W, H);
    if (W === 0 || H === 0) return;

    const cp = cpPos();

    for (let i = 0; i < dust.length; i++) {
      const d = dust[i];
      ctx!.beginPath();
      ctx!.arc(d.x, d.y, d.radius, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(232,232,232,${d.alpha})`;
      ctx!.fill();
    }

    for (let ci = 0; ci < NUM_CLUSTERS; ci++) {
      const c = clusterPos(ci);
      ctx!.beginPath();
      ctx!.arc(c.x, c.y, 2, 0, Math.PI * 2);
      ctx!.fillStyle = 'rgba(232,232,232,0.06)';
      ctx!.fill();
    }

    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      const center = clusterPos(p.clusterId);

      if (p.isMigrator) {
        const progress = 0.45 + p.clusterId * 0.08;
        const sx = center.x + Math.cos(p.orbitAngle) * p.orbitRadius;
        const sy = center.y + Math.sin(p.orbitAngle) * p.orbitRadius;
        const cx = (sx + cp.x) / 2 + p.ctrlOffsetX;
        const cy = (sy + cp.y) / 2 + p.ctrlOffsetY;

        for (let t = 0; t <= progress; t += 0.04) {
          const pt = bez(sx, sy, cx, cy, cp.x, cp.y, t);
          const a = 0.03 + t * 0.07;
          const cr = Math.round(lerp(232, sR, t));
          const cg = Math.round(lerp(232, sG, t));
          const cb = Math.round(lerp(232, sB, t));
          ctx!.beginPath();
          ctx!.arc(pt.x, pt.y, 1, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(${cr},${cg},${cb},${a})`;
          ctx!.fill();
        }

        const pos = bez(sx, sy, cx, cy, cp.x, cp.y, progress);
        const cr = Math.round(lerp(232, sR, progress));
        const cg = Math.round(lerp(232, sG, progress));
        const cb = Math.round(lerp(232, sB, progress));
        ctx!.beginPath();
        ctx!.arc(pos.x, pos.y, p.radius + 0.5, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${cr},${cg},${cb},${lerp(p.baseAlpha, 0.65, progress)})`;
        ctx!.fill();
      } else {
        const x = center.x + Math.cos(p.orbitAngle) * p.orbitRadius;
        const y = center.y + Math.sin(p.orbitAngle) * p.orbitRadius;
        ctx!.beginPath();
        ctx!.arc(x, y, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(232,232,232,${p.baseAlpha})`;
        ctx!.fill();
      }
    }

    const grad = ctx!.createRadialGradient(cp.x, cp.y, 0, cp.x, cp.y, 14);
    grad.addColorStop(0, `rgba(${sR},${sG},${sB},0.15)`);
    grad.addColorStop(1, `rgba(${sR},${sG},${sB},0)`);
    ctx!.beginPath();
    ctx!.arc(cp.x, cp.y, 14, 0, Math.PI * 2);
    ctx!.fillStyle = grad;
    ctx!.fill();
  }

  // --- Loop ---
  function tick() {
    frame++;
    draw();
    rafId = requestAnimationFrame(tick);
  }

  // --- Init ---
  initClusterLayout();
  initParticles();
  assignCycle();
  resize();

  // --- IntersectionObserver ---
  const io = new IntersectionObserver(([e]) => {
    if (e.isIntersecting) {
      if (!rafId && !reducedMotion) rafId = requestAnimationFrame(tick);
    } else {
      cancelAnimationFrame(rafId);
      rafId = 0;
    }
  }, { threshold: 0.01 });

  if (reducedMotion) {
    requestAnimationFrame(() => drawStatic());
  } else {
    io.observe(canvas);
  }

  // --- Cleanup ---
  window.addEventListener('pagehide', () => {
    cancelAnimationFrame(rafId);
    ro.disconnect();
    io.disconnect();
  });
})();
</script>
