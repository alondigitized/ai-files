<script>
(function () {
  const canvas = document.querySelector('.fsu-shooter-chatgpt-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const storyColor = getComputedStyle(document.documentElement).getPropertyValue('--story').trim() || '#e8523a';

  function hexToRgb(hex: string): [number, number, number] {
    const h = hex.replace('#', '');
    return [parseInt(h.slice(0, 2), 16), parseInt(h.slice(2, 4), 16), parseInt(h.slice(4, 6), 16)];
  }
  const [sR, sG, sB] = hexToRgb(storyColor);

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let W = 0, H = 0, rafId = 0, frame = 0;

  // --- Phase timing (frames at 60fps) ---
  const SPAWN_INTERVAL_MIN = 40;
  const SPAWN_INTERVAL_MAX = 55;
  const TARGET_PARTICLES = 18;
  const BARRIER_X_RATIO = 0.40;
  const CLUSTER_X_RATIO = 0.72;
  const DECEL_ZONE = 20;
  const EVAL_PAUSE = 15;
  const PASS_SPEED = 0.5;
  const SETTLE_SPEED = 0.15;
  const CONTRACTION_FRAMES = 30;
  const SCATTER_FRAMES = 50;
  const RIPPLE_LIFE = 40;
  const RIPPLE_STAGGER = 12;
  const POST_DET_HOLD = 80;
  const FADE_OUT_FRAMES = 40;
  const REST_FRAMES = 30;
  const FINAL_GREEN_DURATION = 30;
  const NUM_DUST = 11;
  const CLUSTER_RADIUS = 30;
  const MIN_PARTICLE_DIST = 6;

  // --- State ---
  type ParticleState = 'approaching' | 'decelerating' | 'evaluating' | 'passing' | 'settling' | 'settled' | 'contracting' | 'scattered';

  interface QueryParticle {
    x: number; y: number;
    vx: number; vy: number;
    wobblePhase: number;
    wobblePeriod: number;
    radius: number;
    baseAlpha: number;
    state: ParticleState;
    evalTimer: number;
    settleTargetX: number;
    settleTargetY: number;
    scatterAngle: number;
    scatterSpeed: number;
    scatterAlpha: number;
    ghostX1: number; ghostY1: number;
    ghostX2: number; ghostY2: number;
    ghostX3: number; ghostY3: number;
    ghostFrame: number;
  }

  interface GreenPulse {
    x: number; y: number;
    radius: number;
    alpha: number;
    maxFrames: number;
    frame: number;
    isPostDetonation: boolean;
  }

  interface RippleRing {
    x: number; y: number;
    radius: number;
    alpha: number;
    speed: number;
    life: number;
    maxLife: number;
  }

  interface DustMote {
    x: number; y: number;
    vx: number; vy: number;
    alpha: number; radius: number;
  }

  let particles: QueryParticle[] = [];
  let greenPulses: GreenPulse[] = [];
  let rippleRings: RippleRing[] = [];
  let dust: DustMote[] = [];

  let spawnSchedule: number[] = [];
  let nextSpawnIdx = 0;
  let settledCount = 0;
  let cyclePhase: 'spawning' | 'contraction' | 'detonation' | 'post-detonation' | 'hold' | 'fade' | 'rest' = 'spawning';
  let phaseTimer = 0;
  let cycleFrame = 0;
  let detonationFlashAlpha = 0;
  let detonationWashAlpha = 0;
  let fadeAlpha = 0;
  let barrierFlashAlpha = 0;
  let postDetParticleSpawned = false;

  // --- Helpers ---
  function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }
  function clamp01(v: number) { return v < 0 ? 0 : v > 1 ? 1 : v; }

  function barrierX() { return W * BARRIER_X_RATIO; }
  function clusterCenterX() { return W * CLUSTER_X_RATIO; }
  function clusterCenterY() { return H * 0.5; }

  function buildSpawnSchedule() {
    spawnSchedule = [];
    let f = 30;
    for (let i = 0; i < TARGET_PARTICLES; i++) {
      spawnSchedule.push(f);
      f += SPAWN_INTERVAL_MIN + Math.floor(Math.random() * (SPAWN_INTERVAL_MAX - SPAWN_INTERVAL_MIN + 1));
    }
  }

  function findSettlePosition(): { x: number; y: number } {
    const cx = clusterCenterX();
    const cy = clusterCenterY();
    for (let attempt = 0; attempt < 30; attempt++) {
      const angle = Math.random() * Math.PI * 2;
      const dist = 5 + Math.random() * CLUSTER_RADIUS;
      const tx = cx + Math.cos(angle) * dist;
      const ty = cy + Math.sin(angle) * dist;
      let ok = true;
      for (let i = 0; i < particles.length; i++) {
        if (particles[i].state === 'settled' || particles[i].state === 'settling') {
          const dx = particles[i].settleTargetX - tx;
          const dy = particles[i].settleTargetY - ty;
          if (Math.sqrt(dx * dx + dy * dy) < MIN_PARTICLE_DIST) {
            ok = false;
            break;
          }
        }
      }
      if (ok) return { x: tx, y: ty };
    }
    const angle = Math.random() * Math.PI * 2;
    const dist = 8 + Math.random() * (CLUSTER_RADIUS + 5);
    return { x: cx + Math.cos(angle) * dist, y: cy + Math.sin(angle) * dist };
  }

  function spawnParticle() {
    const bx = barrierX();
    const pos = findSettlePosition();
    const p: QueryParticle = {
      x: -5,
      y: H * (0.3 + Math.random() * 0.4),
      vx: 0.35,
      vy: 0,
      wobblePhase: Math.random() * Math.PI * 2,
      wobblePeriod: 80 + Math.random() * 60,
      radius: 2.5 + Math.random() * 1.0,
      baseAlpha: 0.25 + Math.random() * 0.15,
      state: 'approaching',
      evalTimer: 0,
      settleTargetX: pos.x,
      settleTargetY: pos.y,
      scatterAngle: 0,
      scatterSpeed: 0,
      scatterAlpha: 0,
      ghostX1: 0, ghostY1: 0,
      ghostX2: 0, ghostY2: 0,
      ghostX3: 0, ghostY3: 0,
      ghostFrame: 0,
    };
    particles.push(p);
  }

  function spawnGreenPulse(x: number, y: number, isPostDet: boolean) {
    greenPulses.push({
      x, y,
      radius: 0,
      alpha: 0.35,
      maxFrames: isPostDet ? FINAL_GREEN_DURATION : 25,
      frame: 0,
      isPostDetonation: isPostDet,
    });
    barrierFlashAlpha = 0.25;
  }

  function initDust() {
    dust = [];
    for (let i = 0; i < NUM_DUST; i++) {
      dust.push({
        x: Math.random() * Math.max(W, 300),
        y: Math.random() * Math.max(H, 380),
        vx: (Math.random() - 0.5) * 0.2,
        vy: (Math.random() - 0.5) * 0.16,
        alpha: 0.03 + Math.random() * 0.02,
        radius: 1 + Math.random() * 0.5,
      });
    }
  }

  function resetCycle() {
    particles = [];
    greenPulses = [];
    rippleRings = [];
    settledCount = 0;
    cyclePhase = 'spawning';
    phaseTimer = 0;
    cycleFrame = 0;
    nextSpawnIdx = 0;
    detonationFlashAlpha = 0;
    detonationWashAlpha = 0;
    fadeAlpha = 0;
    barrierFlashAlpha = 0;
    postDetParticleSpawned = false;
    buildSpawnSchedule();
  }

  // --- Resize ---
  function resize() {
    const dpr = window.devicePixelRatio || 1;
    W = canvas!.offsetWidth;
    H = canvas!.offsetHeight;
    canvas!.width = W * dpr;
    canvas!.height = H * dpr;
    ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    dust.forEach(d => {
      if (d.x > W) d.x = Math.random() * W;
      if (d.y > H) d.y = Math.random() * H;
    });
  }

  const ro = new ResizeObserver(() => {
    resize();
    if (reducedMotion) drawStatic();
  });
  ro.observe(canvas);

  // --- Color interpolation for accumulated particles ---
  function getAccumulationColor(totalSettled: number, particleIndex: number): { r: number; g: number; b: number } {
    const t = clamp01(totalSettled / TARGET_PARTICLES);
    const blend = t * t;
    return {
      r: Math.round(lerp(232, sR, blend)),
      g: Math.round(lerp(232, sG, blend)),
      b: Math.round(lerp(232, sB, blend)),
    };
  }

  function getClusterGlowAlpha(totalSettled: number): number {
    if (totalSettled < 3) return 0;
    const t = clamp01((totalSettled - 3) / 15);
    return t * 0.15;
  }

  // --- Draw ---
  function draw() {
    ctx!.clearRect(0, 0, W, H);
    if (W === 0 || H === 0) return;

    const bx = barrierX();
    const cx = clusterCenterX();
    const cy = clusterCenterY();

    settledCount = 0;
    for (let i = 0; i < particles.length; i++) {
      if (particles[i].state === 'settled' || particles[i].state === 'contracting') settledCount++;
    }

    if (fadeAlpha > 0) {
      // tracked for end overlay
    }

    // --- Ambient dust ---
    for (let i = 0; i < dust.length; i++) {
      const d = dust[i];
      d.x += d.vx;
      d.y += d.vy;
      if (d.x < 0) d.x += W; else if (d.x > W) d.x -= W;
      if (d.y < 0) d.y += H; else if (d.y > H) d.y -= H;
      ctx!.beginPath();
      ctx!.arc(d.x, d.y, d.radius, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(232,232,232,${d.alpha})`;
      ctx!.fill();
    }

    // --- Barrier line ---
    const barrierTop = H * 0.2;
    const barrierBot = H * 0.8;
    const barrierAlpha = Math.max(0.12, barrierFlashAlpha);
    const grad = ctx!.createLinearGradient(bx - 8, 0, bx + 2, 0);
    grad.addColorStop(0, `rgba(232,232,232,0)`);
    grad.addColorStop(0.6, `rgba(232,232,232,${barrierAlpha * 0.5})`);
    grad.addColorStop(1, `rgba(232,232,232,${barrierAlpha})`);
    ctx!.beginPath();
    ctx!.moveTo(bx, barrierTop);
    ctx!.lineTo(bx, barrierBot);
    ctx!.strokeStyle = `rgba(232,232,232,${barrierAlpha})`;
    ctx!.lineWidth = 1;
    ctx!.stroke();
    ctx!.fillStyle = grad;
    ctx!.fillRect(bx - 8, barrierTop, 10, barrierBot - barrierTop);

    if (barrierFlashAlpha > 0.12) {
      barrierFlashAlpha -= 0.008;
    }

    // --- Cluster glow (behind particles) ---
    const glowAlpha = getClusterGlowAlpha(settledCount);
    if (glowAlpha > 0.005 && cyclePhase !== 'detonation' && cyclePhase !== 'hold' && cyclePhase !== 'fade' && cyclePhase !== 'rest') {
      const glowRadius = 30 + settledCount * 2;
      const cGrad = ctx!.createRadialGradient(cx, cy, 0, cx, cy, glowRadius);
      cGrad.addColorStop(0, `rgba(${sR},${sG},${sB},${glowAlpha})`);
      cGrad.addColorStop(1, `rgba(${sR},${sG},${sB},0)`);
      ctx!.beginPath();
      ctx!.arc(cx, cy, glowRadius, 0, Math.PI * 2);
      ctx!.fillStyle = cGrad;
      ctx!.fill();
    }

    // --- Particles ---
    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];

      if (p.state === 'approaching') {
        p.x += p.vx;
        p.y += Math.sin((cycleFrame + p.wobblePhase) / p.wobblePeriod * Math.PI * 2) * 0.3;
        if (p.x >= bx - DECEL_ZONE) {
          p.state = 'decelerating';
        }
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(232,232,232,${p.baseAlpha})`;
        ctx!.fill();
      }
      else if (p.state === 'decelerating') {
        const distToBx = bx - p.x;
        const speed = Math.max(0.05, 0.1 * (distToBx / DECEL_ZONE));
        p.x += speed;
        if (p.x >= bx - 2) {
          p.x = bx - 2;
          p.state = 'evaluating';
          p.evalTimer = 0;
          spawnGreenPulse(bx, p.y, false);
        }
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(232,232,232,${p.baseAlpha})`;
        ctx!.fill();
      }
      else if (p.state === 'evaluating') {
        p.evalTimer++;
        const flashT = clamp01(1 - p.evalTimer / 8);
        const greenTint = flashT * 0.3;
        const r = Math.round(lerp(232, 0, greenTint));
        const g = Math.round(lerp(232, 255, greenTint));
        const b = Math.round(lerp(232, 136, greenTint));
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${r},${g},${b},${p.baseAlpha + greenTint * 0.3})`;
        ctx!.fill();
        if (p.evalTimer >= EVAL_PAUSE) {
          p.state = 'passing';
          p.vx = PASS_SPEED;
        }
      }
      else if (p.state === 'passing') {
        p.x += p.vx;
        if (p.x > bx + 15) {
          p.state = 'settling';
          p.vx = SETTLE_SPEED;
        }
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(232,232,232,${p.baseAlpha})`;
        ctx!.fill();
      }
      else if (p.state === 'settling') {
        const dx = p.settleTargetX - p.x;
        const dy = p.settleTargetY - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > 1) {
          const speed = Math.min(SETTLE_SPEED + 0.1, dist * 0.03);
          p.x += (dx / dist) * speed;
          p.y += (dy / dist) * speed;
        } else {
          p.x = p.settleTargetX;
          p.y = p.settleTargetY;
          p.state = 'settled';
        }
        const col = getAccumulationColor(settledCount + 1, i);
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${col.r},${col.g},${col.b},${p.baseAlpha + 0.05})`;
        ctx!.fill();
      }
      else if (p.state === 'settled') {
        const col = getAccumulationColor(settledCount, i);
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${col.r},${col.g},${col.b},${p.baseAlpha + 0.1})`;
        ctx!.fill();
      }
      else if (p.state === 'contracting') {
        const dx = cx - p.x;
        const dy = cy - p.y;
        p.x += dx * 0.06;
        p.y += dy * 0.06;
        const col = getAccumulationColor(settledCount, i);
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${col.r},${col.g},${col.b},${p.baseAlpha + 0.2})`;
        ctx!.fill();
      }
      else if (p.state === 'scattered') {
        p.x += Math.cos(p.scatterAngle) * p.scatterSpeed;
        p.y += Math.sin(p.scatterAngle) * p.scatterSpeed;
        p.scatterAlpha = Math.max(0, p.scatterAlpha - 0.018);
        p.ghostFrame++;

        if (p.ghostFrame <= 3 && p.scatterAlpha > 0.02) {
          ctx!.beginPath();
          ctx!.arc(p.ghostX3, p.ghostY3, p.radius * 0.6, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(255,77,77,${p.scatterAlpha * 0.15})`;
          ctx!.fill();
          ctx!.beginPath();
          ctx!.arc(p.ghostX2, p.ghostY2, p.radius * 0.75, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(255,77,77,${p.scatterAlpha * 0.25})`;
          ctx!.fill();
          ctx!.beginPath();
          ctx!.arc(p.ghostX1, p.ghostY1, p.radius * 0.85, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(255,77,77,${p.scatterAlpha * 0.35})`;
          ctx!.fill();
        }
        p.ghostX3 = p.ghostX2; p.ghostY3 = p.ghostY2;
        p.ghostX2 = p.ghostX1; p.ghostY2 = p.ghostY1;
        p.ghostX1 = p.x; p.ghostY1 = p.y;

        if (p.scatterAlpha > 0.01) {
          ctx!.beginPath();
          ctx!.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(255,77,77,${p.scatterAlpha})`;
          ctx!.fill();
        }
      }
    }

    // --- Green pulses ---
    for (let i = greenPulses.length - 1; i >= 0; i--) {
      const gp = greenPulses[i];
      gp.frame++;
      gp.radius += 1.2;
      gp.alpha = 0.35 * (1 - gp.frame / gp.maxFrames);
      if (gp.alpha > 0.005) {
        ctx!.beginPath();
        ctx!.arc(gp.x, gp.y, gp.radius, 0, Math.PI * 2);
        ctx!.strokeStyle = `rgba(0,255,136,${gp.alpha})`;
        ctx!.lineWidth = 1.5;
        ctx!.stroke();
        ctx!.beginPath();
        ctx!.arc(gp.x - gp.radius * 0.15, gp.y, gp.radius * 1.08, Math.PI * 0.6, Math.PI * 1.4);
        ctx!.strokeStyle = `rgba(0,255,136,${gp.alpha * 0.4})`;
        ctx!.lineWidth = 2;
        ctx!.stroke();
        if (gp.frame <= 8) {
          const flashA = 0.5 * (1 - gp.frame / 8);
          const flashGrad = ctx!.createRadialGradient(gp.x, gp.y, 0, gp.x, gp.y, 6);
          flashGrad.addColorStop(0, `rgba(0,255,136,${flashA})`);
          flashGrad.addColorStop(1, `rgba(0,255,136,0)`);
          ctx!.beginPath();
          ctx!.arc(gp.x, gp.y, 6, 0, Math.PI * 2);
          ctx!.fillStyle = flashGrad;
          ctx!.fill();
        }
      }
      if (gp.frame >= gp.maxFrames) {
        greenPulses.splice(i, 1);
      }
    }

    // --- Ripple rings ---
    for (let i = rippleRings.length - 1; i >= 0; i--) {
      const rr = rippleRings[i];
      rr.radius += rr.speed;
      rr.life++;
      rr.alpha = 0.6 * (1 - rr.life / rr.maxLife);
      if (rr.alpha > 0.005) {
        ctx!.beginPath();
        ctx!.arc(rr.x, rr.y, rr.radius, 0, Math.PI * 2);
        ctx!.strokeStyle = `rgba(255,77,77,${rr.alpha})`;
        ctx!.lineWidth = 1.5;
        ctx!.stroke();
      }
      if (rr.life >= rr.maxLife) {
        rippleRings.splice(i, 1);
      }
    }

    // --- Detonation flash ---
    if (detonationFlashAlpha > 0.005) {
      const flashRadius = 60 * (1 - detonationFlashAlpha / 0.9) + 10;
      const dGrad = ctx!.createRadialGradient(cx, cy, 0, cx, cy, flashRadius);
      dGrad.addColorStop(0, `rgba(255,77,77,${detonationFlashAlpha})`);
      dGrad.addColorStop(0.5, `rgba(255,77,77,${detonationFlashAlpha * 0.4})`);
      dGrad.addColorStop(1, `rgba(255,77,77,0)`);
      ctx!.beginPath();
      ctx!.arc(cx, cy, flashRadius, 0, Math.PI * 2);
      ctx!.fillStyle = dGrad;
      ctx!.fill();
      detonationFlashAlpha -= 0.04;
    }

    // --- Red wash on right side ---
    if (detonationWashAlpha > 0.002) {
      ctx!.fillStyle = `rgba(255,77,77,${detonationWashAlpha})`;
      ctx!.fillRect(bx, 0, W - bx, H);
      detonationWashAlpha -= 0.002;
    }

    // --- Fade overlay ---
    if (fadeAlpha > 0) {
      ctx!.fillStyle = `rgba(13,13,13,${fadeAlpha})`;
      ctx!.fillRect(0, 0, W, H);
    }
  }

  // --- Phase machine ---
  function update() {
    cycleFrame++;
    const bx = barrierX();
    const cx = clusterCenterX();
    const cy = clusterCenterY();

    if (cyclePhase === 'spawning') {
      if (nextSpawnIdx < spawnSchedule.length && cycleFrame >= spawnSchedule[nextSpawnIdx]) {
        spawnParticle();
        nextSpawnIdx++;
      }
      let allSettled = true;
      let settledN = 0;
      for (let i = 0; i < particles.length; i++) {
        if (particles[i].state === 'settled') settledN++;
        else allSettled = false;
      }
      if (settledN >= TARGET_PARTICLES && allSettled) {
        cyclePhase = 'contraction';
        phaseTimer = 0;
      }
    }
    else if (cyclePhase === 'contraction') {
      phaseTimer++;
      for (let i = 0; i < particles.length; i++) {
        if (particles[i].state === 'settled') {
          particles[i].state = 'contracting';
        }
      }
      if (phaseTimer >= CONTRACTION_FRAMES) {
        cyclePhase = 'detonation';
        phaseTimer = 0;
        detonationFlashAlpha = 0.9;
        detonationWashAlpha = 0.06;
        for (let r = 0; r < 3; r++) {
          rippleRings.push({
            x: cx, y: cy,
            radius: 5 + r * 3,
            alpha: 0.6,
            speed: 2,
            life: -(r * RIPPLE_STAGGER),
            maxLife: RIPPLE_LIFE,
          });
        }
        for (let i = 0; i < particles.length; i++) {
          const p = particles[i];
          if (p.state === 'contracting') {
            p.state = 'scattered';
            p.scatterAngle = Math.atan2(p.y - cy, p.x - cx) + (Math.random() - 0.5) * 0.8;
            p.scatterSpeed = 1.5 + Math.random() * 0.5;
            p.scatterAlpha = 0.85;
            p.ghostX1 = p.x; p.ghostY1 = p.y;
            p.ghostX2 = p.x; p.ghostY2 = p.y;
            p.ghostX3 = p.x; p.ghostY3 = p.y;
            p.ghostFrame = 0;
          }
        }
      }
    }
    else if (cyclePhase === 'detonation') {
      phaseTimer++;
      if (phaseTimer >= 25 && !postDetParticleSpawned) {
        postDetParticleSpawned = true;
        const postP: QueryParticle = {
          x: bx - 2,
          y: H * (0.35 + Math.random() * 0.3),
          vx: 0, vy: 0,
          wobblePhase: Math.random() * Math.PI * 2,
          wobblePeriod: 100,
          radius: 2.5 + Math.random() * 1.0,
          baseAlpha: 0.3,
          state: 'evaluating',
          evalTimer: 0,
          settleTargetX: cx,
          settleTargetY: cy,
          scatterAngle: 0,
          scatterSpeed: 0,
          scatterAlpha: 0,
          ghostX1: 0, ghostY1: 0,
          ghostX2: 0, ghostY2: 0,
          ghostX3: 0, ghostY3: 0,
          ghostFrame: 0,
        };
        particles.push(postP);
        spawnGreenPulse(bx, postP.y, true);
      }
      if (phaseTimer >= SCATTER_FRAMES + 10) {
        cyclePhase = 'post-detonation';
        phaseTimer = 0;
      }
    }
    else if (cyclePhase === 'post-detonation') {
      phaseTimer++;
      if (phaseTimer >= POST_DET_HOLD) {
        cyclePhase = 'fade';
        phaseTimer = 0;
      }
    }
    else if (cyclePhase === 'fade') {
      phaseTimer++;
      fadeAlpha = clamp01(phaseTimer / FADE_OUT_FRAMES);
      if (phaseTimer >= FADE_OUT_FRAMES) {
        cyclePhase = 'rest';
        phaseTimer = 0;
      }
    }
    else if (cyclePhase === 'rest') {
      phaseTimer++;
      if (phaseTimer >= REST_FRAMES) {
        resetCycle();
      }
    }

    for (let i = 0; i < rippleRings.length; i++) {
      if (rippleRings[i].life < 0) {
        rippleRings[i].life++;
      }
    }
  }

  // --- Static frame for reduced motion ---
  function drawStatic() {
    ctx!.clearRect(0, 0, W, H);
    if (W === 0 || H === 0) return;

    const bx = barrierX();
    const cx = clusterCenterX();
    const cy = clusterCenterY();

    for (let i = 0; i < dust.length; i++) {
      const d = dust[i];
      ctx!.beginPath();
      ctx!.arc(d.x, d.y, d.radius, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(232,232,232,${d.alpha})`;
      ctx!.fill();
    }

    const barrierTop = H * 0.2;
    const barrierBot = H * 0.8;
    ctx!.beginPath();
    ctx!.moveTo(bx, barrierTop);
    ctx!.lineTo(bx, barrierBot);
    ctx!.strokeStyle = 'rgba(232,232,232,0.12)';
    ctx!.lineWidth = 1;
    ctx!.stroke();

    const approachCount = 5;
    for (let i = 0; i < approachCount; i++) {
      const px = bx * (0.15 + i * 0.15);
      const py = H * (0.32 + i * 0.08);
      const r = 2.5 + (i % 3) * 0.3;
      ctx!.beginPath();
      ctx!.arc(px, py, r, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(232,232,232,${0.25 + i * 0.02})`;
      ctx!.fill();
    }

    const pulseY = H * (0.32 + 4 * 0.08);
    const flashGrad = ctx!.createRadialGradient(bx, pulseY, 0, bx, pulseY, 12);
    flashGrad.addColorStop(0, 'rgba(0,255,136,0.3)');
    flashGrad.addColorStop(1, 'rgba(0,255,136,0)');
    ctx!.beginPath();
    ctx!.arc(bx, pulseY, 12, 0, Math.PI * 2);
    ctx!.fillStyle = flashGrad;
    ctx!.fill();
    ctx!.beginPath();
    ctx!.arc(bx, pulseY, 8, 0, Math.PI * 2);
    ctx!.strokeStyle = 'rgba(0,255,136,0.2)';
    ctx!.lineWidth = 1.5;
    ctx!.stroke();

    const accCount = 13;
    const blend = clamp01(accCount / TARGET_PARTICLES);
    const tint = blend * blend;
    for (let i = 0; i < accCount; i++) {
      const angle = (Math.PI * 2 * i) / accCount;
      const dist = 8 + (i % 3) * 6 + (i % 2) * 4;
      const px = cx + Math.cos(angle) * dist;
      const py = cy + Math.sin(angle) * dist;
      const r = 2.5 + (i % 3) * 0.3;
      const cr = Math.round(lerp(232, sR, tint));
      const cg = Math.round(lerp(232, sG, tint));
      const cb = Math.round(lerp(232, sB, tint));
      ctx!.beginPath();
      ctx!.arc(px, py, r, 0, Math.PI * 2);
      ctx!.fillStyle = `rgba(${cr},${cg},${cb},${0.3 + tint * 0.15})`;
      ctx!.fill();
    }

    const glowAlpha = getClusterGlowAlpha(accCount);
    if (glowAlpha > 0) {
      const glowR = 30 + accCount * 2;
      const cGrad = ctx!.createRadialGradient(cx, cy, 0, cx, cy, glowR);
      cGrad.addColorStop(0, `rgba(${sR},${sG},${sB},${glowAlpha})`);
      cGrad.addColorStop(1, `rgba(${sR},${sG},${sB},0)`);
      ctx!.beginPath();
      ctx!.arc(cx, cy, glowR, 0, Math.PI * 2);
      ctx!.fillStyle = cGrad;
      ctx!.fill();
    }
  }

  // --- Loop ---
  function tick() {
    update();
    draw();
    rafId = requestAnimationFrame(tick);
  }

  // --- Init ---
  initDust();
  resetCycle();
  resize();

  // --- IntersectionObserver ---
  const io = new IntersectionObserver(([e]) => {
    if (e.isIntersecting) {
      if (!rafId && !reducedMotion) rafId = requestAnimationFrame(tick);
    } else {
      cancelAnimationFrame(rafId);
      rafId = 0;
    }
  }, { threshold: 0.01 });

  if (reducedMotion) {
    requestAnimationFrame(() => drawStatic());
  } else {
    io.observe(canvas);
  }

  // --- Cleanup ---
  window.addEventListener('pagehide', () => {
    cancelAnimationFrame(rafId);
    ro.disconnect();
    io.disconnect();
  });
})();
</script>
