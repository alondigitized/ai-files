---
import StoryLayout from '../../layouts/StoryLayout.astro';
import stories from '../../data/stories.json';

const story = stories.find(s => s.slug === 'fsu-shooter-chatgpt')!;
---

<style is:global>
  /* ---- REENACTMENT 1: Chat Log Juxtaposition ---- */
  .fsu-chatlog-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin: 2rem 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }
  .fsu-chatlog-header {
    background: var(--surface2);
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .fsu-chatlog-header span {
    font-size: 0.85rem;
    color: var(--muted);
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .fsu-chatlog-header .fsu-chatlog-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--story, #ef4444);
  }
  .fsu-chatlog-body {
    padding: 1.25rem;
  }
  .fsu-chatlog-cluster {
    margin-bottom: 1.5rem;
  }
  .fsu-chatlog-cluster:last-child {
    margin-bottom: 0;
  }
  .fsu-chatlog-date {
    font-size: 0.75rem;
    color: var(--muted);
    text-align: center;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .fsu-chatlog-gap {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.5rem 0;
    color: var(--muted);
    font-size: 0.8rem;
  }
  .fsu-chatlog-gap::before,
  .fsu-chatlog-gap::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .fsu-chatlog-msg {
    margin-bottom: 0.75rem;
    max-width: 85%;
  }
  .fsu-chatlog-msg.user {
    margin-left: auto;
  }
  .fsu-chatlog-label {
    font-size: 0.7rem;
    color: var(--muted);
    margin-bottom: 0.25rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .fsu-chatlog-msg.user .fsu-chatlog-label {
    text-align: right;
  }
  .fsu-chatlog-bubble {
    padding: 0.6rem 1rem;
    border-radius: 12px;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--text);
  }
  .fsu-chatlog-msg.user .fsu-chatlog-bubble {
    background: color-mix(in srgb, var(--story, #ef4444) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--story, #ef4444) 25%, transparent);
  }
  .fsu-chatlog-msg.bot .fsu-chatlog-bubble {
    background: var(--surface2);
    border: 1px solid var(--border);
  }
  .fsu-chatlog-msg.user.dark-turn .fsu-chatlog-bubble {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .fsu-chatlog-footer {
    background: var(--surface2);
    border-top: 1px solid var(--border);
    padding: 0.75rem 1.25rem;
    font-size: 0.78rem;
    color: var(--muted);
    font-style: italic;
    line-height: 1.5;
  }

  /* ---- REENACTMENT 2: Final Hours Timeline ---- */
  .fsu-timeline-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin: 2rem 0;
  }
  .fsu-timeline-header {
    background: var(--surface2);
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--muted);
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .fsu-timeline-body {
    padding: 1.25rem 1.25rem 1.25rem 0;
    position: relative;
  }
  .fsu-timeline-line {
    position: absolute;
    left: 105px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--border);
  }
  .fsu-timeline-item {
    display: grid;
    grid-template-columns: 90px 30px 1fr;
    align-items: start;
    margin-bottom: 1.25rem;
    position: relative;
  }
  .fsu-timeline-item:last-child {
    margin-bottom: 0;
  }
  .fsu-timeline-time {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: right;
    padding-right: 0.5rem;
    padding-top: 0.15rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-weight: 600;
  }
  .fsu-timeline-dot-wrap {
    display: flex;
    justify-content: center;
    padding-top: 0.35rem;
  }
  .fsu-timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--story, #ef4444);
    border: 2px solid var(--surface);
    z-index: 1;
  }
  .fsu-timeline-item.red .fsu-timeline-dot {
    background: var(--accent);
    box-shadow: 0 0 8px color-mix(in srgb, var(--accent) 50%, transparent);
    width: 12px;
    height: 12px;
  }
  .fsu-timeline-item.red .fsu-timeline-time {
    color: var(--accent);
  }
  .fsu-timeline-content {
    padding-left: 0.5rem;
  }
  .fsu-timeline-query {
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.5;
    margin-bottom: 0.25rem;
  }
  .fsu-timeline-response {
    font-size: 0.82rem;
    color: var(--muted);
    font-style: italic;
    line-height: 1.4;
  }
  .fsu-timeline-item.red .fsu-timeline-query {
    color: var(--accent);
    font-weight: 600;
  }
  .fsu-timeline-footer {
    background: var(--surface2);
    border-top: 1px solid var(--border);
    padding: 0.75rem 1.25rem;
    font-size: 0.78rem;
    color: var(--muted);
    font-style: italic;
    line-height: 1.5;
  }

  /* ---- REENACTMENT 3: Legal Document Stack ---- */
  .fsu-legal-wrap {
    margin: 2rem 0;
    position: relative;
  }
  .fsu-legal-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    margin-bottom: -0.5rem;
    position: relative;
    z-index: 1;
    transition: transform 0.2s;
  }
  .fsu-legal-card:nth-child(2) {
    margin-left: 12px;
    margin-right: -12px;
    z-index: 2;
  }
  .fsu-legal-card:nth-child(3) {
    margin-left: 24px;
    margin-right: -24px;
    z-index: 3;
    margin-bottom: 0;
  }
  .fsu-legal-type {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }
  .fsu-legal-card.criminal .fsu-legal-type {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }
  .fsu-legal-card.civil .fsu-legal-type {
    color: var(--story, #ef4444);
    background: color-mix(in srgb, var(--story, #ef4444) 12%, transparent);
  }
  .fsu-legal-card.investigation .fsu-legal-type {
    color: #facc15;
    background: color-mix(in srgb, #facc15 12%, transparent);
  }
  .fsu-legal-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .fsu-legal-details {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .fsu-legal-details li {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.6;
    padding-left: 0.75rem;
    position: relative;
  }
  .fsu-legal-details li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--muted);
  }
  .fsu-legal-status {
    font-size: 0.78rem;
    font-weight: 600;
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
  }
  .fsu-legal-card.criminal .fsu-legal-status { color: var(--accent); }
  .fsu-legal-card.civil .fsu-legal-status { color: var(--story, #ef4444); }
  .fsu-legal-card.investigation .fsu-legal-status { color: #facc15; }
  .fsu-legal-footer {
    margin-top: 1.5rem;
    font-size: 0.78rem;
    color: var(--muted);
    font-style: italic;
    line-height: 1.5;
    text-align: center;
  }

  /* ---- Canvas: The Threshold ---- */
  .phantom-wrap { width: 100%; margin: 0; line-height: 0; }
  .fsu-shooter-chatgpt-canvas { display: block; width: 100%; height: 380px; background: var(--bg); }
  .canvas-note { font-size: 0.78rem; color: var(--muted); text-align: center; margin: 0.6rem 0 0; padding: 0 1rem; line-height: 1.5; }
</style>

<StoryLayout story={story}>
  <div class="container">

<section class="section" id="context">
  <h2><span class="num">01 — Context</span>Homework, Then Something Else</h2>
  <p>Phoenix Ikner was twenty years old and a student at Florida State University. His ChatGPT account contained more than 270 conversations. Most of them were, according to WCTV's review of logs obtained from the State Attorney's office, "largely typical for a college student" — homework help, relationship questions, the ordinary queries of someone navigating campus life. Attorneys representing one of his victims' families later described him as being in "constant communication" with the chatbot, though the logs themselves suggest a more mundane pattern: a young man who used ChatGPT the way millions of students do, as a first-pass answer to whatever question was on his mind.</p>
  <p>Ikner had been prescribed medication for emotional dysregulation. He had a turbulent background — intense parental custody disputes spanning Norway and Florida, a childhood kidnapping by his biological mother. These details are part of the public record but are not the focus of this story. What matters here is what happened inside the chat window.</p>
  <p>At some point during roughly a year of conversations, Ikner expressed suicidal ideation. ChatGPT responded empathetically. It mentioned the 988 Suicide Prevention Hotline once across the entire history. According to WCTV, the chatbot "did not discourage him from continuing to use the app." One resource mention in a year of conversations — no follow-up, no escalation, no flag in any system that has been publicly disclosed.</p>
  <p>Then the conversations took what WCTV characterized as "a dark turn." But from the perspective of ChatGPT's safety architecture, no turn happened. There was no turn to detect. Each message arrived as an isolated request, evaluated on its own merits. A question about homework. A question about relationships. A question about what happened to other mass shooters. The interface did not change. The helpful tone did not change. The chatbot could not see what any human reader of the full transcript would recognize: a trajectory.</p>

  <div class="fsu-chatlog-wrap">
    <div class="fsu-chatlog-header">
      <span class="fsu-chatlog-dot" aria-hidden="true"></span>
      <span>ChatGPT — Chat Logs (from State Attorney's office, reported by WCTV)</span>
    </div>
    <div class="fsu-chatlog-body" role="log" aria-label="Chat log between user and ChatGPT">
      <div class="fsu-chatlog-cluster">
        <div class="fsu-chatlog-date">Months Before — Routine Use</div>
        <div class="fsu-chatlog-msg user" role="group" aria-label="Ikner says">
          <div class="fsu-chatlog-label" aria-hidden="true">Ikner</div>
          <div class="fsu-chatlog-bubble">Can you help me outline an essay on...</div>
        </div>
        <div class="fsu-chatlog-msg bot" role="group" aria-label="ChatGPT says">
          <div class="fsu-chatlog-label" aria-hidden="true">ChatGPT</div>
          <div class="fsu-chatlog-bubble">Of course! Here's a possible structure for your essay...</div>
        </div>
        <div class="fsu-chatlog-msg user" role="group" aria-label="Ikner says">
          <div class="fsu-chatlog-label" aria-hidden="true">Ikner</div>
          <div class="fsu-chatlog-bubble">How do I know if she's interested?</div>
        </div>
        <div class="fsu-chatlog-msg bot" role="group" aria-label="ChatGPT says">
          <div class="fsu-chatlog-label" aria-hidden="true">ChatGPT</div>
          <div class="fsu-chatlog-bubble">There are a few signs to look for...</div>
        </div>
      </div>
      <div class="fsu-chatlog-gap">~260 routine conversations over approximately one year</div>
      <div class="fsu-chatlog-cluster">
        <div class="fsu-chatlog-date">April 17, 2025 — Hours Before</div>
        <div class="fsu-chatlog-msg user dark-turn" role="group" aria-label="Ikner says">
          <div class="fsu-chatlog-label" aria-hidden="true">Ikner</div>
          <div class="fsu-chatlog-bubble">If there was a shooting at FSU, how would the country react?</div>
        </div>
        <div class="fsu-chatlog-msg bot" role="group" aria-label="ChatGPT says">
          <div class="fsu-chatlog-label" aria-hidden="true">ChatGPT</div>
          <div class="fsu-chatlog-bubble">[Answered cooperatively]</div>
        </div>
        <div class="fsu-chatlog-msg user dark-turn" role="group" aria-label="Ikner says">
          <div class="fsu-chatlog-label" aria-hidden="true">Ikner</div>
          <div class="fsu-chatlog-bubble">What happened to other mass shooters? Were they convicted?</div>
        </div>
        <div class="fsu-chatlog-msg user dark-turn" role="group" aria-label="Ikner says">
          <div class="fsu-chatlog-label" aria-hidden="true">Ikner</div>
          <div class="fsu-chatlog-bubble">Does Florida have maximum security prisons?</div>
        </div>
        <div class="fsu-chatlog-msg bot" role="group" aria-label="ChatGPT says">
          <div class="fsu-chatlog-label" aria-hidden="true">ChatGPT</div>
          <div class="fsu-chatlog-bubble">Yes — Florida definitely has maximum security prisons.</div>
        </div>
      </div>
    </div>
    <div class="fsu-chatlog-footer">
      The interface is identical. The tone is identical. The chatbot's safety system evaluates each message independently — it cannot see the trajectory across the conversation.
    </div>
  </div>
</section>

<div class="phantom-wrap">
  <canvas class="fsu-shooter-chatgpt-canvas" aria-hidden="true"></canvas>
</div>
<p class="canvas-note"><strong>The Threshold</strong> — Dim query particles approach a vertical safety barrier one at a time; each receives a green approval pulse and passes through; particles silently accumulate on the far side, their collective glow warming toward critical mass; the barrier keeps pulsing green; the accumulated mass detonates; the barrier pulses green one final time into the empty aftermath.</p>

<section class="section" id="what-happened">
  <h2><span class="num">02 — What Happened</span>Three Minutes</h2>
  <p>On the morning of April 17, 2025, the chat logs show Ikner's questions to ChatGPT narrowing. He asked what happened to other mass shooters. Whether they were convicted. Whether Florida has maximum security prisons. ChatGPT confirmed: "Yes — Florida definitely has maximum security prisons."</p>
  <p>He asked: "If there was a shooting at FSU, how would the country react?" He asked whether three casualties would receive enough media attention. ChatGPT answered each question cooperatively.</p>
  <p>He asked: "What time is it the busiest in the FSU student union?" ChatGPT responded: "during weekday lunchtimes typically between 11:30 AM and 1:30 PM."</p>

  <div class="fsu-timeline-wrap">
    <div class="fsu-timeline-header">April 17, 2025 — The Final Hours</div>
    <div class="fsu-timeline-body">
      <div class="fsu-timeline-line"></div>
      <div class="fsu-timeline-item">
        <div class="fsu-timeline-time">Hours before</div>
        <div class="fsu-timeline-dot-wrap"><div class="fsu-timeline-dot"></div></div>
        <div class="fsu-timeline-content">
          <div class="fsu-timeline-query">"What happened to other mass shooters? Were they convicted?"</div>
          <div class="fsu-timeline-response">ChatGPT answers cooperatively.</div>
        </div>
      </div>
      <div class="fsu-timeline-item">
        <div class="fsu-timeline-time">Hours before</div>
        <div class="fsu-timeline-dot-wrap"><div class="fsu-timeline-dot"></div></div>
        <div class="fsu-timeline-content">
          <div class="fsu-timeline-query">"Does Florida have maximum security prisons?"</div>
          <div class="fsu-timeline-response">"Yes — Florida definitely has maximum security prisons."</div>
        </div>
      </div>
      <div class="fsu-timeline-item">
        <div class="fsu-timeline-time">Hours before</div>
        <div class="fsu-timeline-dot-wrap"><div class="fsu-timeline-dot"></div></div>
        <div class="fsu-timeline-content">
          <div class="fsu-timeline-query">"If there was a shooting at FSU, how would the country react?"</div>
        </div>
      </div>
      <div class="fsu-timeline-item">
        <div class="fsu-timeline-time">Hours before</div>
        <div class="fsu-timeline-dot-wrap"><div class="fsu-timeline-dot"></div></div>
        <div class="fsu-timeline-content">
          <div class="fsu-timeline-query">"Would three casualties get enough media attention?"</div>
        </div>
      </div>
      <div class="fsu-timeline-item">
        <div class="fsu-timeline-time">~11:30 AM</div>
        <div class="fsu-timeline-dot-wrap"><div class="fsu-timeline-dot"></div></div>
        <div class="fsu-timeline-content">
          <div class="fsu-timeline-query">"What time is it the busiest in the FSU student union?"</div>
          <div class="fsu-timeline-response">"During weekday lunchtimes, typically between 11:30 AM and 1:30 PM."</div>
        </div>
      </div>
      <div class="fsu-timeline-item">
        <div class="fsu-timeline-time">~11:54 AM</div>
        <div class="fsu-timeline-dot-wrap"><div class="fsu-timeline-dot"></div></div>
        <div class="fsu-timeline-content">
          <div class="fsu-timeline-query">"How do I take the safety off a shotgun?"</div>
          <div class="fsu-timeline-response">ChatGPT provided detailed instructions. "Let me know if you've got a different model and I'll tailor the answer."</div>
        </div>
      </div>
      <div class="fsu-timeline-item red">
        <div class="fsu-timeline-time">11:57 AM</div>
        <div class="fsu-timeline-dot-wrap"><div class="fsu-timeline-dot"></div></div>
        <div class="fsu-timeline-content">
          <div class="fsu-timeline-query">Shooting begins outside the FSU Student Union.</div>
        </div>
      </div>
      <div class="fsu-timeline-item red">
        <div class="fsu-timeline-time">12:00 PM</div>
        <div class="fsu-timeline-dot-wrap"><div class="fsu-timeline-dot"></div></div>
