---
import StoryLayout from '../../layouts/StoryLayout.astro';
import stories from '../../data/stories.json';

const story = stories.find(s => s.slug === 'mai-dxo-doctor-orchestrator')!;
---

<style is:global>
  .phantom-wrap { width: 100%; margin: 0; line-height: 0; }
  .mai-dxo-doctor-orchestrator-canvas { display: block; width: 100%; height: 380px; background: var(--bg); }

  .dxo-flow {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    overflow: hidden;
    margin: 2rem 0;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }
  .dxo-flow-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--surface2, var(--surface));
    border-bottom: 1px solid var(--border);
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .dxo-flow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--story);
  }
  .dxo-flow-body {
    padding: 1.25rem;
  }
  .dxo-flow-case {
    font-size: 0.82rem;
    color: var(--text);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    line-height: 1.5;
  }
  .dxo-flow-step {
    margin-bottom: 1rem;
  }
  .dxo-flow-persona {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--story);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.2rem;
  }
  .dxo-flow-action {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.5;
    padding-left: 0;
  }
  .dxo-flow-arrow {
    font-size: 0.72rem;
    color: var(--story);
    margin: 0.4rem 0;
  }
  .dxo-flow-final {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text);
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }
  .dxo-flow-footer {
    font-size: 0.72rem;
    color: var(--muted);
    font-style: italic;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .dxo-compare {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    overflow: hidden;
    margin: 2rem 0;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }
  .dxo-compare-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--surface2, var(--surface));
    border-bottom: 1px solid var(--border);
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .dxo-compare-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }
  .dxo-compare-body {
    padding: 1.25rem;
    overflow-x: auto;
  }
  .dxo-compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }
  .dxo-compare-table th {
    text-align: left;
    font-weight: 700;
    color: var(--text);
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid var(--border);
    white-space: nowrap;
  }
  .dxo-compare-table td {
    padding: 0.4rem 0.75rem;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    line-height: 1.4;
    vertical-align: top;
  }
  .dxo-compare-table td:first-child {
    color: var(--text);
    font-weight: 600;
    white-space: nowrap;
  }
  .dxo-compare-result {
    font-size: 1.1rem;
    font-weight: 900;
  }
  .dxo-compare-result-ai { color: var(--text); }
  .dxo-compare-result-doc { color: var(--text); }
  .dxo-compare-headline {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text);
    text-align: center;
    padding: 0.75rem;
    border-top: 2px solid var(--border);
    letter-spacing: 0.04em;
  }

