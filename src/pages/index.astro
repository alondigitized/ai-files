          <!-- Slide 1: Sydney -->
          <div class="ep-slide" style="--ep-color:#e879f9;--ep-bg-from:#2a0040;--ep-bg-to:#0d0020;--ep-grid:rgba(232,121,249,0.04);--ep-hover:rgba(232,121,249,0.4);">
            <a class="featured" href="/stories/sydney">
              <div class="featured-visual">
