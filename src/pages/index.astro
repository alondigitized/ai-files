  <script>
    (function () {
      const track = document.getElementById('ep-track') as HTMLElement | null;
      const dots = document.querySelectorAll<HTMLButtonElement>('.ep-dot');
      const total = 3;
      let current = 0;
      let autoTimer: ReturnType<typeof setInterval> | null = null;

      function goTo(idx: number) {
        current = (idx + total) % total;
        if (track) track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
      }

      function startAuto() {
        autoTimer = setInterval(() => goTo(current + 1), 6000);
      }

      function stopAuto() {
        if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
      }

      document.getElementById('ep-prev')?.addEventListener('click', () => { stopAuto(); goTo(current - 1); startAuto(); });
      document.getElementById('ep-next')?.addEventListener('click', () => { stopAuto(); goTo(current + 1); startAuto(); });
      dots.forEach(d => d.addEventListener('click', () => { stopAuto(); goTo(Number(d.dataset.idx)); startAuto(); }));

      const carousel = document.getElementById('ep-carousel');
      carousel?.addEventListener('mouseenter', stopAuto);
      carousel?.addEventListener('mouseleave', startAuto);

      // Touch swipe
      let touchX = 0;
      carousel?.addEventListener('touchstart', (e: TouchEvent) => { touchX = e.touches[0].clientX; }, { passive: true });
      carousel?.addEventListener('touchend', (e: TouchEvent) => {
        const dx = touchX - e.changedTouches[0].clientX;
        if (Math.abs(dx) > 40) { stopAuto(); goTo(current + (dx > 0 ? 1 : -1)); startAuto(); }
      }, { passive: true });

      startAuto();
    })();
  </script>

  <script>
    (function () {
      const cue = document.getElementById('scroll-cue');
      if (!cue) return;
      let hidden = false;
      window.addEventListener('scroll', () => {
        if (!hidden && window.scrollY > 80) {
          hidden = true;
          cue.classList.add('hidden');
        }
      }, { passive: true });
    })();
  </script>

  <script>
    (function () {
      /* ── Edition Canvas Animations ── */
      const demonsEl = document.querySelector('.demons-canvas') as HTMLCanvasElement | null;
      const angelsEl = document.querySelector('.angels-canvas') as HTMLCanvasElement | null;
      if (!demonsEl || !angelsEl) return;

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let activeSide = 'dark';
      (window as any).__setEditionSide = (s: string) => { activeSide = s; };

      function setupCanvas(canvas: HTMLCanvasElement) {
        const ctx = canvas.getContext('2d')!;
        const dpr = window.devicePixelRatio || 1;
        function resize() {
          const r = canvas.getBoundingClientRect();
          canvas.width = r.width * dpr;
          canvas.height = r.height * dpr;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        }
        const ro = new ResizeObserver(resize);
        ro.observe(canvas);
        resize();
        return { ctx, dpr, ro };
      }

      /* ── Demons Canvas ── */
      const dCtx = setupCanvas(demonsEl);
      interface DemonParticle { x: number; y: number; vy: number; vx: number; size: number; alpha: number; }
      const dParticles: DemonParticle[] = [];
      function initDemons() {
        const r = demonsEl!.getBoundingClientRect();
        dParticles.length = 0;
        for (let i = 0; i < 20; i++) {
          dParticles.push({
            x: Math.random() * r.width,
            y: Math.random() * r.height,
            vy: 0.15 + Math.random() * 0.3,
            vx: (Math.random() - 0.5) * 0.3,
            size: 1 + Math.random() * 1.5,
            alpha: 0.3 + Math.random() * 0.5,
          });
        }
      }
      initDemons();
      let dGlitchTimer = 0;
      interface Glitch { x: number; y: number; dx: number; alpha: number; life: number; }
      const dGlitches: Glitch[] = [];
      interface Pulse { x: number; y: number; alpha: number; }
      const dPulses: Pulse[] = [];

      function drawDemons(frame: number) {
        const c = dCtx.ctx;
        const r = demonsEl!.getBoundingClientRect();
        const w = r.width, h = r.height;
        const isActive = activeSide === 'dark';
        const speedMul = isActive ? 1 : 0.25;
        const alphaMul = isActive ? 1 : 0.3;

        c.clearRect(0, 0, w, h);
        c.fillStyle = '#0d0d0d';
        c.fillRect(0, 0, w, h);

        // Grid
        const gridAlpha = 0.06 * alphaMul;
        c.strokeStyle = `rgba(255,77,77,${gridAlpha})`;
        c.lineWidth = 0.5;
        for (let x = 0; x < w; x += 40) {
          c.beginPath(); c.moveTo(x, 0); c.lineTo(x, h); c.stroke();
        }
        for (let y = 0; y < h; y += 40) {
          c.beginPath(); c.moveTo(0, y); c.lineTo(w, y); c.stroke();
        }

        // Glitch segments
        dGlitchTimer += speedMul;
        if (dGlitchTimer > 60 && Math.random() < 0.03 * speedMul) {
          dGlitchTimer = 0;
          const gx = Math.floor(Math.random() * (w / 40)) * 40;
          const gy = Math.floor(Math.random() * (h / 40)) * 40;
          dGlitches.push({ x: gx, y: gy, dx: (Math.random() - 0.5) * 6, alpha: 0.4, life: 30 });
        }
        for (let i = dGlitches.length - 1; i >= 0; i--) {
          const g = dGlitches[i];
          g.life -= speedMul;
          g.alpha *= 0.95;
          if (g.life <= 0) { dGlitches.splice(i, 1); continue; }
          c.strokeStyle = `rgba(255,77,77,${g.alpha * alphaMul})`;
          c.lineWidth = 1;
          const vertical = Math.random() > 0.5;
          c.beginPath();
          if (vertical) {
            c.moveTo(g.x + g.dx, g.y); c.lineTo(g.x + g.dx, g.y + 40);
          } else {
            c.moveTo(g.x, g.y + g.dx); c.lineTo(g.x + 40, g.y + g.dx);
          }
          c.stroke();
        }

        // Pulses on intersections
        if (Math.random() < 0.02 * speedMul) {
          const px = Math.floor(Math.random() * (w / 40)) * 40;
          const py = Math.floor(Math.random() * (h / 40)) * 40;
          dPulses.push({ x: px, y: py, alpha: 0.6 });
        }
        for (let i = dPulses.length - 1; i >= 0; i--) {
          const p = dPulses[i];
          p.alpha *= 0.93;
          if (p.alpha < 0.02) { dPulses.splice(i, 1); continue; }
          c.beginPath();
          c.arc(p.x, p.y, 3, 0, Math.PI * 2);
          c.fillStyle = `rgba(255,77,77,${p.alpha * alphaMul})`;
          c.fill();
        }

        // Particles
        for (const p of dParticles) {
          p.y += p.vy * speedMul;
          p.x += p.vx * speedMul;
          if (p.y > h + 5) { p.y = -5; p.x = Math.random() * w; }
          if (p.x < -5) p.x = w + 5;
          if (p.x > w + 5) p.x = -5;
          c.beginPath();
          c.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          c.fillStyle = `rgba(255,77,77,${p.alpha * alphaMul})`;
          c.fill();
        }
      }

      /* ── Angels Canvas ── */
      const aCtx = setupCanvas(angelsEl);
      interface AngelParticle { x: number; y: number; baseX: number; phase: number; speed: number; size: number; alpha: number; }
      const aParticles: AngelParticle[] = [];
      function initAngels() {
        const r = angelsEl!.getBoundingClientRect();
        aParticles.length = 0;
        for (let i = 0; i < 15; i++) {
          aParticles.push({
            x: Math.random() * r.width,
            y: Math.random() * r.height,
            baseX: r.width * 0.5,
            phase: Math.random() * Math.PI * 2,
            speed: 0.2 + Math.random() * 0.25,
            size: 1.5 + Math.random() * 2,
            alpha: 0.4 + Math.random() * 0.4,
          });
        }
      }
      initAngels();
      let aRingPhase = 0;

      function drawAngels(frame: number) {
        const c = aCtx.ctx;
        const r = angelsEl!.getBoundingClientRect();
        const w = r.width, h = r.height;
        const isActive = activeSide === 'light';
        const speedMul = isActive ? 1 : 0.25;
        const alphaMul = isActive ? 1 : 0.3;

        c.clearRect(0, 0, w, h);
        c.fillStyle = '#f5f0e8';
        c.fillRect(0, 0, w, h);

        const cx = w / 2, cy = h / 2;

        // Concentric rings
        aRingPhase += 0.008 * speedMul;
        for (let i = 0; i < 5; i++) {
          const radius = ((aRingPhase * 60 + i * 40) % (Math.max(w, h) * 0.8));
          const ringAlpha = 0.04 * (1 - radius / (Math.max(w, h) * 0.8)) * alphaMul;
          if (ringAlpha <= 0) continue;
          c.beginPath();
          c.arc(cx, cy, radius, 0, Math.PI * 2);
          c.strokeStyle = `rgba(200,150,62,${ringAlpha})`;
          c.lineWidth = 1;
          c.stroke();
        }

        // Particles
        for (const p of aParticles) {
          p.phase += 0.015 * speedMul;
          p.y -= p.speed * speedMul;
          p.x = p.baseX + Math.sin(p.phase) * 60;
          // Gentle convergence toward center
          p.baseX += (cx - p.baseX) * 0.0004 * speedMul;
          if (p.y < -10) {
            p.y = h + 10;
            p.baseX = Math.random() * w;
            p.phase = Math.random() * Math.PI * 2;
          }

          // Glow halo
          const grad = c.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.size * 4);
          grad.addColorStop(0, `rgba(200,150,62,${0.12 * p.alpha * alphaMul})`);
          grad.addColorStop(1, 'rgba(200,150,62,0)');
          c.fillStyle = grad;
          c.fillRect(p.x - p.size * 4, p.y - p.size * 4, p.size * 8, p.size * 8);

          // Core dot
          c.beginPath();
          c.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          c.fillStyle = `rgba(200,150,62,${p.alpha * alphaMul})`;
          c.fill();
        }
      }

      /* ── Animation Loop ── */
      if (reduced) {
        drawDemons(0);
        drawAngels(0);
      } else {
        let frame = 0;
        let rafId: number;
        function tick() {
          frame++;
          drawDemons(frame);
          drawAngels(frame);
          rafId = requestAnimationFrame(tick);
        }
        rafId = requestAnimationFrame(tick);
        window.addEventListener('unload', () => cancelAnimationFrame(rafId));
      }
    })();
  </script>

  <script>
    (function () {
      /* ── Edition Toggle ── */
      const filter = document.getElementById('side-filter');
      if (!filter) return;
      const cards = filter.querySelectorAll<HTMLElement>('.edition-card');
      const sections = document.querySelectorAll<HTMLElement>('.vol-section[data-side]');
      const epBlocks = document.querySelectorAll<HTMLElement>('[data-ep]');

      const contentTarget = document.querySelector('.idx-container') as HTMLElement | null;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function smoothScrollTo(target: HTMLElement, duration: number) {
        const start = window.scrollY;
        const end = target.getBoundingClientRect().top + start - 20;
        const distance = end - start;
        if (Math.abs(distance) < 10) return;
        let startTime: number | null = null;
        function ease(t: number) {
          return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
        }
        function step(time: number) {
          if (!startTime) startTime = time;
          const elapsed = time - startTime;
          const progress = Math.min(elapsed / duration, 1);
          window.scrollTo(0, start + distance * ease(progress));
          if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }

      function switchTo(side: string) {
        document.documentElement.dataset.theme = side;
        cards.forEach(c => c.classList.toggle('active', c.dataset.edition === side));
        sections.forEach(sec => {
          sec.classList.toggle('hidden-by-filter', sec.dataset.side !== side);
        });
        epBlocks.forEach(ep => {
          ep.style.display = ep.dataset.ep === side ? '' : 'none';
        });
        if ((window as any).__setEditionSide) {
          (window as any).__setEditionSide(side);
        }
        if (contentTarget && !reduceMotion) {
          smoothScrollTo(contentTarget, 800);
        }
      }

      cards.forEach(card => {
        card.addEventListener('click', () => switchTo(card.dataset.edition!));
        card.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            switchTo(card.dataset.edition!);
          }
        });
      });
    })();
  </script>

  <script>
    (function () {
      const SUBMITTED_KEY = 'submitted-idea';
      const form = document.getElementById('ideas-form-home');
      const input = document.getElementById('ideas-input-home') as HTMLTextAreaElement | null;
      const thanks = document.getElementById('ideas-thanks-home');
      const topList = document.getElementById('ideas-top-home');

      // If already submitted, hide form
      if (localStorage.getItem(SUBMITTED_KEY) && form && thanks) {
        (form as HTMLElement).hidden = true;
        (thanks as HTMLElement).hidden = false;
      }

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const text = input?.value.trim() ?? '';
          if (!text || text.length > 280) return;
          const btn = form.querySelector('button') as HTMLButtonElement;
          if (btn) { btn.disabled = true; btn.textContent = 'Submitting…'; }
          try {
            const r = await fetch('/api/ideas', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ text }),
            });
            if (r.ok) {
              localStorage.setItem(SUBMITTED_KEY, '1');
              if (form && thanks) {
                (form as HTMLElement).hidden = true;
                (thanks as HTMLElement).hidden = false;
              }
            } else {
              if (btn) { btn.disabled = false; btn.textContent = 'Error — try again'; }
            }
          } catch {
            if (btn) { btn.disabled = false; btn.textContent = 'Error — try again'; }
          }
        });
      }

      // Load top 3 ideas
      if (topList) {
        fetch('/api/ideas?limit=3')
          .then(r => r.json())
          .then((ideas: Array<{ id: string; text: string; votes: number }>) => {
            if (!ideas.length) {
              topList.innerHTML = '<span class="ideas-top-empty">No ideas yet — be the first.</span>';
              return;
            }
            topList.innerHTML = '';
            for (const idea of ideas) {
              const row = document.createElement('div');
              row.className = 'idea-top-row';
              row.innerHTML = `<span class="idea-top-votes">${idea.votes}</span><span class="idea-top-text">${idea.text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</span>`;
              topList.appendChild(row);
            }
          })
          .catch(() => {
            if (topList) topList.innerHTML = '<span class="ideas-top-empty">–</span>';
          });
      }
    })();
  </script>

