---
import BaseLayout from '../layouts/BaseLayout.astro';
import stories from '../data/stories.json';

const SITE = 'https://theaifiles.app';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'The AI Files',
  url: SITE,
  description: 'True stories from the age of artificial intelligence — documented incidents, landmark moments, and cautionary tales.',
};

const activeStories = stories.filter(s => !s.wip);

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'The AI Files — Story Archive',
  url: SITE,
  numberOfItems: activeStories.length,
  itemListElement: [
    ...activeStories.filter(s => (s.side ?? 'dark') === 'dark').sort((a, b) => a.chapter - b.chapter),
    ...activeStories.filter(s => s.side === 'light').sort((a, b) => a.chapter - b.chapter),
  ].map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: s.title,
    url: `${SITE}/stories/${s.slug}`,
    description: s.deck,
  })),
};

const VOLUMES = [
  { num: 1, side: 'dark', color: '#fbbf24', title: 'What Could Go Wrong', tagline: "The stories that'll make you laugh. And then make you wonder." },
  { num: 2, side: 'dark', color: '#f97316', title: 'What It Cost', tagline: 'The stories where the laughing stopped.' },
  { num: 3, side: 'dark', color: '#ff4d4d', title: 'What It Means', tagline: "The stories you can't un-read." },
  { num: 4, side: 'dark', color: '#00ff88', title: "What We're Left With", tagline: 'The stories still being written.' },
  { num: 1, side: 'light', color: '#c8963e', title: 'What Went Right', tagline: 'The stories that gave us hope.' },
];

const VOL_LABELS = ['I','II','III','IV','V'];

const volumeData = VOLUMES.map(v => ({
  ...v,
  label: VOL_LABELS[v.num - 1],
  stories: activeStories
    .filter(s => s.volume === v.num && (s.side ?? 'dark') === v.side)
    .sort((a, b) => a.chapter - b.chapter),
}));

const storyMap = Object.fromEntries(activeStories.map(s => [s.slug, s]));

const pad = (n: number) => String(n).padStart(2, '0');
---

<style is:global>
  /* ── Nav ── */
  .site-nav {
    position: sticky; top: 0; z-index: 100;
    background: var(--nav-bg);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    padding: 0.85rem 2rem;
    display: flex; align-items: center; justify-content: center;
  }
  .nav-logo { font-size: 1rem; font-weight: 800; color: var(--text); text-decoration: none; letter-spacing: -0.01em; }
  .nav-logo span { color: var(--accent); }

  /* ── Masthead ── */
  .masthead {
    position: relative; overflow: hidden;
    padding: 6rem 2rem 5rem;
    background: radial-gradient(ellipse at 30% 50%, var(--bg-deep) 0%, var(--bg) 65%);
    border-bottom: 1px solid var(--border);
    text-align: center;
  }
  .masthead::before {
    content: ''; position: absolute; inset: 0;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 39px, color-mix(in srgb, var(--accent) 4%, transparent) 40px),
      repeating-linear-gradient(90deg, transparent, transparent 39px, color-mix(in srgb, var(--accent) 4%, transparent) 40px);
    pointer-events: none;
  }
  .masthead-inner { max-width: 700px; margin: 0 auto; position: relative; }
  .masthead-eyebrow {
    font-size: 0.72rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 1.5rem;
    display: flex; align-items: center; justify-content: center; gap: 1rem;
  }
  .masthead-eyebrow::before, .masthead-eyebrow::after { content: ''; flex: 0 0 40px; height: 1px; background: var(--border); }
  .masthead-title {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900; letter-spacing: -0.03em; line-height: 1; margin-bottom: 1rem;
  }
  .masthead-title .the { color: var(--muted); font-weight: 300; font-size: 0.5em; display: block; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.25rem; }
  .masthead-title .ai { color: var(--accent); }
  .masthead-tagline {
    font-size: 1.1rem; color: var(--muted);
    max-width: 480px; margin: 1.5rem auto 0;
    line-height: 1.6; font-style: italic;
  }
  .masthead-meta {
    margin-top: 2.5rem;
    display: flex; align-items: center; justify-content: center;
    gap: 1.5rem; font-size: 0.78rem; color: var(--muted); flex-wrap: wrap;
  }
  .masthead-meta .divider { color: var(--border); }
  .masthead-count {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: color-mix(in srgb, var(--accent) 10%, transparent); border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: 2rem; padding: 0.3rem 0.9rem;
    font-size: 0.78rem; color: var(--accent);
  }

  /* ── Side Toggle ── */
  .side-toggle {
    display: flex; justify-content: center; padding: 1.5rem 0 0;
  }
  .side-toggle-track {
    display: grid; grid-template-columns: 1fr 1fr;
    width: 340px; max-width: 90vw;
    border-radius: 0.75rem; overflow: hidden;
    border: 1px solid var(--border);
    position: relative;
  }
  .side-btn {
    position: relative;
    padding: 0.7rem 1rem;
    font-family: inherit; font-size: 0.85rem; font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer; border: none;
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    transition: background 0.3s, color 0.3s, box-shadow 0.3s;
  }
  .side-btn .btn-icon { font-size: 1.1rem; line-height: 1; }

  /* Demons button */
  .side-btn[data-filter="dark"] {
    background: rgba(255,77,77,0.06); color: var(--muted);
  }
  .side-btn[data-filter="dark"]:hover {
    background: rgba(255,77,77,0.1); color: #ff6b6b;
  }
  .side-btn[data-filter="dark"].active {
    background: rgba(255,77,77,0.14); color: #ff4d4d;
    box-shadow: inset 0 0 20px rgba(255,77,77,0.08);
  }

  /* Angels button */
  .side-btn[data-filter="light"] {
    background: rgba(200,150,62,0.06); color: var(--muted);
  }
  .side-btn[data-filter="light"]:hover {
    background: rgba(200,150,62,0.1); color: #d4a94e;
  }
  .side-btn[data-filter="light"].active {
    background: rgba(200,150,62,0.14); color: #c8963e;
    box-shadow: inset 0 0 20px rgba(200,150,62,0.08);
  }

  /* Divider line between buttons */
  .side-toggle-track::after {
    content: ''; position: absolute; top: 20%; bottom: 20%; left: 50%;
    width: 1px; background: var(--border); pointer-events: none;
  }

  .vol-section.hidden-by-filter { display: none; }

  /* ── Container ── */
  .idx-container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }

  /* ── Section header ── */
  .section-header {
    padding: 4rem 0 2rem;
    display: flex; align-items: baseline; justify-content: space-between;
    border-bottom: 1px solid var(--border);
    gap: 1rem; flex-wrap: wrap;
  }
  .section-header h2 {
    font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted);
  }
  .section-header .section-rule { flex: 1; height: 1px; background: var(--border); margin: 0 1rem; }

  /* ── Featured story ── */
  .featured {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 1rem; overflow: hidden; text-decoration: none;
    transition: border-color 0.2s; min-height: 380px;
  }
  .featured:hover { border-color: var(--ep-hover, rgba(255,255,255,0.12)); }
  .featured-visual {
    background: radial-gradient(ellipse at center, var(--ep-bg-from, #2a0040) 0%, var(--ep-bg-to, #0d0020) 100%);
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .featured-visual::before {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 19px, var(--ep-grid, rgba(232,121,249,0.04)) 20px),
      repeating-linear-gradient(90deg, transparent, transparent 19px, var(--ep-grid, rgba(232,121,249,0.04)) 20px);
  }
  .featured-icon {
    font-size: 6rem;
    animation: ep-flicker 2.5s ease-in-out infinite alternate;
    position: relative;
  }
  @keyframes ep-flicker {
    0%   { transform: scale(1);    opacity: 0.85; }
    100% { transform: scale(1.06); opacity: 1; }
  }

  /* ── Editor's Pick carousel ── */
  .ep-carousel { position: relative; margin: 2rem 0; overflow: hidden; border-radius: 1rem; }
  .ep-track { display: flex; transition: transform 0.42s cubic-bezier(0.4, 0, 0.2, 1); }
  .ep-slide { min-width: 100%; flex: 0 0 100%; }
  .ep-slide .featured { border-radius: 0; border: none; margin: 0; }
  .ep-outer-border {
    border: 1px solid var(--border); border-radius: 1rem; overflow: hidden;
    transition: border-color 0.2s;
  }
  .ep-controls {
    display: flex; align-items: center; justify-content: center;
    gap: 1.25rem; margin-top: 0.9rem;
  }
  .ep-btn {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--surface); border: 1px solid var(--border);
    color: var(--muted); cursor: pointer; padding: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.95rem; line-height: 1;
    transition: border-color 0.2s, color 0.2s;
  }
  .ep-btn:hover { border-color: var(--border-hover); color: var(--text); }
  .ep-dots { display: flex; align-items: center; gap: 0.5rem; }
  .ep-dot {
    height: 6px; width: 6px; border-radius: 3px; border: none; padding: 0;
    background: var(--border); cursor: pointer;
    transition: width 0.25s ease, background 0.25s ease;
  }
  .ep-dot.active { width: 20px; background: var(--accent); }
  .featured-content { padding: 2.5rem; display: flex; flex-direction: column; justify-content: center; }
  .featured-eyebrow { font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ep-color, #e879f9); margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.75rem; }
  .featured-badge {
    background: color-mix(in srgb, var(--ep-color, #e879f9) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--ep-color, #e879f9) 40%, transparent);
    border-radius: 2rem; padding: 0.2rem 0.7rem;
    font-size: 0.65rem; font-weight: 700; color: var(--ep-color, #e879f9); letter-spacing: 0.1em;
  }
  .featured-title { font-size: 1.9rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1.15; margin-bottom: 1rem; color: var(--text); }
  .featured-title span { color: var(--ep-color, #e879f9); }
  .featured-deck { font-size: 0.92rem; color: var(--muted); line-height: 1.6; margin-bottom: 1.5rem; }
  .featured-meta { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; font-size: 0.75rem; color: var(--muted); border-top: 1px solid var(--border); padding-top: 1rem; }
  .story-tag { background: var(--surface2); border: 1px solid var(--border); border-radius: 0.35rem; padding: 0.2rem 0.55rem; font-size: 0.72rem; color: var(--muted); }
  .read-link { margin-left: auto; font-size: 0.8rem; color: var(--ep-color, var(--accent)); letter-spacing: 0.05em; }

  /* ── Volume sections ── */
  .vol-section { padding: 4rem 0 0; }
  .vol-header {
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 0.4rem;
  }
  .vol-eyebrow { font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 700; margin-bottom: 0.4rem; }
  .vol-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.1; }
  .vol-tagline { font-size: 0.95rem; color: var(--muted); font-style: italic; max-width: 540px; line-height: 1.55; margin-top: 0.25rem; }
  .vol-pill {
    display: inline-flex; align-items: center; gap: 0.4rem;
    border: 1px solid var(--border); border-radius: 2rem;
    padding: 0.25rem 0.85rem; font-size: 0.72rem; color: var(--muted);
    margin-top: 0.75rem; width: fit-content;
  }

  /* ── Story grid ── */
  .story-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem; padding: 2rem 0 2rem;
  }
  .story-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 0.75rem; padding: 1.75rem;
    text-decoration: none; display: flex; flex-direction: column;
    transition: border-color 0.2s, transform 0.2s;
  }
  .story-card:hover { border-color: var(--border-hover); transform: translateY(-3px); }
  .card-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1.25rem; }
  .card-icon { font-size: 2.5rem; }

  /* Animated Go stone for move-37 card */
  a[href="/stories/move-37"] .card-icon {
    font-size: 0;
    position: relative;
    display: inline-block;
    width: 2.5rem;
    height: 2.5rem;
  }
  a[href="/stories/move-37"] .card-icon::before,
  a[href="/stories/move-37"] .card-icon::after {
    position: absolute;
    top: 0;
    left: 0;
    font-size: 2.5rem;
    line-height: 1;
  }
  a[href="/stories/move-37"] .card-icon::before {
    content: '⚪';
    animation: go-white 6s ease-in-out infinite;
  }
  a[href="/stories/move-37"] .card-icon::after {
    content: '⚫';
    animation: go-black 6s ease-in-out infinite;
  }
  @keyframes go-white {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
  @keyframes go-black {
    0%, 100% { opacity: 0; }
    50%       { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    a[href="/stories/move-37"] .card-icon::before { animation: none; opacity: 1; }
    a[href="/stories/move-37"] .card-icon::after  { animation: none; opacity: 0; }
  }
  .card-chapter { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); }
  .card-title { font-size: 1.15rem; font-weight: 700; color: var(--text); margin-bottom: 0.6rem; line-height: 1.3; letter-spacing: -0.01em; }
  .card-deck { font-size: 0.85rem; color: var(--muted); line-height: 1.55; flex: 1; margin-bottom: 1.25rem; }
  .card-footer { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; font-size: 0.72rem; color: var(--muted); border-top: 1px solid var(--border); padding-top: 1rem; }
  .card-tag { background: var(--surface2); border: 1px solid var(--border); border-radius: 0.3rem; padding: 0.15rem 0.5rem; color: var(--muted); }
  .card-footer .read-link { margin-left: auto; color: var(--muted); letter-spacing: 0.05em; }

  /* ── Subscribe ── */
  .subscribe-section { border-top: 1px solid var(--border); padding: 5rem 0; }
  .subscribe-inner {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: center;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 1rem; padding: 3rem;
  }
  .subscribe-eyebrow { font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; font-weight: 700; }
  .subscribe-title { font-size: clamp(1.4rem, 2.5vw, 1.9rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 0.75rem; }
  .subscribe-deck { font-size: 0.9rem; color: var(--muted); line-height: 1.6; }
  .subscribe-form iframe { width: 100%; border-radius: 0.5rem; border: 1px solid var(--border) !important; }

  /* ── About ── */
  .about {
    border-top: 1px solid var(--border); padding: 4rem 0;
    display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;
  }
  .about h3 { font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem; }
  .about p { font-size: 0.9rem; color: var(--muted); margin-bottom: 0.75rem; }
  .coming-soon { display: flex; flex-direction: column; gap: 0.75rem; }
  .cs-item {
    background: var(--surface); border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: 0 0.5rem 0.5rem 0; padding: 0.75rem 1rem;
    font-size: 0.85rem; color: var(--muted);
  }
  .cs-item span { display: block; font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.2rem; }

  footer { text-align: center; padding: 3rem 2rem; border-top: 1px solid var(--border); color: var(--muted); font-size: 0.82rem; }
  footer a { color: var(--blue); text-decoration: none; }

  /* ── Ideas Section ── */
  .ideas-section { border-top: 1px solid var(--border); padding: 4rem 0; }
  .ideas-inner {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: start;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 1rem; padding: 3rem;
  }
  .ideas-eyebrow { font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.75rem; font-weight: 700; }
  .ideas-title { font-size: clamp(1.3rem, 2.5vw, 1.8rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 0.5rem; }
  .ideas-deck { font-size: 0.85rem; color: var(--muted); line-height: 1.6; margin-bottom: 1.25rem; }
  .ideas-form { display: flex; flex-direction: column; gap: 0.6rem; }
  .ideas-input {
    width: 100%; background: var(--bg); border: 1px solid var(--border);
    border-radius: 0.5rem; color: var(--text); font-size: 0.88rem;
    font-family: inherit; line-height: 1.5; padding: 0.65rem 0.9rem;
    resize: none; box-sizing: border-box; transition: border-color 0.2s;
  }
  .ideas-input:focus { outline: none; border-color: var(--accent); }
  .ideas-btn {
    align-self: flex-start; background: var(--accent); color: #fff;
    border: none; border-radius: 0.5rem; padding: 0.5rem 1.1rem;
    font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: opacity 0.2s;
  }
  .ideas-btn:hover { opacity: 0.85; }
  .ideas-thanks { font-size: 0.82rem; color: var(--muted); }
  .ideas-right { display: flex; flex-direction: column; gap: 0.75rem; }
  .ideas-top-label { font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); font-weight: 700; }
  .ideas-top-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .idea-top-row { display: flex; align-items: baseline; gap: 0.75rem; }
  .idea-top-votes { font-size: 0.85rem; font-weight: 700; color: #f59e0b; min-width: 28px; }
  .idea-top-text { font-size: 0.85rem; color: var(--text); line-height: 1.4; }
  .ideas-top-empty { font-size: 0.82rem; color: var(--muted); }
  .ideas-more-link { font-size: 0.82rem; color: var(--blue); text-decoration: none; margin-top: 0.25rem; }
  .ideas-more-link:hover { text-decoration: underline; }

  @media (max-width: 700px) {
    .featured { grid-template-columns: 1fr; min-height: auto; }
    .featured-visual { min-height: 220px; }
    .featured-title { font-size: 1.5rem; }
    .story-grid { grid-template-columns: 1fr; }
    .about { grid-template-columns: 1fr; gap: 2rem; }
    .masthead-title { font-size: 3.5rem; }
    .site-nav { padding: 0.85rem 1rem; }
    .subscribe-inner { grid-template-columns: 1fr; gap: 2rem; padding: 2rem; }
    .ideas-inner { grid-template-columns: 1fr; gap: 2rem; padding: 2rem; }
  }
</style>

<BaseLayout
  title="The AI Files — True Stories from the Age of Artificial Intelligence"
  description="True stories from the age of artificial intelligence — documented incidents, landmark moments, and cautionary tales. 26 stories across 5 volumes."
  ogImage="https://theaifiles.app/og/default.png"
>
  <script slot="jsonld" type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script slot="jsonld" type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>

  <nav class="site-nav">
    <a href="/" class="nav-logo">The <span>AI</span> Files</a>

  </nav>

  <header class="masthead">
    <div class="masthead-inner">
      <div class="masthead-eyebrow">Archive</div>
      <h1 class="masthead-title">
        <span class="the">The</span>
        <span class="ai">AI</span> Files
      </h1>
      <p class="masthead-tagline" data-side="dark">True stories from the age of artificial intelligence — the blunders, the exploits, and the moments that changed everything.</p>
      <p class="masthead-tagline" data-side="light" style="display:none;">True stories from the age of artificial intelligence — the breakthroughs, the cures, and the moments that gave us hope.</p>
      <div class="masthead-meta">
        <span class="masthead-count">● 26 Stories</span>
        <span class="divider">·</span>
        <span>5 Volumes</span>
      </div>
      <div class="side-toggle" id="side-filter">
        <div class="side-toggle-track">
          <button class="side-btn active" data-filter="dark"><span class="btn-icon">😈</span> Demons</button>
          <button class="side-btn" data-filter="light"><span class="btn-icon">😇</span> Angels</button>
        </div>
      </div>
    </div>
  </header>

  <div class="idx-container">

    <div class="section-header" data-ep="dark">
      <h2>Editor's Pick</h2>
      <div class="section-rule"></div>
    </div>

    <div class="ep-carousel" id="ep-carousel" data-ep="dark">
      <div class="ep-outer-border">
        <div class="ep-track" id="ep-track">

          <!-- Slide 1: Sydney -->
